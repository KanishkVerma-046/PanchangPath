---
import type { Festival } from '../lib/festivals';
import { getFestivalIcon, getFestivalGradient, getFestivalSlug, daysUntil, formatCountdown } from '../lib/festivals';

interface Props {
  festivals: Festival[];
  today: Date;
}

const { festivals, today } = Astro.props;
---

<section class="ff-section">
  <div class="ff-container">

    <!-- Header -->
    <div class="ff-header">
      <div>
        <p class="caption-mono" style="color:var(--color-mute);margin:0 0 6px;">Coming up</p>
        <h2 class="ff-title">
          <span class="en-text">Festivals &amp; Vrats</span>
          <span class="hi-text">त्योहार &amp; व्रत</span>
        </h2>
      </div>
      <a href="/festivals" class="ff-more-link">
        <span class="en-text">Full calendar →</span>
        <span class="hi-text">पूरा कैलेंडर →</span>
      </a>
    </div>

    <!-- Scrollable card strip -->
    <div class="ff-scroll" role="list">
      {festivals.map(f => {
        const days      = daysUntil(today, f.date);
        const countdown = formatCountdown(days);
        const slug      = getFestivalSlug(f);
        const icon      = getFestivalIcon(f);
        const gradient  = getFestivalGradient(f);
        const fd        = new Date(f.date);
        const dateLabel = fd.toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
        const isToday   = days === 0;

        return (
          <a href={`/festivals/${slug}`} class={`ff-card ${isToday ? 'ff-today' : ''}`} role="listitem">
            <!-- Thumbnail -->
            <div class="ff-thumb" style={`background:${gradient}`}>
              <span class="ff-icon" aria-hidden="true">{icon}</span>
              {isToday && <div class="ff-today-glow" aria-hidden="true"></div>}
            </div>

            <!-- Content -->
            <div class="ff-content">
              <!-- Badges row -->
              <div class="ff-badges">
                <span class={`ff-countdown ${isToday ? 'ff-countdown-today' : days <= 7 ? 'ff-countdown-soon' : ''}`}>
                  {isToday && <span class="ff-dot" aria-hidden="true"></span>}
                  {countdown}
                </span>
                <span class={`ff-type ff-type-${f.type}`}>
                  {f.type === 'major' ? '✦ Major' : f.type === 'vrat' ? 'Vrat' : 'Regional'}
                </span>
              </div>

              <!-- Name -->
              <p class="ff-name en-text">{f.name}</p>
              <p class="ff-name hi-text">{f.nameHi}</p>

              <!-- Date -->
              <p class="ff-date">{dateLabel}</p>

              <!-- Description -->
              <p class="ff-desc">{f.description}</p>
            </div>
          </a>
        );
      })}

      <!-- "See all" trailing card -->
      <a href="/festivals" class="ff-card ff-see-all" aria-label="View all festivals">
        <div class="ff-see-all-inner">
          <span class="ff-see-all-icon">📅</span>
          <p class="ff-see-all-text">
            <span class="en-text">View Full Calendar</span>
            <span class="hi-text">पूरा कैलेंडर</span>
          </p>
          <span class="ff-see-all-arrow">→</span>
        </div>
      </a>
    </div>

  </div>
</section>

<style>
.ff-section {
  padding: 48px 0;
  background: var(--color-canvas);
  border-top: 1px solid var(--color-hairline);
  border-bottom: 1px solid var(--color-hairline);
}

.ff-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Header ── */
.ff-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 12px;
}
.ff-title {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.6px;
  color: var(--color-ink);
  margin: 0;
}
.ff-more-link {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-saffron-deep);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.ff-more-link:hover { text-decoration: underline; }

/* ── Scroll strip ── */
.ff-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 10px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: var(--color-hairline) transparent;
}
.ff-scroll::-webkit-scrollbar       { height: 4px; }
.ff-scroll::-webkit-scrollbar-track { background: transparent; }
.ff-scroll::-webkit-scrollbar-thumb { background: var(--color-hairline); border-radius: 2px; }

/* ── On wider screens: wrap into a grid instead of scrolling ── */
@media (min-width: 900px) {
  .ff-scroll {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    overflow-x: visible;
    padding-bottom: 0;
  }
}

/* ── Festival card ── */
.ff-card {
  flex: 0 0 188px;
  scroll-snap-align: start;
  background: var(--color-canvas);
  border: 1px solid var(--color-hairline);
  border-radius: 10px;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.18s, transform 0.18s, border-color 0.18s;
}
.ff-card:hover {
  box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  transform: translateY(-2px);
  border-color: var(--color-saffron);
}
.ff-card.ff-today {
  border-color: var(--color-saffron);
  box-shadow: 0 0 0 2px rgba(255,153,51,0.20);
}

/* ── Thumbnail ── */
.ff-thumb {
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.ff-icon {
  font-size: 42px;
  line-height: 1;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.18));
  position: relative;
  z-index: 1;
}
.ff-today-glow {
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.12);
  animation: ff-pulse 2s ease-in-out infinite;
}
@keyframes ff-pulse {
  0%, 100% { opacity: 0; }
  50%       { opacity: 1; }
}

/* ── Card content ── */
.ff-content {
  padding: 12px 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

/* Badges row */
.ff-badges {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 2px;
}
.ff-countdown {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10.5px;
  font-weight: 700;
  font-family: var(--font-mono, monospace);
  color: var(--color-mute);
  letter-spacing: 0.02em;
}
.ff-countdown-today { color: var(--color-saffron-deep); }
.ff-countdown-soon  { color: #b45309; }
.ff-dot {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-saffron);
  animation: ff-pulse 1.5s ease-in-out infinite;
}
.ff-type {
  font-size: 9.5px;
  font-weight: 600;
  padding: 1px 6px;
  border-radius: 999px;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.ff-type-major    { background: rgba(255,153,51,0.15); color: var(--color-saffron-deep); }
.ff-type-vrat     { background: rgba(124,58,237,0.12); color: #6d28d9; }
.ff-type-regional { background: rgba(14,165,233,0.12); color: #0369a1; }
html.dark .ff-type-major    { background: rgba(255,153,51,0.20); }
html.dark .ff-type-vrat     { background: rgba(167,139,250,0.15); color: #a78bfa; }
html.dark .ff-type-regional { background: rgba(56,189,248,0.15); color: #38bdf8; }

/* Name */
.ff-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Date */
.ff-date {
  font-size: 11px;
  color: var(--color-mute);
  font-family: var(--font-mono, monospace);
  margin: 0;
}

/* Description */
.ff-desc {
  font-size: 11.5px;
  color: var(--color-body-text);
  margin: 0;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: auto;
  padding-top: 4px;
}

/* ── "See all" trailing card ── */
.ff-see-all {
  flex: 0 0 140px;
  border-style: dashed;
  border-color: var(--color-hairline);
  background: var(--color-canvas-soft);
}
.ff-see-all:hover {
  border-style: solid;
  border-color: var(--color-saffron);
  background: var(--color-saffron-soft);
  transform: translateY(-2px);
}
.ff-see-all-inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 20px;
  text-align: center;
}
.ff-see-all-icon  { font-size: 28px; }
.ff-see-all-text  { font-size: 13px; font-weight: 600; color: var(--color-ink); margin: 0; }
.ff-see-all-arrow { font-size: 18px; color: var(--color-saffron); }

@media (min-width: 900px) {
  .ff-card          { flex: unset; }
  .ff-see-all       { display: none; }
}
</style>
