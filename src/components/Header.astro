          <a href="/" class="drawer-link">Moonrise &amp; Moonset</a>
          <a href="/" class="drawer-link">Rahu Kalam</a>
        </div>
      </div>
      <div class="drawer-section">
        <button class="drawer-cat" data-target="m-calendars">
          Calendars <span class="drawer-caret">›</span>
        </button>
        <div class="drawer-sub" id="m-calendars">
          <a href="/calendar" class="drawer-link">Hindu Calendar</a>
          <a href="/calendar" class="drawer-link">Vikram Samvat</a>
          <a href="/calendar" class="drawer-link">Saka Calendar</a>
        </div>
      </div>
