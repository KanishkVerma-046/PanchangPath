</header>

<!-- Overlay for mobile drawer -->
<div id="drawer-overlay" class="drawer-overlay" aria-hidden="true"></div>

<!-- Mobile slide-out drawer -->
<aside id="mobile-drawer" class="mobile-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <div class="drawer-header">
    <a href="/" class="logo-link">
      <span class="logo-om">🕉️</span>
      <span class="logo-text">PanchangPath</span>
    </a>
    <button id="drawer-close" class="hdr-icon-btn" aria-label="Close menu">
