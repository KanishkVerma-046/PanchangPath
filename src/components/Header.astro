    border-radius: var(--radius-sm);
    font-size: 10px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.15s;
  }
  .app-badge:hover { opacity: 0.8; }

  /* Hamburger — hidden on desktop */
  .hamburger-btn { display: none; }

  /* ── Desktop nav bar (second row) ── */
  #desktop-nav {
    height: 38px;
    display: flex;
    align-items: stretch;
  }
  #desktop-nav .header-container { height: 100%; }

  .desktop-nav-list {
    list-style: none;
