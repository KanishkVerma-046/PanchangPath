  .mic-btn.listening { color: var(--color-error); animation: mic-pulse 1s infinite; }
  @keyframes mic-pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

  /* Search dropdown */
  .search-dropdown {
