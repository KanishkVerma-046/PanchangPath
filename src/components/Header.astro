          <a href="/festivals" class="drawer-link">Diwali 2025</a>
          <a href="/festivals" class="drawer-link">Navratri 2025</a>
        </div>
      </div>
      <div class="drawer-section">
        <button class="drawer-cat" data-target="m-jyotish">
          Jyotish <span class="drawer-caret">›</span>
        </button>
        <div class="drawer-sub" id="m-jyotish">
          <a href="/jyotish" class="drawer-link">All Jyotish Calculators</a>
          <a href="/jyotish/kundali" class="drawer-link">Kundali Generator</a>
          <a href="/jyotish/horoscope-match" class="drawer-link">Horoscope Match</a>
          <a href="/jyotish/rashi" class="drawer-link">Rashi Calculator</a>
          <a href="/jyotish/nakshatra" class="drawer-link">Nakshatra Calculator</a>
          <a href="/jyotish/mangal-dosha" class="drawer-link">Mangal Dosha</a>
          <a href="/jyotish/kalasarpa" class="drawer-link">Kalasarpa Yoga</a>
          <a href="/jyotish/sadesati" class="drawer-link">Shani Sadesati</a>
          <a href="/jyotish/baby-names" class="drawer-link">Baby Names</a>
          <a href="/jyotish/gemstone" class="drawer-link">Gemstone Calculator</a>
          <a href="/rashifal" class="drawer-link">Rashifal (Horoscope)</a>
          <a href="/prashnavali" class="drawer-link">Prashnavali Oracle</a>
        </div>
      </div>
      <div class="drawer-section">
        <button class="drawer-cat" data-target="m-planets">
