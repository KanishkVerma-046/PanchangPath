---
// Header.astro — sticky top header with clock, search, lang/region picker, theme switcher, mobile drawer
import LocationPicker from './LocationPicker.astro';
import LanguagePicker from './LanguagePicker.astro';
---

<!-- HEADER -->
<header id="site-header">
  <!-- Top bar -->
  <div id="header-top">
    <div class="header-container">

      <!-- LEFT: Logo -->
      <a href="/" class="logo-link" aria-label="PanchangPath Home">
        <span class="logo-om">🕉️</span>
        <span class="logo-text">PanchangPath</span>
      </a>

      <!-- CENTER: Live clock + search -->
      <div class="header-center">
        <!-- Live clock (links to sunrise page) -->
        <a href="/" class="clock-widget" id="clock-link" title="Today's Panchang">
          <span class="clock-time" id="live-time">00:00:00</span>
          <span class="clock-sep">|</span>
          <span class="clock-date" id="live-date">—</span>
        </a>

        <!-- Search bar -->
        <div class="search-wrap">
          <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            id="search-input"
            class="search-input"
            type="search"
            placeholder="Search panchang, festivals, muhurta…"
            aria-label="Search"
            autocomplete="off"
          />
          <button class="mic-btn" id="mic-btn" title="Voice search" aria-label="Voice search">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="2" width="6" height="11" rx="3"/>
              <path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/>
            </svg>
          </button>
          <!-- Search results dropdown -->
          <div id="search-dropdown" class="search-dropdown" hidden></div>
        </div>
      </div>

      <!-- RIGHT: Controls -->
      <div class="header-right">
        <!-- Language / Region picker -->
        <LanguagePicker />

        <!-- Theme switcher: Modern / Classic -->
        <div class="theme-switcher" id="theme-switcher" title="Switch theme">
          <button class="theme-opt active" id="theme-modern" data-theme="modern">Modern</button>
          <button class="theme-opt" id="theme-classic" data-theme="classic">Classic</button>
        </div>

        <!-- Dark mode -->
        <button id="dark-toggle" class="hdr-icon-btn" title="Toggle dark mode" aria-label="Toggle dark mode">
          <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>

        <!-- Settings -->
        <button class="hdr-icon-btn" id="settings-btn" title="Settings" aria-label="Settings">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        </button>

        <!-- App store badges (desktop only) -->
        <div class="app-badges">
          <a href="#" class="app-badge" title="Get on Google Play" aria-label="Android app">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76a2 2 0 0 0 2.17-.22l11.28-6.51-2.54-2.54L3.18 23.76zM20.77 10.6 17.9 9l-3.18 3.18 3.18 3.18 2.9-1.67a1.94 1.94 0 0 0 0-3.09zM1.08.3A1.94 1.94 0 0 0 .5 1.72v20.56a1.94 1.94 0 0 0 .58 1.42l.07.07 11.52-11.52v-.27L1.15.23l-.07.07zM14.62 7.73 3.35 1.22a2 2 0 0 0-2.17-.22l11 10.99 2.44-3.26z"/></svg>
            <span>Android</span>
          </a>
          <a href="#" class="app-badge" title="Get on App Store" aria-label="iOS app">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.14-2.19 1.28-2.17 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.77M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span>iOS</span>
          </a>
        </div>

        <!-- Location picker -->
        <LocationPicker />

        <!-- Hamburger (mobile) -->
        <button id="hamburger" class="hdr-icon-btn hamburger-btn" aria-label="Open menu" aria-expanded="false">
          <svg id="hamburger-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="close-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="display:none">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Desktop nav categories -->
  <nav id="desktop-nav" aria-label="Main navigation">
    <div class="header-container">
      <ul class="desktop-nav-list">
        <li class="nav-item has-dropdown">
          <a href="/" class="nav-cat">Panchang <span class="nav-caret">▾</span></a>
          <div class="nav-dropdown">
