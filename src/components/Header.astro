          <a href="/muhurta/hora" class="drawer-link">Shubha Hora</a>
          <a href="/muhurta/rahu-kala" class="drawer-link">Rahu Kala</a>
          <a href="/muhurta/lagna" class="drawer-link">Lagna Table</a>
          <a href="/muhurta/abhijit" class="drawer-link">Abhijit Muhurat</a>
          <a href="/muhurta/panchaka" class="drawer-link">Panchaka &amp; Gowri</a>
          <a href="/muhurta/vivah" class="drawer-link">Vivah Muhurat</a>
          <a href="/muhurta/griha-pravesh" class="drawer-link">Griha Pravesh</a>
          <a href="/muhurta/shubha-dates" class="drawer-link">Shubha Dates</a>
        </div>
      </div>
      <div class="drawer-section">
        <button class="drawer-cat" data-target="m-vrat">
          Vrat &amp; Upavas <span class="drawer-caret">›</span>
        </button>
        <div class="drawer-sub" id="m-vrat">
          <a href="/festivals" class="drawer-link">Vrat Calendar</a>
          <a href="/festivals" class="drawer-link">Ekadashi</a>
          <a href="/festivals" class="drawer-link">Pradosh Vrat</a>
        </div>
      </div>
      <div class="drawer-section">
        <button class="drawer-cat" data-target="m-festivals">
