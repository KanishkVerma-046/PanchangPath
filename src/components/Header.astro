    box-shadow: var(--shadow-modal);
    padding: 6px 0;
    z-index: 200;
    display: none;
    animation: fadeIn 0.14s ease both;
  }
  .nav-item.has-dropdown:hover .nav-dropdown { display: block; }

  .dd-link {
    display: block;
    padding: 7px 14px;
    font-size: 13px;
    color: var(--color-body-text);
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
  }
  .dd-link:hover { background: var(--color-canvas-soft-2); color: var(--color-ink); }
  .dd-divider { height: 1px; background: var(--color-hairline); margin: 4px 8px; }
  .dd-link-accent { color: var(--color-saffron-deep) !important; font-weight: 600 !important; }
  .dd-link-accent:hover { background: var(--color-saffron-soft) !important; }

  /* ── Mobile drawer ── */
  .drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(2px);
  }
  .drawer-overlay.open { display: block; }

  .mobile-drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 88vw);
    z-index: 160;
    background: var(--color-canvas);
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .mobile-drawer.open { transform: translateX(0); }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-hairline);
    flex-shrink: 0;
  }

  .drawer-body {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .drawer-search-wrap {
    position: relative;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .drawer-search-input {
    width: 100%;
    height: 36px;
    padding: 0 12px 0 32px;
    background: var(--color-canvas-soft-2);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-ink);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }
  .drawer-search-input:focus { border-color: var(--color-saffron); }

  .drawer-nav { flex: 1; }

  .drawer-section { border-bottom: 1px solid var(--color-hairline); }

  .drawer-cat {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    background: none;
    border: none;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    text-align: left;
    transition: background 0.12s;
  }
  .drawer-cat:hover { background: var(--color-canvas-soft-2); }
  .drawer-cat[aria-expanded="true"] .drawer-caret { transform: rotate(90deg); }

  .drawer-caret {
    font-size: 14px;
    color: var(--color-mute);
    transition: transform 0.2s;
    display: inline-block;
  }

  .drawer-sub {
    display: none;
    padding: 4px 0 8px;
    background: var(--color-canvas-soft);
  }
  .drawer-sub.open { display: block; }

  .drawer-link {
    display: block;
    padding: 9px 28px;
    font-size: 13.5px;
    color: var(--color-body-text);
    text-decoration: none;
    transition: color 0.12s, background 0.12s;
  }
  .drawer-link:hover { color: var(--color-saffron-deep); background: var(--color-saffron-soft); }

  .drawer-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    border-top: 1px solid var(--color-hairline);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .app-badges { display: none; }
    .theme-switcher { display: none; }
  }
  @media (max-width: 768px) {
    #desktop-nav { display: none; }
    .hamburger-btn { display: inline-flex !important; }
    .search-wrap { max-width: none; }
    .clock-widget { display: none; }
    #header-top { height: 52px; }
  }
  @media (max-width: 480px) {
    .app-badges { display: none; }
    .header-container { padding: 0 12px; }
  }
</style>

<script>
  // ── Live clock ──
  function updateClock() {
    const now = new Date();
    const timeEl = document.getElementById('live-time');
    const dateEl = document.getElementById('live-date');
    if (!timeEl || !dateEl) return;

    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    timeEl.textContent = `${h}:${m}:${s}`;

    const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    dateEl.textContent = `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ── Dark mode ──
  const html = document.documentElement;
  const darkToggle = document.getElementById('dark-toggle');
  const mDarkToggle = document.getElementById('m-dark-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');
  const mIconSun = document.getElementById('m-icon-sun');
  const mIconMoon = document.getElementById('m-icon-moon');

  function applyDark(isDark: boolean) {
    if (isDark) {
      html.classList.remove('light');
      html.classList.add('dark');
    } else {
      html.classList.remove('dark');
      html.classList.add('light');
    }
    if (iconSun) iconSun.style.display = isDark ? 'block' : 'none';
    if (iconMoon) iconMoon.style.display = isDark ? 'none' : 'block';
    if (mIconSun) mIconSun.style.display = isDark ? 'block' : 'none';
    if (mIconMoon) mIconMoon.style.display = isDark ? 'none' : 'block';
    localStorage.setItem('dark', String(isDark));
  }

  applyDark(localStorage.getItem('dark') === 'true');

  darkToggle?.addEventListener('click', () => applyDark(!html.classList.contains('dark')));
  mDarkToggle?.addEventListener('click', () => applyDark(!html.classList.contains('dark')));

  // Language switching is handled by LanguagePicker component

  // ── Theme switcher ──
  const themeBtns = document.querySelectorAll<HTMLButtonElement>('.theme-opt');
  const savedTheme = localStorage.getItem('site-theme') || 'modern';
  themeBtns.forEach(btn => {
    if (btn.dataset.theme === savedTheme) btn.classList.add('active');
    else btn.classList.remove('active');
    btn.addEventListener('click', () => {
      themeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      localStorage.setItem('site-theme', btn.dataset.theme || 'modern');
      html.dataset.theme = btn.dataset.theme || 'modern';
    });
  });

  // ── Mobile drawer ──
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');
  const drawerClose = document.getElementById('drawer-close');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function openDrawer() {
    drawer?.classList.add('open');
    overlay?.classList.add('open');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    if (hamburgerIcon) hamburgerIcon.style.display = 'none';
    if (closeIcon) closeIcon.style.display = 'block';
  }
  function closeDrawer() {
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (hamburgerIcon) hamburgerIcon.style.display = 'block';
    if (closeIcon) closeIcon.style.display = 'none';
  }

  hamburger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Keyboard: Escape closes drawer
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });

  // ── Drawer accordion ──
  document.querySelectorAll<HTMLButtonElement>('.drawer-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      if (!targetId) return;
      const sub = document.getElementById(targetId);
      const isOpen = sub?.classList.contains('open');
      // close all
      document.querySelectorAll('.drawer-sub').forEach(s => s.classList.remove('open'));
      document.querySelectorAll('.drawer-cat').forEach(b => b.setAttribute('aria-expanded', 'false'));
      // toggle clicked
      if (!isOpen) {
        sub?.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ── Voice search ──
  const micBtn = document.getElementById('mic-btn');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;

  if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
    const SR = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    const recog = new SR();
    recog.lang = 'en-IN';
    recog.interimResults = false;

    micBtn?.addEventListener('click', () => {
      micBtn.classList.add('listening');
      recog.start();
    });
    recog.onresult = (e: any) => {
      if (searchInput) searchInput.value = e.results[0][0].transcript;
      micBtn?.classList.remove('listening');
    };
    recog.onerror = () => micBtn?.classList.remove('listening');
    recog.onend = () => micBtn?.classList.remove('listening');
  } else {
    micBtn?.setAttribute('title', 'Voice search not supported in this browser');
  }

  // ── Search: simple keyword filter ──
  const searchItems = [
    { label: "Today's Panchang", url: "/" },
    { label: "Monthly Calendar", url: "/calendar" },
    { label: "All Festivals", url: "/festivals" },
    { label: "Muhurat Finder", url: "/muhurta" },
    { label: "Choghadiya", url: "/muhurta/choghadiya" },
    { label: "Shubha Hora", url: "/muhurta/hora" },
    { label: "Rahu Kala", url: "/muhurta/rahu-kala" },
    { label: "Lagna Table", url: "/muhurta/lagna" },
    { label: "Abhijit Muhurat", url: "/muhurta/abhijit" },
    { label: "Panchaka", url: "/muhurta/panchaka" },
    { label: "Gowri Panchangam", url: "/muhurta/panchaka" },
    { label: "Vivah Muhurat", url: "/muhurta/vivah" },
    { label: "Griha Pravesh", url: "/muhurta/griha-pravesh" },
    { label: "Vehicle Purchase Muhurat", url: "/muhurta/shubha-dates?activity=vehicle" },
    { label: "Property Purchase Muhurat", url: "/muhurta/shubha-dates?activity=property" },
    { label: "Shubha Dates", url: "/muhurta/shubha-dates" },
    { label: "Diwali 2025", url: "/festivals" },
    { label: "Navratri 2025", url: "/festivals" },
    { label: "Ekadashi", url: "/festivals" },
    { label: "Sunrise & Sunset", url: "/" },
    { label: "Jyotish Calculators", url: "/jyotish" },
    { label: "Kundali Generator", url: "/jyotish/kundali" },
    { label: "Horoscope Matching", url: "/jyotish/horoscope-match" },
    { label: "Guna Milan", url: "/jyotish/horoscope-match" },
    { label: "Gemstone Calculator", url: "/jyotish/gemstone" },
    { label: "Rudraksha Calculator", url: "/jyotish/rudraksha" },
    { label: "Rashi Calculator", url: "/jyotish/rashi" },
    { label: "Moon Sign Calculator", url: "/jyotish/rashi" },
    { label: "Sun Sign Calculator", url: "/jyotish/sunsign" },
    { label: "Nakshatra Calculator", url: "/jyotish/nakshatra" },
    { label: "Birth Star", url: "/jyotish/nakshatra" },
    { label: "Janma Lagna / Ascendant", url: "/jyotish/lagna" },
    { label: "Mangal Dosha / Manglik", url: "/jyotish/mangal-dosha" },
    { label: "Kalasarpa Yoga", url: "/jyotish/kalasarpa" },
    { label: "Shani Sadesati", url: "/jyotish/sadesati" },
    { label: "Baby Name Finder", url: "/jyotish/baby-names" },
    { label: "Shraddha Tithi", url: "/jyotish/shraddha" },
    { label: "Sahasra Chandrodaya", url: "/jyotish/sahasra-chandrodaya" },
    { label: "Pancha Pakshi", url: "/jyotish/pancha-pakshi" },
  ];

  const dropdown = document.getElementById('search-dropdown');

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (!q || !dropdown) { dropdown && (dropdown.hidden = true); return; }
    const matches = searchItems.filter(i => i.label.toLowerCase().includes(q));
    if (!matches.length) { dropdown.hidden = true; return; }
    dropdown.innerHTML = matches.map(i =>
      `<a href="${i.url}" style="display:block;padding:8px 14px;font-size:13px;color:var(--color-body-text);text-decoration:none;transition:background 0.1s;" onmouseover="this.style.background='var(--color-canvas-soft-2)'" onmouseout="this.style.background=''">${i.label}</a>`
    ).join('');
    dropdown.hidden = false;
  });

  document.addEventListener('click', (e) => {
    if (!searchInput?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
      if (dropdown) dropdown.hidden = true;
    }
  });
</script>
