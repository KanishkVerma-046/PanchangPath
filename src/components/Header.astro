  }

  /* App badges */
  .app-badges {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .app-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 28px;
    padding: 0 9px;
    background: var(--color-ink);
