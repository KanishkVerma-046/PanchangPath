    <!-- Drawer bottom controls -->
    <div class="drawer-controls">
      <!-- Language picker is in the header bar -->
      <button id="m-dark-toggle" class="hdr-icon-btn">
        <svg id="m-icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        </svg>
        <svg id="m-icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</aside>

<style>
  /* ── Header shell ── */
  #site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }

  .header-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
