---
import type { PlanetaryEvent } from '../lib/planetaryEvents';
import { formatCountdownLabel, formatEventDateTime } from '../lib/planetaryEvents';

interface Props {
  events: PlanetaryEvent[];
  today: Date;
  limit?: number;
}

const { events, today, limit = 8 } = Astro.props;
const displayed = events.slice(0, limit);

function typeLabel(type: string): string {
  switch (type) {
    case 'sign_transit':     return 'Transit';
    case 'retrograde_start': return 'Retrograde';
    case 'direct_start':     return 'Direct';
    case 'conjunction':      return 'Conjunction';
    case 'opposition':       return 'Opposition';
    case 'solar_eclipse':    return 'Solar Eclipse';
    case 'lunar_eclipse':    return 'Lunar Eclipse';
    case 'solstice_equinox': return 'Solstice / Equinox';
    default:                 return 'Event';
  }
}

function typeClass(type: string): string {
  switch (type) {
    case 'sign_transit':      return 'pef-tag-transit';
    case 'retrograde_start':  return 'pef-tag-retro';
    case 'direct_start':      return 'pef-tag-direct';
    case 'conjunction':       return 'pef-tag-aspect';
    case 'opposition':        return 'pef-tag-aspect';
    case 'solar_eclipse':
    case 'lunar_eclipse':     return 'pef-tag-eclipse';
    case 'solstice_equinox':  return 'pef-tag-season';
    default:                  return '';
  }
}
---

<section class="pef-section">
  <div class="pef-container">

    <!-- Header -->
    <div class="pef-header">
      <div>
        <p class="caption-mono" style="color:var(--color-mute);margin:0 0 6px;">Upcoming</p>
        <h2 class="pef-title">
          <span class="en-text">Planetary Events</span>
          <span class="hi-text">ग्रह घटनाएँ</span>
        </h2>
      </div>
      <a href="/events" class="pef-more-link">
        <span class="en-text">All events →</span>
        <span class="hi-text">सभी घटनाएँ →</span>
      </a>
    </div>

    <!-- Event list -->
    <div class="pef-list" role="list">
      {displayed.map((ev, idx) => {
        const countdown = formatCountdownLabel(ev.daysAway);
        const datetime  = formatEventDateTime(ev);
        const isToday   = ev.daysAway === 0;
        const isSoon    = ev.daysAway <= 7;

        return (
          <a
            href={`/events/${ev.id}`}
            class={`pef-row ${isToday ? 'pef-today' : ''}`}
            role="listitem"
          >
            <!-- Timeline connector -->
            <div class="pef-timeline">
              <div class="pef-dot-wrap">
                <span class="pef-icon" style={`color:${ev.badgeColor}`} aria-hidden="true">
                  {ev.icon}
                </span>
              </div>
              {idx < displayed.length - 1 && <div class="pef-line" aria-hidden="true"></div>}
            </div>

            <!-- Content -->
            <div class="pef-content">
              <div class="pef-meta">
                <span class={`pef-tag ${typeClass(ev.type)}`}>
                  {typeLabel(ev.type)}
                </span>
                <span class={`pef-countdown ${isToday ? 'pef-now' : isSoon ? 'pef-soon' : ''}`}>
                  {isToday && <span class="pef-pulse" aria-hidden="true"></span>}
                  {countdown}
                </span>
              </div>

              <p class="pef-name">
                <span class="en-text">{ev.title}</span>
                <span class="hi-text">{ev.titleHi}</span>
              </p>
              <p class="pef-datetime">{datetime}</p>
              <p class="pef-desc">{ev.description}</p>
            </div>

            <!-- Arrow -->
            <span class="pef-arrow" aria-hidden="true">›</span>
          </a>
        );
      })}
    </div>

    <!-- Footer link -->
    <a href="/events" class="pef-view-all">
      <span class="en-text">View all upcoming planetary events</span>
      <span class="hi-text">सभी ग्रह घटनाएँ देखें</span>
      <span class="pef-arrow-sm">→</span>
    </a>

  </div>
</section>

<style>
.pef-section {
  padding: 48px 0;
  border-top: 1px solid var(--color-hairline);
}
.pef-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Header ── */
.pef-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 12px;
}
.pef-title {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.6px;
  color: var(--color-ink);
  margin: 0;
}
.pef-more-link {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-saffron-deep);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.pef-more-link:hover { text-decoration: underline; }

/* ── List ── */
.pef-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--color-hairline);
  border-radius: 12px;
  overflow: hidden;
}

/* ── Row ── */
.pef-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
  padding: 0;
  text-decoration: none;
  color: inherit;
  border-bottom: 1px solid var(--color-hairline);
  transition: background 0.15s;
  position: relative;
}
.pef-row:last-child { border-bottom: none; }
.pef-row:hover { background: var(--color-canvas-soft); }
.pef-row.pef-today { background: rgba(255, 153, 51, 0.05); }
.pef-row.pef-today:hover { background: rgba(255, 153, 51, 0.09); }

/* ── Timeline column ── */
.pef-timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 52px;
  flex-shrink: 0;
  padding-top: 16px;
}
.pef-dot-wrap {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-canvas-soft);
  border: 1px solid var(--color-hairline);
  flex-shrink: 0;
}
.pef-icon {
  font-size: 16px;
  line-height: 1;
  display: block;
}
.pef-line {
  width: 1px;
  flex: 1;
  min-height: 12px;
  background: var(--color-hairline);
  margin-top: 4px;
  margin-bottom: -1px;
}

/* ── Content column ── */
.pef-content {
  flex: 1;
  min-width: 0;
  padding: 14px 8px 14px 4px;
}

/* Meta row */
.pef-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 5px;
  flex-wrap: wrap;
}

/* Type tag */
.pef-tag {
  display: inline-block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 4px;
}
.pef-tag-transit  { background: rgba(255,153,51,0.12); color: #c05c00; }
.pef-tag-retro    { background: rgba(220,38,38,0.10);  color: #b91c1c; }
.pef-tag-direct   { background: rgba(21,128,61,0.10);  color: #15803d; }
.pef-tag-aspect   { background: rgba(124,58,237,0.10); color: #6d28d9; }
.pef-tag-eclipse  { background: rgba(30,27,75,0.12);   color: #312e81; }
.pef-tag-season   { background: rgba(14,165,233,0.10); color: #0369a1; }
html.dark .pef-tag-transit  { background: rgba(255,153,51,0.18); color: #fb923c; }
html.dark .pef-tag-retro    { background: rgba(220,38,38,0.18);  color: #fca5a5; }
html.dark .pef-tag-direct   { background: rgba(21,128,61,0.18);  color: #86efac; }
html.dark .pef-tag-aspect   { background: rgba(167,139,250,0.18);color: #c4b5fd; }
html.dark .pef-tag-eclipse  { background: rgba(99,102,241,0.18); color: #a5b4fc; }
html.dark .pef-tag-season   { background: rgba(56,189,248,0.18); color: #7dd3fc; }

/* Countdown */
.pef-countdown {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10.5px;
  font-weight: 700;
  font-family: var(--font-mono, monospace);
  color: var(--color-mute);
  letter-spacing: 0.03em;
}
.pef-now  { color: var(--color-saffron-deep); }
.pef-soon { color: #b45309; }
.pef-pulse {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-saffron);
  animation: pef-blink 1.4s ease-in-out infinite;
}
@keyframes pef-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* Event name */
.pef-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 3px;
  line-height: 1.3;
}
.pef-row:hover .pef-name { color: var(--color-saffron-deep); }

/* Date/time */
.pef-datetime {
  font-size: 11px;
  font-family: var(--font-mono, monospace);
  color: var(--color-mute);
  margin: 0 0 4px;
}

/* Short description */
.pef-desc {
  font-size: 12px;
  color: var(--color-body-text);
  margin: 0;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
@media (min-width: 640px) {
  .pef-desc { -webkit-line-clamp: 2; }
}

/* Arrow */
.pef-arrow {
  font-size: 20px;
  color: var(--color-hairline);
  padding: 16px 16px 16px 8px;
  align-self: center;
  flex-shrink: 0;
  transition: color 0.15s;
}
.pef-row:hover .pef-arrow { color: var(--color-saffron); }

/* ── View all footer ── */
.pef-view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
  padding: 11px 0;
  font-size: 13px;
  font-weight: 600;
  color: var(--color-saffron-deep);
  text-decoration: none;
  border: 1px solid var(--color-hairline);
  border-radius: 8px;
  background: var(--color-canvas-soft);
  transition: border-color 0.15s, background 0.15s;
}
.pef-view-all:hover {
  border-color: var(--color-saffron);
  background: var(--color-saffron-soft);
}
.pef-arrow-sm { font-size: 15px; }
</style>
