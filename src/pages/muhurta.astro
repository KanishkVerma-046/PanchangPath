---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Muhurta Finder — Auspicious Time — PanchangPath" description="Find the best auspicious time (Muhurta) for any activity — marriage, travel, business, housewarming, and more.">
  <!-- Hero -->
  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:48px 0 40px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.5;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Shubh Muhurta</p>
      <h1 style="font-size:36px;font-weight:600;letter-spacing:-1.4px;color:var(--color-ink);margin:0 0 12px;">Muhurta Finder.</h1>
      <p style="font-size:16px;color:var(--color-body-text);margin:0;max-width:500px;">Find the most auspicious time window for any important activity or ceremony.</p>
    </div>
  </section>

  <!-- Finder form -->
  <section style="padding:40px 0;">
    <div class="container" style="max-width:780px;margin:0 auto;">
      <div class="card" style="padding:32px;">
        <h2 style="font-size:20px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 24px;">Select Activity & Date</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
          <div>
            <label style="font-size:12px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:6px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">Activity</label>
            <select id="activity-select" class="input" style="height:40px;">
              <option value="marriage">Marriage / Vivah</option>
              <option value="travel">Travel / Yatra</option>
              <option value="business">Business Start / New Venture</option>
              <option value="housewarming">Griha Pravesh (Housewarming)</option>
              <option value="namkaran">Namkaran (Baby Naming)</option>
              <option value="education">Vidyarambha (Education Start)</option>
              <option value="purchase">Purchase (Vehicle / Property)</option>
              <option value="medical">Medical Surgery / Treatment</option>
            </select>
          </div>
          <div>
            <label style="font-size:12px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:6px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">Date Range</label>
            <input type="date" id="muhurta-date" class="input" style="height:40px;" />
          </div>
        </div>
        <div style="margin-bottom:24px;">
          <label style="font-size:12px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:6px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">Location</label>
          <select id="muhurta-city" class="input" style="height:40px;"></select>
        </div>
        <button id="find-muhurta" class="btn-primary" style="width:100%;height:44px;font-size:15px;border-radius:8px;justify-content:center;">
          Find Auspicious Time →
        </button>
      </div>

      <!-- Results -->
      <div id="muhurta-results" style="margin-top:24px;display:none;">
        <h2 style="font-size:18px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 16px;" id="results-title"></h2>
        <div id="results-grid" style="display:flex;flex-direction:column;gap:10px;"></div>
      </div>

      <!-- Info cards -->
      <div style="margin-top:40px;">
        <h3 style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 16px;">How Muhurta is determined</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          {[
            { label: 'Tithi', desc: 'Certain Tithis are ideal for specific activities. For example, Dwadashi and Purnima are good for most work.' },
            { label: 'Nakshatra', desc: 'The Moon\'s Nakshatra on the chosen day plays a key role. Rohini, Hasta, Pushya are broadly auspicious.' },
            { label: 'Yoga', desc: 'Auspicious Yogas like Siddha, Amrita, and Shubha enhance any Muhurta. Vishkambha and Shula are avoided.' },
            { label: 'Vara', desc: 'Wednesday (Mercury) and Thursday (Jupiter) are most broadly auspicious for important beginnings.' },
          ].map(item => (
            <div class="card" style="padding:16px;">
              <p style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 6px;">{item.label}</p>
              <p style="font-size:12px;color:var(--color-body-text);margin:0;line-height:1.6;">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
const LOCS = [
  {name:'New Delhi',lat:28.6139,lng:77.209,tzOffset:5.5},
  {name:'Mumbai',lat:19.076,lng:72.8777,tzOffset:5.5},
  {name:'Bengaluru',lat:12.9716,lng:77.5946,tzOffset:5.5},
  {name:'Chennai',lat:13.0827,lng:80.2707,tzOffset:5.5},
  {name:'Kolkata',lat:22.5726,lng:88.3639,tzOffset:5.5},
  {name:'Hyderabad',lat:17.385,lng:78.4867,tzOffset:5.5},
  {name:'Jaipur',lat:26.9124,lng:75.7873,tzOffset:5.5},
  {name:'Varanasi',lat:25.3176,lng:82.9739,tzOffset:5.5},
  {name:'Haridwar',lat:29.9457,lng:78.1642,tzOffset:5.5},
  {name:'Dubai',lat:25.2048,lng:55.2708,tzOffset:4},
  {name:'New York',lat:40.7128,lng:-74.006,tzOffset:-4},
  {name:'London',lat:51.5074,lng:-0.1278,tzOffset:1},
];

const sel = document.getElementById('muhurta-city') as HTMLSelectElement;
if (sel) sel.innerHTML = LOCS.map(l => `<option value="${l.name}">${l.name}</option>`).join('');

const dateInput = document.getElementById('muhurta-date') as HTMLInputElement;
dateInput.value = new Date().toISOString().split('T')[0];

const toRad = (d: number) => d * Math.PI / 180;
const norm = (a: number) => ((a % 360) + 360) % 360;

function quickCalc(date: Date, lat: number, lng: number, tz: number) {
  const yr = date.getFullYear(), mo = date.getMonth()+1, dy = date.getDate();
  let y = yr, m = mo;
  if (m <= 2) { y--; m += 12; }
  const A = Math.floor(y/100), B = 2 - A + Math.floor(A/4);
  const jd = Math.floor(365.25*(y+4716)) + Math.floor(30.6001*(m+1)) + dy + 6/24 + B - 1524.5;
  const T = (jd - 2451545)/36525;
  const L0 = norm(280.46646 + 36000.76983*T);
  const Ms = norm(357.52911 + 35999.05029*T);
  const sunLon = norm(L0 + (1.914602-0.004817*T)*Math.sin(toRad(Ms)) + 0.019993*Math.sin(2*toRad(Ms)));
  const moonL = norm(218.3164477 + 481267.88123421*T);
  const moonD = norm(297.8501921 + 445267.1114034*T);
  const moonMp = norm(134.9633964 + 477198.8675055*T);
  const dL = 6.288774*Math.sin(toRad(moonMp)) + 1.274027*Math.sin(toRad(2*moonD-moonMp)) + 0.658314*Math.sin(toRad(2*moonD));
  const moonLon = norm(moonL + dL/1000);
  const ay = 23.85 + 1.3612*T;
  const moonSid = norm(moonLon - ay), sunSid = norm(sunLon - ay);
  const elong = norm(moonLon - sunLon);
  const tithiIdx = Math.floor(elong/12)%30;
  const nIdx = Math.floor(moonSid/(360/27))%27;
  const yIdx = Math.floor(norm(sunSid+moonSid)/(360/27))%27;
  const wd = date.getDay();
  // Sunrise
  const sunDec = Math.asin(Math.sin(toRad(23.4393))*Math.sin(toRad(sunLon)));
  const cosHA = (Math.sin(toRad(-0.8333))-Math.sin(toRad(lat))*Math.sin(sunDec))/(Math.cos(toRad(lat))*Math.cos(sunDec));
  const ha = Math.acos(Math.max(-1,Math.min(1,cosHA)))*180/Math.PI;
  const noon = 12 - lng/15;
  const srUTC = noon - ha/15, ssUTC = noon + ha/15;
  const srMins = srUTC*60 + tz*60, ssMins = ssUTC*60 + tz*60;
  const RAHU = [7,1,6,4,5,2,3];
  const slotDur = (ssMins-srMins)/8;
  const rahuStart = srMins + RAHU[wd]*slotDur, rahuEnd = rahuStart + slotDur;
  return { tithiIdx, nIdx, yIdx, wd, rahuStart, rahuEnd, srMins, ssMins };
}

const AUSPICIOUS_VARAS: Record<string, number[]> = {
  marriage:[1,2,3,4,5], travel:[0,1,2,3,4,5], business:[1,3,4,5],
  housewarming:[1,3,4,5], namkaran:[1,2,4,5], education:[1,2,4,5],
  purchase:[1,3,4,5], medical:[1,3,4,5],
};
const AUSPICIOUS_NAKSHATRAS: Record<string, number[]> = {
  marriage:[3,4,6,7,10,12,22,25], travel:[3,6,7,10,12,21,22],
  business:[3,6,7,10,12,21,22], housewarming:[3,6,7,10,12],
  namkaran:[3,4,7,10,12], education:[3,7,10,12,21,22],
  purchase:[3,6,7,10,12], medical:[3,6,7,10,12],
};
const GOOD_YOGAS = [1,2,3,4,6,7,10,11,13,15,17,19,20,21,22,23,24,25]; // indices of auspicious yogas
const GOOD_TITHIS = [1,2,4,5,6,7,10,11,12,14,20,21];

const TITHI_NAMES = ['Pratipada','Dwitiya','Tritiya','Chaturthi','Panchami','Shashthi','Saptami','Ashtami','Navami','Dashami','Ekadashi','Dwadashi','Trayodashi','Chaturdashi','Purnima','Pratipada','Dwitiya','Tritiya','Chaturthi','Panchami','Shashthi','Saptami','Ashtami','Navami','Dashami','Ekadashi','Dwadashi','Trayodashi','Chaturdashi','Amavasya'];
const NAK_NAMES = ['Ashwini','Bharani','Krittika','Rohini','Mrigashira','Ardra','Punarvasu','Pushya','Ashlesha','Magha','Purva Phalguni','Uttara Phalguni','Hasta','Chitra','Swati','Vishakha','Anuradha','Jyeshtha','Mula','Purva Ashadha','Uttara Ashadha','Shravana','Dhanishtha','Shatabhisha','Purva Bhadrapada','Uttara Bhadrapada','Revati'];
const YOGA_NAMES = ['Vishkambha','Preeti','Ayushman','Saubhagya','Shobhana','Atiganda','Sukarma','Dhriti','Shula','Ganda','Vriddhi','Dhruva','Vyaghata','Harshana','Vajra','Siddhi','Vyatipata','Variyan','Parigha','Shiva','Siddha','Sadhya','Shubha','Shukla','Brahma','Indra','Vaidhriti'];
const VARA_NAMES = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function scoreDay(d: Date, loc: typeof LOCS[0], activity: string) {
  const c = quickCalc(d, loc.lat, loc.lng, loc.tzOffset);
  const paksha = c.tithiIdx < 15 ? 'Shukla' : 'Krishna';
  let score = 0;
  const notes: string[] = [];
  const goodVaras = AUSPICIOUS_VARAS[activity] || [1,3,4,5];
  const goodNaks = AUSPICIOUS_NAKSHATRAS[activity] || [3,6,7,10,12];
  if (goodVaras.includes(c.wd)) { score += 3; notes.push(`${VARA_NAMES[c.wd]} (good weekday)`); }
  if (goodNaks.includes(c.nIdx)) { score += 3; notes.push(`${NAK_NAMES[c.nIdx]} (auspicious nakshatra)`); }
  if (GOOD_YOGAS.includes(c.yIdx)) { score += 2; notes.push(`${YOGA_NAMES[c.yIdx]} yoga`); }
  if (GOOD_TITHIS.includes(c.tithiIdx)) { score += 2; notes.push(`${paksha} ${TITHI_NAMES[c.tithiIdx]}`); }
  return { score, notes, vara: c.wd, tithi: c.tithiIdx, nakshatra: c.nIdx, yoga: c.yIdx, rahuStart: c.rahuStart, rahuEnd: c.rahuEnd };
}

function minsToFmt(m: number): string {
  const h = Math.floor((m/60)%24), mn = Math.round(m%60);
  const ap = h < 12 ? 'AM' : 'PM';
  return `${h%12||12}:${String(mn).padStart(2,'0')} ${ap}`;
}

document.getElementById('find-muhurta')?.addEventListener('click', () => {
  const activity = (document.getElementById('activity-select') as HTMLSelectElement)?.value || 'travel';
  const dateStr = dateInput.value;
  const cityName = sel.value;
  const loc = LOCS.find(l => l.name === cityName) || LOCS[0];
  const baseDate = new Date(dateStr + 'T12:00:00');

  // Score next 15 days
  const results = [];
  for (let i = 0; i < 15; i++) {
    const d = new Date(baseDate);
    d.setDate(d.getDate() + i);
    const s = scoreDay(d, loc, activity);
    results.push({ date: d, ...s });
  }
  results.sort((a, b) => b.score - a.score);
  const top = results.slice(0, 5);

  const grid = document.getElementById('results-grid');
  const title = document.getElementById('results-title');
  const section = document.getElementById('muhurta-results');
  if (!grid || !title || !section) return;
  title.textContent = `Best times for ${activity.charAt(0).toUpperCase() + activity.slice(1)} — next 15 days`;
  grid.innerHTML = top.map((r, i) => {
    const stars = '★'.repeat(Math.min(5, Math.round(r.score / 2)));
    const empty = '☆'.repeat(5 - Math.min(5, Math.round(r.score / 2)));
    const label = r.score >= 8 ? 'Excellent' : r.score >= 6 ? 'Very Good' : r.score >= 4 ? 'Good' : 'Acceptable';
    const bg = i === 0 ? 'background:var(--color-ink);' : '';
    const textColor = i === 0 ? 'color:var(--color-on-primary);' : 'color:var(--color-ink);';
    const muteColor = i === 0 ? 'color:rgba(255,255,255,0.6);' : 'color:var(--color-mute);';
    const badgeBg = i === 0 ? 'background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.2);' : '';
    return `<div class="card" style="padding:20px;${bg}">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <div>
          <p style="font-size:16px;font-weight:600;letter-spacing:-0.3px;${textColor}margin:0;">${r.date.toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'short'})}</p>
          <p style="font-size:12px;${muteColor}margin:2px 0 0;font-family:var(--font-mono);">${VARA_NAMES[r.vara]} · ${NAK_NAMES[r.nakshatra]}</p>
        </div>
        <div style="text-align:right;">
          <span style="font-size:13px;${i===0?'color:#ffcc00;':'color:var(--color-warning);'}">${stars}</span><span style="font-size:13px;${muteColor}">${empty}</span>
          <p style="font-size:11px;font-weight:600;margin:2px 0 0;${i===0?'color:rgba(255,255,255,0.9);':'color:var(--color-auspicious);'}">${label}</p>
        </div>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        ${r.notes.map(n => `<span style="font-size:10px;padding:3px 8px;border-radius:100px;${badgeBg || 'background:var(--color-canvas-soft-2);color:var(--color-body-text);border:1px solid var(--color-hairline);'}">${n}</span>`).join('')}
      </div>
      ${i===0 ? `<div style="margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.15);">
        <p style="font-size:11px;color:rgba(255,255,255,0.5);margin:0 0 4px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.05em;">Avoid Rahu Kalam</p>
        <p style="font-size:13px;font-weight:500;color:rgba(255,255,255,0.85);margin:0;">${minsToFmt(r.rahuStart)} – ${minsToFmt(r.rahuEnd)}</p>
      </div>` : ''}
    </div>`;
  }).join('');
  section.style.display = 'block';
  section.scrollIntoView({ behavior:'smooth', block:'start' });
});
</script>
