---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Muhurta Tools — Auspicious Timing — PanchangPath" description="Complete Muhurta toolkit: Choghadiya, Shubha Hora, Rahu Kala, Lagna table, Vivah Muhurat, Griha Pravesh and more.">

  <!-- Hero -->
  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:48px 0 40px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.5;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">मुहूर्त · Shubh Muhurta</p>
      <h1 style="font-size:36px;font-weight:600;letter-spacing:-1.4px;color:var(--color-ink);margin:0 0 12px;">Muhurta Tools.</h1>
      <p style="font-size:16px;color:var(--color-body-text);margin:0;max-width:540px;">Complete auspicious timing toolkit — daily Choghadiya, planetary hours, Lagna table, and life-event date finders. All calculations use Drik astronomical method with Lahiri ayanamsha.</p>
    </div>
  </section>

  <!-- Today's quick Choghadiya widget -->
  <section style="padding:40px 0 0;">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
        <div>
          <h2 style="font-size:18px;font-weight:600;letter-spacing:-0.4px;color:var(--color-ink);margin:0 4px 0 0;display:inline;">Today's Choghadiya</h2>
          <span style="font-size:13px;color:var(--color-mute);margin-left:8px;" id="quick-date-label"></span>
        </div>
        <a href="/muhurta/choghadiya" class="btn-outline" style="font-size:13px;height:34px;padding:0 16px;">Full Choghadiya →</a>
      </div>
      <div id="quick-chog" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;margin-bottom:40px;">
        <div style="height:60px;background:var(--color-canvas-soft-2);border-radius:8px;animation:pulse 1.5s infinite;"></div>
        <div style="height:60px;background:var(--color-canvas-soft-2);border-radius:8px;animation:pulse 1.5s infinite;"></div>
        <div style="height:60px;background:var(--color-canvas-soft-2);border-radius:8px;animation:pulse 1.5s infinite;"></div>
        <div style="height:60px;background:var(--color-canvas-soft-2);border-radius:8px;animation:pulse 1.5s infinite;"></div>
      </div>
    </div>
  </section>

  <!-- Daily Tools grid -->
  <section style="padding:0 0 48px;">
    <div class="container">
      <h2 style="font-size:15px;font-weight:600;color:var(--color-ink);margin:0 0 16px;letter-spacing:-0.2px;">Daily Muhurta Tools</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:48px;">
        {[
          { href:'/muhurta/choghadiya', icon:'🕰️', title:'Choghadiya', titleHi:'चौघड़िया', desc:'8 daily auspicious & inauspicious time slots from sunrise to sunset.' },
          { href:'/muhurta/hora', icon:'🪐', title:'Shubha Hora', titleHi:'शुभ होरा', desc:'Planetary hours ruled by Sun, Moon, Mars, Mercury, Jupiter, Venus, Saturn.' },
          { href:'/muhurta/rahu-kala', icon:'🐍', title:'Rahu Kala', titleHi:'राहु काल', desc:'Inauspicious Rahu period — avoid starting new work during this time.' },
          { href:'/muhurta/lagna', icon:'⚖️', title:'Lagna Table', titleHi:'लग्न तालिका', desc:'Rising sign (Lagna) changes every ~2 hours; shows today\'s full table.' },
          { href:'/muhurta/abhijit', icon:'☀️', title:'Abhijit Muhurat', titleHi:'अभिजित मुहूर्त', desc:'The most auspicious midday window. Also Do Ghati & Brahma Muhurta.' },
          { href:'/muhurta/panchaka', icon:'🌙', title:'Panchaka & Gowri', titleHi:'पंचक · गौरी पंचांग', desc:'Panchaka inauspicious periods and Gowri Panchangam for South India.' },
        ].map(t => (
          <a href={t.href} class="card" style="padding:20px;text-decoration:none;display:block;transition:transform 0.15s,box-shadow 0.15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
            <div style="font-size:24px;margin-bottom:10px;">{t.icon}</div>
            <p style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 2px;">{t.title}</p>
            <p style="font-size:11px;color:var(--color-mute);font-family:var(--font-mono);margin:0 0 8px;">{t.titleHi}</p>
            <p style="font-size:12px;color:var(--color-body-text);margin:0;line-height:1.6;">{t.desc}</p>
          </a>
        ))}
      </div>

      <!-- Life Events -->
      <h2 style="font-size:15px;font-weight:600;color:var(--color-ink);margin:0 0 16px;letter-spacing:-0.2px;">Life Event Muhurta Finders</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
        {[
          { href:'/muhurta/vivah', icon:'💍', title:'Vivah Muhurat', titleHi:'विवाह मुहूर्त', desc:'Find the best auspicious dates for marriage with strict Vedic criteria.', badge:'Most Popular' },
          { href:'/muhurta/griha-pravesh', icon:'🏠', title:'Griha Pravesh', titleHi:'गृह प्रवेश', desc:'Auspicious dates for moving into a new home or housewarming.', badge:'' },
          { href:'/muhurta/shubha-dates?activity=property', icon:'🏗️', title:'Property Purchase', titleHi:'संपत्ति खरीद', desc:'Best dates to purchase, register, or take possession of property.', badge:'' },
          { href:'/muhurta/shubha-dates?activity=vehicle', icon:'🚗', title:'Vehicle Purchase', titleHi:'वाहन खरीद', desc:'Auspicious dates for buying a new vehicle or two-wheeler.', badge:'' },
          { href:'/muhurta/shubha-dates?activity=business', icon:'💼', title:'Business Start', titleHi:'व्यापार मुहूर्त', desc:'Lucky dates to start a new business, shop, or venture.', badge:'' },
          { href:'/muhurta/shubha-dates', icon:'📅', title:'Shubha Dates', titleHi:'शुभ दिन', desc:'General auspicious date finder for any important activity.', badge:'' },
        ].map(t => (
          <a href={t.href} class="card" style="padding:20px;text-decoration:none;display:block;position:relative;transition:transform 0.15s,box-shadow 0.15s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
            {t.badge && <span style="position:absolute;top:12px;right:12px;font-size:9px;font-weight:700;padding:2px 8px;background:var(--color-saffron-soft);color:var(--color-saffron-deep);border-radius:100px;border:1px solid rgba(255,153,51,0.3);">{t.badge}</span>}
            <div style="font-size:24px;margin-bottom:10px;">{t.icon}</div>
            <p style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 2px;">{t.title}</p>
            <p style="font-size:11px;color:var(--color-mute);font-family:var(--font-mono);margin:0 0 8px;">{t.titleHi}</p>
            <p style="font-size:12px;color:var(--color-body-text);margin:0;line-height:1.6;">{t.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How Muhurta works explainer -->
  <section style="padding:48px 0;background:var(--color-canvas-soft);">
    <div class="container" style="max-width:860px;margin:0 auto;">
      <h2 style="font-size:18px;font-weight:600;letter-spacing:-0.4px;color:var(--color-ink);margin:0 0 8px;">How Muhurta is calculated</h2>
      <p style="font-size:14px;color:var(--color-body-text);margin:0 0 24px;">Muhurta selects an auspicious time window based on five Panchang elements. A strong Muhurta aligns all five favourably.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;">
        {[
          { label:'Tithi', icon:'🌕', desc:'Lunar day — Dwitiya, Panchami, Dashami and Trayodashi in Shukla Paksha are broadly auspicious.' },
          { label:'Nakshatra', icon:'⭐', desc:'Moon\'s asterism — Rohini, Hasta, Pushya, Swati, Anuradha and Revati are best for most activities.' },
          { label:'Yoga', icon:'🔮', desc:'Sun + Moon combination — Siddha, Amrita, Shubha and Brahma yogas boost any Muhurta.' },
          { label:'Vara', icon:'📆', desc:'Weekday — Monday, Wednesday, Thursday and Friday are most broadly auspicious.' },
          { label:'Karana', icon:'🌗', desc:'Half-tithi — Bava, Balava, Kaulava and Taitila are good; Vishti (Bhadra) is avoided.' },
        ].map(f => (
          <div class="card" style="padding:16px;">
            <div style="font-size:20px;margin-bottom:8px;">{f.icon}</div>
            <p style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 6px;">{f.label}</p>
            <p style="font-size:12px;color:var(--color-body-text);margin:0;line-height:1.6;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
</style>

<script>
const LOCS = [
  {name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},
  {name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},
  {name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},
  {name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},
  {name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},
  {name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},
  {name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},
  {name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},
];

const DAY_CHOG = [
  ['Udveg','Char','Labh','Amrit','Kaal','Shubh','Rog','Udveg'],
  ['Amrit','Kaal','Shubh','Rog','Udveg','Char','Labh','Amrit'],
  ['Rog','Udveg','Char','Labh','Amrit','Kaal','Shubh','Rog'],
  ['Labh','Amrit','Kaal','Shubh','Rog','Udveg','Char','Labh'],
  ['Shubh','Rog','Udveg','Char','Labh','Amrit','Kaal','Shubh'],
  ['Char','Labh','Amrit','Kaal','Shubh','Rog','Udveg','Char'],
  ['Kaal','Shubh','Rog','Udveg','Char','Labh','Amrit','Kaal'],
];
const CHOG_COLOR: Record<string,string> = {
  Amrit:'#dcfce7',Shubh:'#fef3c7',Labh:'#dbeafe',Char:'#ede9fe',
  Udveg:'#fee2e2',Kaal:'#f3f4f6',Rog:'#fee2e2',
};
const CHOG_TEXT: Record<string,string> = {
  Amrit:'#15803d',Shubh:'#b45309',Labh:'#1d4ed8',Char:'#6d28d9',
  Udveg:'#dc2626',Kaal:'#374151',Rog:'#b91c1c',
};
const CHOG_QUALITY: Record<string,string> = {
  Amrit:'Best',Shubh:'Good',Labh:'Good',Char:'Neutral',
  Udveg:'Avoid',Kaal:'Avoid',Rog:'Avoid',
};

function toJD(y:number,m:number,d:number,h=0) {
  if(m<=2){y--;m+=12;}
  const A=Math.floor(y/100),B=2-A+Math.floor(A/4);
  return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;
}
const n360=(a:number)=>((a%360)+360)%360;
const toRad=(d:number)=>d*Math.PI/180;
const toDeg=(r:number)=>r*180/Math.PI;

function sunriseUTC(jd:number,lat:number,lng:number,rising=true) {
  const T=(jd-2451545)/36525;
  const M=n360(357.52911+35999.05029*T);
  const L0=n360(280.46646+36000.76983*T);
  const C=(1.914602-0.004817*T)*Math.sin(toRad(M))+0.019993*Math.sin(2*toRad(M));
  const sunL=L0+C;
  const sinDec=Math.sin(toRad(23.4393))*Math.sin(toRad(sunL));
  const dec=Math.asin(sinDec);
  const cosHA=(Math.sin(toRad(-0.8333))-Math.sin(toRad(lat))*Math.sin(dec))/(Math.cos(toRad(lat))*Math.cos(dec));
  if(cosHA<-1||cosHA>1)return NaN;
  const ha=toDeg(Math.acos(cosHA));
  const noon=12-lng/15;
  return rising?noon-ha/15:noon+ha/15;
}
function fmtMins(m:number) {
  const h=Math.floor((m/60)%24),mn=Math.round(m%60);
  return `${h%12||12}:${String(mn).padStart(2,'0')} ${h<12?'AM':'PM'}`;
}

const now=new Date();
const wd=now.getDay();
const loc=LOCS[0];
const jd=toJD(now.getFullYear(),now.getMonth()+1,now.getDate(),6-loc.tz);
const srUTC=sunriseUTC(jd,loc.lat,loc.lng,true);
const ssUTC=sunriseUTC(jd,loc.lat,loc.lng,false);
const srMins=srUTC*60+loc.tz*60, ssMins=ssUTC*60+loc.tz*60;
const slotDur=(ssMins-srMins)/8;
const daySeq=DAY_CHOG[wd];
const nowMins=now.getHours()*60+now.getMinutes();

const label=document.getElementById('quick-date-label');
if(label) label.textContent=now.toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'short'});

const grid=document.getElementById('quick-chog');
if(grid) {
  grid.innerHTML=daySeq.map((name,i)=>{
    const start=srMins+i*slotDur, end=start+slotDur;
    const isCurrent=nowMins>=start&&nowMins<end;
    const bg=isCurrent?'var(--color-ink)':CHOG_COLOR[name];
    const fg=isCurrent?'#fff':CHOG_TEXT[name];
    const muted=isCurrent?'rgba(255,255,255,0.65)':'var(--color-mute)';
    return `<div style="background:${bg};border-radius:8px;padding:12px 14px;border:1px solid ${isCurrent?'transparent':'var(--color-hairline)'};">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
        <span style="font-size:13px;font-weight:600;color:${fg};">${name}</span>
        ${isCurrent?'<span style="font-size:9px;font-weight:700;background:rgba(255,255,255,0.2);color:#fff;padding:1px 6px;border-radius:100px;">NOW</span>':''}
      </div>
      <p style="font-size:10px;color:${muted};margin:0;">${fmtMins(start)} – ${fmtMins(end)}</p>
      <p style="font-size:10px;color:${isCurrent?'rgba(255,255,255,0.5)':CHOG_COLOR[name]==='#f3f4f6'?'#6b7280':'var(--color-mute)'};margin:2px 0 0;">${CHOG_QUALITY[name]}</p>
    </div>`;
  }).join('');
}
</script>
