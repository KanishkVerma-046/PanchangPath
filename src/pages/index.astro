function calcPanchang(date: Date, loc: Location) {
  const year = date.getFullYear(), month = date.getMonth()+1, day = date.getDate();
  const hour = 6 - loc.tzOffset;
  const jd = julianDay(year, month, day, hour);
  const sLon = sunTrueLon(jd);
  const mLon = moonLon(jd);
  const ay = ayanamsha(jd);
  const sSid = norm360(sLon - ay);
  const mSid = norm360(mLon - ay);
  const elong = norm360(mLon - sLon);
  const tithiIdx = Math.floor(elong / 12) % 30;
  const paksha = tithiIdx < 15 ? 'Shukla' : 'Krishna';
  const nIdx = Math.floor(mSid / (360/27)) % 27;
  const pada = Math.floor((mSid % (360/27)) / (360/27/4)) + 1;
  const yLon = norm360(sSid + mSid);
  const yIdx = Math.floor(yLon / (360/27)) % 27;
  const kIdx = Math.floor(elong / 6) % 60;
  const wd = date.getDay();
  const srUTC = sunriseUTC(jd, loc.lat, loc.lng, true);
  const ssUTC = sunriseUTC(jd, loc.lat, loc.lng, false);
  const srMins = srUTC * 60 + loc.tzOffset * 60;
  const ssMins = ssUTC * 60 + loc.tzOffset * 60;
  const dayMins = ssMins - srMins;
  const slotDur = dayMins / 8;
  const slot = (s: number) => ({ start: minsToFmt(srMins + s * slotDur), end: minsToFmt(srMins + (s+1) * slotDur) });
  srMinsGlobal = srMins; // store for 24+ format

  const moonAge = elong / 360 * 29.53;
  const mrMins = srMins + moonAge * 48;
  const noonMins = (srMins + ssMins) / 2;
  const abStart = noonMins - 24, abEnd = noonMins + 24;
  return {
    vara: { name: VARAS[wd], nameHi: VARAS_HI[wd], lord: VARA_LORDS[wd] },
    tithi: { name: TITHIS[tithiIdx], nameHi: TITHIS_HI[tithiIdx], paksha, pakshaNi: paksha==='Shukla'?'शुक्ल':'कृष्ण', type: TITHI_TYPES[tithiIdx], endTime: estimateEnd(elong, 12, jd, loc.tzOffset, 13.17) },
    nakshatra: { name: NAKSHATRAS[nIdx], nameHi: NAKSHATRAS_HI[nIdx], lord: NAKSHATRA_LORDS[nIdx], pada, endTime: estimateEnd(mSid, 360/27, jd, loc.tzOffset, 13.17) },
    yoga: { name: YOGAS[yIdx], nameHi: YOGAS_HI[yIdx], type: YOGA_TYPES[yIdx], endTime: estimateEnd(yLon, 360/27, jd, loc.tzOffset, 14.17) },
    karana: { name: KARANAS[kIdx]||'Bava', nameHi: KARANAS_HI[kIdx]||'बव', endTime: estimateEnd(elong, 6, jd, loc.tzOffset, 13.17) },
    sunrise: fmtTime(srUTC, loc.tzOffset),
    sunset: fmtTime(ssUTC, loc.tzOffset),
    moonrise: minsToFmt(((mrMins % 1440) + 1440) % 1440),
    durationDay: `${Math.floor(dayMins/60)}h ${Math.round(dayMins%60)}m`,
    rahuKalam: slot(RAHU[wd]),
    gulikaKalam: slot(GULIKA[wd]),
    yamaganda: slot(YAMA[wd] < 8 ? YAMA[wd] : 7),
    abhijitMuhurta: { start: minsToFmt(abStart), end: minsToFmt(abEnd) },
    srMins, ssMins,
    sunSidereal: sSid,
    moonSidereal: mSid,
    tithiPaksha: paksha as 'Shukla' | 'Krishna',
  };
}

