---
import Layout from '../layouts/Layout.astro';
import PanchangSummaryCard from '../components/PanchangSummaryCard.astro';
import KundaliWidget from '../components/KundaliWidget.astro';
import FestivalFeed from '../components/FestivalFeed.astro';
import PlanetaryEventsFeed from '../components/PlanetaryEventsFeed.astro';
import RashifalFeed from '../components/RashifalFeed.astro';
import VedicClock from '../components/VedicClock.astro';
import { calculatePanchang, getHinduCalendarInfo } from '../lib/panchang';
import { getUpcomingFestivals, getTodayFestivals, daysUntil } from '../lib/festivals';
import { computeUpcomingEvents } from '../lib/planetaryEvents';
import { getDefaultLocation } from '../lib/locations';

const today = new Date();
const loc = getDefaultLocation(); // New Delhi, will be overridden client-side
const panchang = calculatePanchang(today, loc.lat, loc.lng, loc.tzOffset);
const hinduCal = getHinduCalendarInfo(today, panchang.sunLongitude, panchang.moonLongitude, panchang.tithi.paksha);
const todayFestivals = getTodayFestivals(today);
const upcoming = getUpcomingFestivals(today, 8);
const planetaryEvents = computeUpcomingEvents(today, 180);

const dateStr = today.toLocaleDateString('en-IN', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title="PanchangPath — Today's Hindu Panchang">
  <!-- HERO -->
  <section style="position:relative;overflow:hidden;background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);">
    <div class="gradient-mesh" style="position:absolute;inset:0;pointer-events:none;opacity:0.7;"></div>
    <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;position:relative;padding-top:56px;padding-bottom:48px;">

      <!-- Festival badge -->
      {todayFestivals.length > 0 && (
        <div style="margin-bottom:20px;">
          <a href="/festivals" style="display:inline-flex;align-items:center;gap:8px;background:var(--color-saffron-soft);color:var(--color-saffron-deep);font-size:13px;font-weight:500;padding:5px 12px;border-radius:100px;text-decoration:none;border:1px solid rgba(255,153,51,0.3);">
            <span>🪔</span>
            <span>{todayFestivals[0].name} today</span>
            <span style="opacity:0.6;">→</span>
          </a>
        </div>
      )}

      <!-- Headline -->
      <h1 style="font-size:42px;font-weight:600;letter-spacing:-1.6px;line-height:1.05;color:var(--color-ink);margin:0 0 16px;max-width:680px;" id="hero-title">
        Today's Panchang.
      </h1>
      <p style="font-size:17px;color:var(--color-body-text);margin:0 0 32px;line-height:1.6;max-width:520px;" id="hero-sub">
        Precise Hindu almanac for <strong id="loc-display" style="color:var(--color-ink);">{loc.name}</strong> — auto-detected from your location.
      </p>

      <!-- Controls row -->
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <!-- Date picker -->
        <div style="display:flex;align-items:center;gap:8px;background:var(--color-canvas);border:1px solid var(--color-hairline);border-radius:8px;padding:6px 12px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-mute)" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <input type="date" id="date-picker" class="input" style="border:none;background:transparent;height:auto;padding:0;font-size:14px;width:140px;color:var(--color-ink);"
            value={today.toISOString().split('T')[0]} />
        </div>
        <!-- Location selector -->
        <div style="display:flex;align-items:center;gap:8px;background:var(--color-canvas);border:1px solid var(--color-hairline);border-radius:8px;padding:6px 12px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-mute)" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <select id="city-select" class="input" style="border:none;background:transparent;height:auto;padding:0;font-size:14px;color:var(--color-ink);cursor:pointer;">
            <option value="">Detecting location…</option>
          </select>
        </div>
        <!-- Detect location -->
        <button id="detect-btn" class="btn-secondary" style="height:36px;font-size:13px;gap:6px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
          </svg>
          Auto-detect
        </button>
      </div>

      <!-- Date display -->
      <p class="caption-mono" style="color:var(--color-mute);margin-top:20px;" id="date-display">{dateStr}</p>
    </div>
  </section>

  <!-- PANCHANG SUMMARY CARD -->
  <PanchangSummaryCard
    city={loc.name}
    cityHi={loc.nameHi ?? loc.name}
    dateStr={dateStr}
    panchang={panchang}
    hinduCal={hinduCal}
  />

  <!-- VEDIC TIME CLOCK -->
  <VedicClock />

  <!-- LAGNA KUNDALI WIDGET -->
  <KundaliWidget />

  <!-- MAIN PANCHANG GRID -->
  <section style="padding:0 0 40px;" id="panchang-section">
    <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
      <!-- Live indicator -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:24px;">
        <div style="position:relative;display:flex;align-items:center;justify-content:center;">
          <div class="live-pulse"></div>
          <div class="live-pulse-dot"></div>
        </div>
        <span class="caption-mono" style="color:var(--color-mute);">Panchang for <span id="panchang-date-label">{today.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })}</span></span>
      </div>

      <!-- 5 Panchang elements -->
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:12px;" class="panchang-grid" id="pancha-grid">
        <!-- Vara -->
        <div class="card animate-in" style="padding:20px;animation-delay:0ms;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Vara</p>
          <p class="en-text" style="font-size:22px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 2px;" id="vara-name">{panchang.vara.name}</p>
          <p class="hi-text" style="font-size:18px;font-weight:600;color:var(--color-ink);margin:0 0 2px;display:none;" id="vara-name-hi">{panchang.vara.nameHi}</p>
          <p style="font-size:12px;color:var(--color-mute);margin:0;" id="vara-lord">Lord: {panchang.vara.lord}</p>
        </div>

        <!-- Tithi -->
        <div class="card animate-in" style="padding:20px;animation-delay:60ms;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Tithi</p>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
            <div>
              <p class="en-text" style="font-size:20px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 2px;" id="tithi-name">{panchang.tithi.paksha} {panchang.tithi.name}</p>
              <p class="hi-text" style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 2px;display:none;" id="tithi-name-hi">{panchang.tithi.pakshaNi} {panchang.tithi.nameHi}</p>
            </div>
            <span class="badge" id="tithi-type" style="flex-shrink:0;font-size:10px;">{panchang.tithi.type}</span>
          </div>
          <p style="font-size:11px;color:var(--color-mute);margin:4px 0 0;font-family:var(--font-mono);" id="tithi-end">Ends: {panchang.tithi.endTime}</p>
        </div>

        <!-- Nakshatra -->
        <div class="card animate-in" style="padding:20px;animation-delay:120ms;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Nakshatra</p>
          <p class="en-text" style="font-size:20px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 2px;" id="nakshatra-name">{panchang.nakshatra.name}</p>
          <p class="hi-text" style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 2px;display:none;" id="nakshatra-name-hi">{panchang.nakshatra.nameHi}</p>
          <p style="font-size:11px;color:var(--color-mute);margin:2px 0;font-family:var(--font-mono);" id="nakshatra-meta">Pada {panchang.nakshatra.pada} · {panchang.nakshatra.lord}</p>
          <p style="font-size:11px;color:var(--color-mute);margin:0;font-family:var(--font-mono);" id="nakshatra-end">Ends: {panchang.nakshatra.endTime}</p>
        </div>

        <!-- Yoga -->
        <div class="card animate-in" style="padding:20px;animation-delay:180ms;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Yoga</p>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
            <div>
              <p class="en-text" style="font-size:20px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 2px;" id="yoga-name">{panchang.yoga.name}</p>
              <p class="hi-text" style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 2px;display:none;" id="yoga-name-hi">{panchang.yoga.nameHi}</p>
            </div>
            <span class="badge" id="yoga-type" style="flex-shrink:0;font-size:10px;">{panchang.yoga.type}</span>
          </div>
          <p style="font-size:11px;color:var(--color-mute);margin:4px 0 0;font-family:var(--font-mono);" id="yoga-end">Ends: {panchang.yoga.endTime}</p>
        </div>

        <!-- Karana -->
        <div class="card animate-in" style="padding:20px;animation-delay:240ms;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Karana</p>
          <p class="en-text" style="font-size:20px;font-weight:600;letter-spacing:-0.5px;color:var(--color-ink);margin:0 0 2px;" id="karana-name">{panchang.karana.name}</p>
          <p class="hi-text" style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 2px;display:none;" id="karana-name-hi">{panchang.karana.nameHi}</p>
          <p style="font-size:11px;color:var(--color-mute);margin:4px 0 0;font-family:var(--font-mono);" id="karana-end">Ends: {panchang.karana.endTime}</p>
        </div>
      </div>

      <!-- Sun times + Muhurtas row -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
        <!-- Sun & Moon times -->
        <div class="card" style="padding:24px;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0 0 16px;">Sun & Moon</p>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;">
            <div>
              <p style="font-size:11px;color:var(--color-mute);margin:0 0 4px;font-family:var(--font-mono);">SUNRISE</p>
              <p style="font-size:18px;font-weight:600;letter-spacing:-0.3px;color:var(--color-ink);margin:0;" id="sunrise">{panchang.sunrise}</p>
            </div>
            <div>
              <p style="font-size:11px;color:var(--color-mute);margin:0 0 4px;font-family:var(--font-mono);">SUNSET</p>
              <p style="font-size:18px;font-weight:600;letter-spacing:-0.3px;color:var(--color-ink);margin:0;" id="sunset">{panchang.sunset}</p>
            </div>
            <div>
              <p style="font-size:11px;color:var(--color-mute);margin:0 0 4px;font-family:var(--font-mono);">MOONRISE</p>
              <p style="font-size:18px;font-weight:600;letter-spacing:-0.3px;color:var(--color-ink);margin:0;" id="moonrise">{panchang.moonrise}</p>
            </div>
            <div>
              <p style="font-size:11px;color:var(--color-mute);margin:0 0 4px;font-family:var(--font-mono);">DAY LENGTH</p>
              <p style="font-size:18px;font-weight:600;letter-spacing:-0.3px;color:var(--color-ink);margin:0;" id="day-duration">{panchang.durationDay}</p>
            </div>
          </div>
        </div>

        <!-- Abhijit Muhurta -->
        <div class="card" style="padding:24px;background:var(--color-canvas);">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
            <p class="caption-mono" style="color:var(--color-mute);margin:0;">Abhijit Muhurta</p>
            <span class="badge-auspicious badge" style="font-size:10px;">Most Auspicious</span>
          </div>
          <p class="en-text" style="font-size:26px;font-weight:600;letter-spacing:-0.8px;color:var(--color-ink);margin:0 0 4px;" id="abhijit-time">{panchang.abhijitMuhurta.start} – {panchang.abhijitMuhurta.end}</p>
          <p style="font-size:13px;color:var(--color-body-text);margin:0;">Solar noon window — ideal for any important work, travel, or ceremony.</p>
        </div>
      </div>

      <!-- Inauspicious times -->
      <div class="card" style="padding:24px;margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
          <p class="caption-mono" style="color:var(--color-mute);margin:0;">Inauspicious Periods</p>
          <span class="badge-inauspicious badge" style="font-size:10px;">Avoid important work</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;">
          <div>
            <p style="font-size:11px;color:var(--color-mute);margin:0 0 6px;font-family:var(--font-mono);letter-spacing:0.06em;text-transform:uppercase;">Rahu Kalam</p>
            <p style="font-size:20px;font-weight:600;letter-spacing:-0.4px;color:var(--color-ink);margin:0 0 2px;" id="rahu-time">{panchang.rahuKalam.start} – {panchang.rahuKalam.end}</p>
            <p style="font-size:12px;color:var(--color-mute);margin:0;">Shadow of Rahu — most inauspicious</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--color-mute);margin:0 0 6px;font-family:var(--font-mono);letter-spacing:0.06em;text-transform:uppercase;">Gulika Kalam</p>
            <p style="font-size:20px;font-weight:600;letter-spacing:-0.4px;color:var(--color-ink);margin:0 0 2px;" id="gulika-time">{panchang.gulikaKalam.start} – {panchang.gulikaKalam.end}</p>
            <p style="font-size:12px;color:var(--color-mute);margin:0;">Son of Saturn — avoid new ventures</p>
          </div>
          <div>
            <p style="font-size:11px;color:var(--color-mute);margin:0 0 6px;font-family:var(--font-mono);letter-spacing:0.06em;text-transform:uppercase;">Yamaganda</p>
            <p style="font-size:20px;font-weight:600;letter-spacing:-0.4px;color:var(--color-ink);margin:0 0 2px;" id="yama-time">{panchang.yamaganda.start} – {panchang.yamaganda.end}</p>
            <p style="font-size:12px;color:var(--color-mute);margin:0;">Period of Yama — avoid travel</p>
          </div>
        </div>
      </div>

      <!-- Day timeline bar -->
      <div class="card" style="padding:20px 24px;margin-bottom:12px;overflow:hidden;">
        <p class="caption-mono" style="color:var(--color-mute);margin:0 0 14px;">Day Timeline</p>
        <div style="position:relative;height:32px;background:var(--color-canvas-soft-2);border-radius:4px;overflow:hidden;" id="timeline-bar">
          <!-- Filled by JS -->
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:6px;">
          <span style="font-size:11px;color:var(--color-mute);font-family:var(--font-mono);" id="tl-sunrise">{panchang.sunrise}</span>
          <span style="font-size:11px;color:var(--color-mute);font-family:var(--font-mono);" id="tl-sunset">{panchang.sunset}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- UPCOMING FESTIVALS & VRATS FEED -->
  <FestivalFeed festivals={upcoming} today={today} />

  <!-- UPCOMING PLANETARY EVENTS FEED -->
  <PlanetaryEventsFeed events={planetaryEvents} today={today} />

  <!-- RASHIFAL SECTION -->
  <RashifalFeed today={today} />

  <!-- WHY PANCHANGPATH section -->
  <section style="padding:64px 0;">
    <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
      <div style="text-align:center;max-width:560px;margin:0 auto 40px;">
        <p class="caption-mono" style="color:var(--color-mute);margin:0 0 10px;">Why PanchangPath</p>
        <h2 style="font-size:28px;font-weight:600;letter-spacing:-1px;color:var(--color-ink);margin:0 0 12px;">Better than every other Panchang site.</h2>
        <p style="font-size:15px;color:var(--color-body-text);margin:0;line-height:1.7;">Built on Drik (astronomical) calculations with Lahiri Ayanamsha. Zero ads. Loads instantly.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
        {[
          { icon: '🎯', title: 'Astronomically Precise', desc: 'Drik method with Lahiri Ayanamsha — same calculations used by traditional pandits and modern ephemerides.' },
          { icon: '📍', title: 'Location-Aware', desc: 'Sunrise, Kalam periods, and Muhurtas auto-adjusted for your exact GPS coordinates.' },
          { icon: '🌙', title: 'Dark Mode', desc: 'First-class dark mode that actually looks good. None of our competitors have this.' },
          { icon: '📅', title: 'Monthly Calendar', desc: 'See the full month Panchang at a glance — Tithis, Nakshatras, and festivals on one calendar.' },
          { icon: '⚡', title: 'No Ads. Ever.', desc: 'The entire site is ad-free. We believe sacred information should not be cluttered with ads.' },
          { icon: '🌐', title: 'Hindi + English', desc: 'Every Panchang element shown in both English and Hindi — switch instantly with one tap.' },
        ].map(f => (
          <div class="card" style="padding:24px;">
            <div style="font-size:24px;margin-bottom:12px;">{f.icon}</div>
            <p style="font-size:15px;font-weight:600;color:var(--color-ink);margin:0 0 8px;">{f.title}</p>
            <p style="font-size:13px;color:var(--color-body-text);margin:0;line-height:1.6;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section style="background:var(--color-ink);padding:64px 0;">
    <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;text-align:center;">
      <h2 style="font-size:30px;font-weight:600;letter-spacing:-1px;color:#ffffff;margin:0 0 12px;">Start every day with Panchang.</h2>
      <p style="font-size:16px;color:rgba(255,255,255,0.6);margin:0 0 28px;">Bookmark this page, or set it as your homepage.</p>
      <div style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;">
        <a href="/" style="display:inline-flex;align-items:center;gap:6px;background:#ffffff;color:#171717;font-size:14px;font-weight:500;padding:0 20px;height:40px;border-radius:100px;text-decoration:none;">
          🕉️ Open Today's Panchang
        </a>
        <a href="/festivals" style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.1);color:#ffffff;font-size:14px;font-weight:500;padding:0 20px;height:40px;border-radius:100px;text-decoration:none;border:1px solid rgba(255,255,255,0.2);">
          View Festival Calendar →
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
// ─── Client-side Panchang engine ─────────────────────────────────────────
// Mirrors src/lib/panchang.ts + src/lib/panchang.ts#getHinduCalendarInfo

// ── Global display state ──
let timeFormat: '12h' | '24h' | '24p' = '12h';
let calSchool: 'amanta' | 'purnimanta' = 'amanta';
let chartVisible = false;
let srMinsGlobal = 0; // sunrise (mins from midnight) for 24+ format

const toRad = (d: number) => d * Math.PI / 180;
const toDeg = (r: number) => r * 180 / Math.PI;
const norm360 = (a: number) => ((a % 360) + 360) % 360;

function julianDay(year: number, month: number, day: number, hour = 0): number {
  if (month <= 2) { year -= 1; month += 12; }
  const A = Math.floor(year / 100);
  const B = 2 - A + Math.floor(A / 4);
  return Math.floor(365.25 * (year + 4716)) + Math.floor(30.6001 * (month + 1)) + day + hour / 24 + B - 1524.5;
}

function sunTrueLon(jd: number): number {
  const T = (jd - 2451545.0) / 36525;
  const L0 = norm360(280.46646 + 36000.76983 * T);
  const M = norm360(357.52911 + 35999.05029 * T);
  const Mr = toRad(M);
  return norm360(L0 + (1.914602 - 0.004817 * T) * Math.sin(Mr) + 0.019993 * Math.sin(2 * Mr));
}

function moonLon(jd: number): number {
  const T = (jd - 2451545.0) / 36525;
  const L = norm360(218.3164477 + 481267.88123421 * T);
  const D = norm360(297.8501921 + 445267.1114034 * T);
  const M = norm360(357.5291092 + 35999.0502909 * T);
  const Mp = norm360(134.9633964 + 477198.8675055 * T);
  const F = norm360(93.2720950 + 483202.0175233 * T);
  const Dr = toRad(D), Mr = toRad(M), Mpr = toRad(Mp), Fr = toRad(F);
  const dL = 6.288774*Math.sin(Mpr)+1.274027*Math.sin(2*Dr-Mpr)+0.658314*Math.sin(2*Dr)
    +0.213618*Math.sin(2*Mpr)-0.185116*Math.sin(Mr)-0.114332*Math.sin(2*Fr)
    +0.058793*Math.sin(2*Dr-2*Mpr)+0.057066*Math.sin(2*Dr-Mr-Mpr)+0.053322*Math.sin(2*Dr+Mpr)
    +0.045758*Math.sin(2*Dr-Mr)-0.040923*Math.sin(Mr-Mpr)-0.034720*Math.sin(Dr)
    -0.030383*Math.sin(Mr+Mpr)+0.015327*Math.sin(2*Dr-2*Fr)+0.010980*Math.sin(Mpr-2*Fr)
    +0.010675*Math.sin(4*Dr-Mpr)+0.010034*Math.sin(3*Mpr)+0.008548*Math.sin(4*Dr-2*Mpr);
  return norm360(L + dL / 1000);
}

function ayanamsha(jd: number): number {
  const T = (jd - 2451545.0) / 36525;
  return 23.85 + 1.3612 * T;
}

function sunriseUTC(jd: number, lat: number, lng: number, rising: boolean): number {
  const T = (jd - 2451545.0) / 36525;
  const M = norm360(357.52911 + 35999.05029 * T);
  const L0 = norm360(280.46646 + 36000.76983 * T);
  const Mr = toRad(M);
  const sunLon = L0 + (1.914602 - 0.004817 * T) * Math.sin(Mr) + 0.019993 * Math.sin(2 * Mr);
  const obliq = 23.4393 - 0.0000004 * T * 36525;
  const sinDec = Math.sin(toRad(obliq)) * Math.sin(toRad(sunLon));
  const dec = Math.asin(sinDec);
  const latR = toRad(lat);
  const cosHA = (Math.sin(toRad(-0.8333)) - Math.sin(latR) * Math.sin(dec)) / (Math.cos(latR) * Math.cos(dec));
  if (cosHA < -1 || cosHA > 1) return NaN;
  const HA = toDeg(Math.acos(cosHA));
  const noon = 12 - lng / 15;
  return rising ? noon - HA / 15 : noon + HA / 15;
}

function minsToFmt(totalMins: number): string {
  const m = ((totalMins % 1440) + 1440) % 1440;
  const h = Math.floor(m / 60);
  const mn = Math.round(m % 60);
  if (timeFormat === '24h') {
    return `${String(h).padStart(2,'0')}:${String(mn).padStart(2,'0')}`;
  } else if (timeFormat === '24p') {
    // Times before sunrise are part of the panchang day that started the previous sunrise;
    // display them as 24+ (e.g. 1:30 AM → 25:30 when sunrise is ~5:30 AM)
    const display = m < srMinsGlobal ? m + 1440 : m;
    const dh = Math.floor(display / 60);
    const dm = Math.round(display % 60);
    return `${String(dh).padStart(2,'0')}:${String(dm).padStart(2,'0')}`;
  }
  // 12h (default)
  const ap = h < 12 ? 'AM' : 'PM';
  return `${h % 12 || 12}:${String(mn).padStart(2,'0')} ${ap}`;
}

function fmtTime(h: number, tz: number): string {
  const local = ((h + tz) % 24 + 24) % 24;
  return minsToFmt(local * 60);
}

function estimateEnd(lon: number, step: number, jd: number, tz: number, rate: number): string {
  const remaining = step - (lon % step);
  const hoursToEnd = (remaining / rate) * 24;
  const hourUTC = (jd - (Math.floor(jd - 0.5) + 0.5)) * 24;
  return fmtTime(hourUTC + hoursToEnd, tz);
}

