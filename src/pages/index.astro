function drawTimeline(p: ReturnType<typeof calcPanchang>) {
  const bar = document.getElementById('timeline-bar');
  if (!bar) return;
  const sr = p.srMins, ss = p.ssMins, total = ss - sr;
  if (total <= 0) return;
  const pct = (m: number) => Math.max(0, Math.min(100, ((m - sr) / total) * 100));
  const now = new Date();
  const nowMins = now.getHours() * 60 + now.getMinutes();
  const segments = [
    { start: pct(p.rahuKalam.start), end: pct(p.rahuKalam.end), color: '#ef4444', label: 'Rahu', startM: sr + RAHU[currentDate.getDay()] * (total/8) },
    { start: pct(p.gulikaKalam.start), end: pct(p.gulikaKalam.end), color: '#f59e0b', label: 'Gulika', startM: sr + GULIKA[currentDate.getDay()] * (total/8) },
    { start: pct(p.yamaganda.start), end: pct(p.yamaganda.end), color: '#8b5cf6', label: 'Yama', startM: sr + (YAMA[currentDate.getDay()] < 8 ? YAMA[currentDate.getDay()] : 7) * (total/8) },
  ];
  const nowPct = pct(nowMins);
  bar.innerHTML = segments.map(s => {
    const sp = typeof s.start === 'number' ? s.start : pct(s.startM);
    const ep = typeof s.end === 'number' ? s.end : pct(s.startM + total/8);
    return `<div style="position:absolute;left:${sp}%;width:${ep-sp}%;height:100%;background:${s.color};opacity:0.25;" title="${s.label} Kalam"></div>`;
  }).join('') + `<div style="position:absolute;left:${nowPct}%;top:0;width:2px;height:100%;background:var(--color-ink);border-radius:1px;" title="Now"></div>`;
}

function applyLang(hindi: boolean) {
  isHindi = hindi;
  document.querySelectorAll('.en-text').forEach(el => (el as HTMLElement).style.display = hindi ? 'none' : 'block');
  document.querySelectorAll('.hi-text').forEach(el => (el as HTMLElement).style.display = hindi ? 'block' : 'none');
  const locDisplay = document.getElementById('loc-display');
  if (locDisplay) locDisplay.textContent = hindi ? currentLoc.nameHi : currentLoc.name;
  // Refresh summary card to update bilingual fields
  const p = calcPanchang(currentDate, currentLoc);
  updateSummaryCard(p, currentDate, currentLoc);
}

function updateSummaryCard(p: ReturnType<typeof calcPanchang>, date: Date, loc: Location) {
  const cal = getHinduCalInfo(date, p.sunSidereal, p.moonSidereal, p.tithiPaksha);

  // Header
  setText('ps-city', loc.name); setText('ps-city-hi', loc.nameHi ?? loc.name);
  setText('ps-date', date.toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' }));

  // Vikrama / Shaka
  setText('ps-vs-year', String(cal.vsYear));
  setText('ps-vs-name', cal.vsName);
  setText('ps-ss-year', String(cal.ssYear));

  // Hindu month (Amanta / Purnimanta)
  const month = calSchool === 'purnimanta' ? cal.purnimantaMonth : cal.amantaMonth;
  const monthLbl = document.getElementById('ps-month-lbl');
  if (monthLbl) monthLbl.textContent = calSchool === 'purnimanta' ? 'Purnimanta Month' : 'Amanta Month';
  setText('ps-month', month.name);
  setText('ps-month-hi', month.nameHi);

  // Vara
  setText('ps-vara', p.vara.name);
  setText('ps-vara-hi', p.vara.nameHi);

  // Sun / moon times
  setText('ps-sunrise', p.sunrise); setText('ps-sunset', p.sunset);
  setText('ps-tl-sunrise', p.sunrise); setText('ps-tl-sunset', p.sunset);

  // Rashis
  const enMode = !isHindi;
  if (enMode) {
    setText('ps-sunsign', `${cal.sunRashi.name} (${cal.sunRashi.en})`);
    setText('ps-moonsign', `${cal.moonRashi.name} (${cal.moonRashi.en})`);
  } else {
    setText('ps-sunsign-hi', cal.sunRashi.nameHi);
    setText('ps-moonsign-hi', cal.moonRashi.nameHi);
  }

  // Paksha badge
  const pakshaBadge = document.getElementById('ps-paksha-badge');
  if (pakshaBadge) {
    pakshaBadge.dataset.isShukla = p.tithiPaksha === 'Shukla' ? 'true' : 'false';
    const isShukla = p.tithiPaksha === 'Shukla';
    pakshaBadge.innerHTML = `${isShukla ? '🌕' : '🌑'}
      <span class="en-text" style="${isHindi ? 'display:none' : ''}">${p.tithiPaksha} Paksha</span>
      <span class="hi-text" style="${isHindi ? '' : 'display:none'}">${p.tithi.pakshaNi} पक्ष</span>`;
    pakshaBadge.style.cssText = isShukla
      ? 'background:rgba(255,153,51,0.12);color:var(--color-saffron-deep);border:1px solid rgba(255,153,51,0.25);display:inline-flex;align-items:center;gap:5px;padding:2px 10px 2px 6px;border-radius:var(--radius-pill);font-size:12.5px;font-weight:600;'
      : 'background:var(--color-canvas-soft-2);color:var(--color-body-text);border:1px solid var(--color-hairline);display:inline-flex;align-items:center;gap:5px;padding:2px 10px 2px 6px;border-radius:var(--radius-pill);font-size:12.5px;font-weight:600;';
  }

  // Tithi
  setText('ps-tithi', p.tithi.name); setText('ps-tithi-hi', p.tithi.nameHi);
  setText('ps-tithi-ends', `ends ${p.tithi.endTime}`);

  // Nakshatra
  setText('ps-nakshatra', p.nakshatra.name); setText('ps-nakshatra-hi', p.nakshatra.nameHi);
  setText('ps-nakshatra-sub', `, Pada ${p.nakshatra.pada} · ${p.nakshatra.lord}`);
  setText('ps-nakshatra-ends', `ends ${p.nakshatra.endTime}`);

  // Yoga
  setText('ps-yoga', p.yoga.name); setText('ps-yoga-hi', p.yoga.nameHi);
  setText('ps-yoga-ends', `ends ${p.yoga.endTime}`);
  const yogaBadge = document.getElementById('ps-yoga-badge');
  if (yogaBadge) {
    yogaBadge.textContent = p.yoga.type;
    yogaBadge.style.cssText = p.yoga.type === 'Auspicious'
      ? 'background:var(--color-auspicious-soft);color:#15803d;border-color:rgba(34,197,94,0.3);display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 7px;border-radius:9999px;border:1px solid;'
      : 'background:var(--color-inauspicious-soft);color:#b91c1c;border-color:rgba(239,68,68,0.3);display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 7px;border-radius:9999px;border:1px solid;';
  }

  // Karana
  setText('ps-karana', p.karana.name); setText('ps-karana-hi', p.karana.nameHi);
  setText('ps-karana-ends', `ends ${p.karana.endTime}`);

  // Kalam + Abhijit
  setText('ps-rahu-kalam', `${p.rahuKalam.start} – ${p.rahuKalam.end}`);
  setText('ps-abhijit', `${p.abhijitMuhurta.start} – ${p.abhijitMuhurta.end}`);
  setText('ps-day-length', p.durationDay);

  // Draw chart if visible
  if (chartVisible) drawSummaryTimeline(p);
}

function drawSummaryTimeline(p: ReturnType<typeof calcPanchang>) {
  const bar = document.getElementById('ps-timeline');
  if (!bar) return;
  const sr = p.srMins, ss = p.ssMins, total = ss - sr;
  if (total <= 0) return;
  const pct = (m: number) => Math.max(0, Math.min(100, ((m - sr) / total) * 100));
  const now = new Date();
  const nowMins = now.getHours() * 60 + now.getMinutes();
  const wd = currentDate.getDay();
  const RAHU_S = [7,1,6,4,5,2,3], GULIKA_S = [6,5,4,3,2,1,0], YAMA_S = [3,5,2,7,4,6,1];
  const slotDur = total / 8;
  const segments = [
    { s: pct(sr + RAHU_S[wd] * slotDur), e: pct(sr + (RAHU_S[wd]+1) * slotDur), color: '#ef4444' },
    { s: pct(sr + GULIKA_S[wd] * slotDur), e: pct(sr + (GULIKA_S[wd]+1) * slotDur), color: '#f59e0b' },
    { s: pct(sr + (YAMA_S[wd] < 8 ? YAMA_S[wd] : 7) * slotDur), e: pct(sr + ((YAMA_S[wd] < 8 ? YAMA_S[wd] : 7)+1) * slotDur), color: '#8b5cf6' },
  ];
  const nowPct = pct(nowMins);
  bar.innerHTML =
    `<div style="position:absolute;inset:0;background:linear-gradient(90deg,#fef3c7 0%,#fed7aa 50%,#fde68a 100%);opacity:0.3;"></div>` +
    segments.map(sg =>
      `<div style="position:absolute;left:${sg.s}%;width:${sg.e - sg.s}%;height:100%;background:${sg.color};opacity:0.35;"></div>`
    ).join('') +
    `<div style="position:absolute;left:${nowPct}%;top:0;width:2px;height:100%;background:var(--color-ink);border-radius:1px;" title="Now"></div>` +
    `<div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-size:9px;color:var(--color-mute);font-family:var(--font-mono);pointer-events:none;">Noon</div>`;
}

function renderWithLoc(loc: Location, date: Date) {
  currentLoc = loc; currentDate = date;
  const p = calcPanchang(date, loc);
  updateUI(p);
  updateSummaryCard(p, date, loc);
  // Update Kundali widget
  if (typeof (window as any).updateKundaliWidget === 'function') {
    (window as any).updateKundaliWidget(loc.lat, loc.lng, isHindi ? (loc.nameHi ?? loc.name) : loc.name);
  }
  // Update Vedic Clock
  if (typeof (window as any).updateVedicClock === 'function') {
    const cal = getHinduCalInfo(date, p.sunSidereal, p.moonSidereal, p.tithiPaksha);
    const tithiStr = cal.amantaMonth.name + " " + p.tithi.paksha + " " + p.tithi.name;
    const vsStr = "VS " + cal.vsYear;
    const weekStr = date.toLocaleDateString("en-IN", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
    (window as any).updateVedicClock({
      srMins: p.srMins,
      ssMins: p.ssMins,
      cityName: isHindi ? (loc.nameHi ?? loc.name) : loc.name,
      tithi: tithiStr,
      vs: vsStr,
      weekday: weekStr,
      srFormatted: p.sunrise,
      ssFormatted: p.sunset,
      dayLen: p.durationDay,
    });
  }
  // Update date label
  const d = date.toLocaleDateString('en-IN', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
  setText('date-display', d);
  setText('panchang-date-label', date.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }));
  const locDisplay = document.getElementById('loc-display');
  if (locDisplay) locDisplay.textContent = isHindi ? loc.nameHi : loc.name;
}

// Populate city selector
const sel = document.getElementById('city-select') as HTMLSelectElement;
if (sel) {
  sel.innerHTML = LOCS.map(l => `<option value="${l.name}">${l.name}${l.country !== 'India' ? ` (${l.country})` : ''}</option>`).join('');
  sel.value = 'New Delhi';
}

// Date picker
const dp = document.getElementById('date-picker') as HTMLInputElement;
dp?.addEventListener('change', () => {
  const d = new Date(dp.value + 'T12:00:00');
  renderWithLoc(currentLoc, d);
});

// City select
sel?.addEventListener('change', () => {
  const loc = LOCS.find(l => l.name === sel.value);
  if (loc) renderWithLoc(loc, currentDate);
});

// Auto-detect
document.getElementById('detect-btn')?.addEventListener('click', () => {
  if (!navigator.geolocation) return;
  navigator.geolocation.getCurrentPosition(pos => {
    const { latitude, longitude } = pos.coords;
    const tzOffset = -(new Date().getTimezoneOffset()) / 60;
    const custom: Location = { name: 'My Location', nameHi: 'मेरा स्थान', lat: latitude, lng: longitude, tzOffset, country: '' };
    LOCS.unshift(custom);
    if (sel) {
      const opt = document.createElement('option');
      opt.value = 'My Location'; opt.text = '📍 My Location'; opt.selected = true;
      sel.prepend(opt);
    }
    renderWithLoc(custom, currentDate);
  });
});

// Language change
document.addEventListener('langchange', (e: Event) => {
  const evt = e as CustomEvent;
  applyLang(evt.detail.hindi);
});

// ── Toolbar: time format ──
document.querySelectorAll<HTMLButtonElement>('.ps-seg-btn[data-fmt]').forEach(btn => {
  btn.addEventListener('click', () => {
    timeFormat = btn.dataset.fmt as '12h' | '24h' | '24p';
    document.querySelectorAll<HTMLButtonElement>('.ps-seg-btn[data-fmt]').forEach(b => {
      b.classList.toggle('active', b.dataset.fmt === timeFormat);
      b.setAttribute('aria-pressed', String(b.dataset.fmt === timeFormat));
    });
    renderWithLoc(currentLoc, currentDate);
  });
});

// ── Toolbar: calendar school ──
document.querySelectorAll<HTMLButtonElement>('.ps-seg-btn[data-school]').forEach(btn => {
  btn.addEventListener('click', () => {
    calSchool = btn.dataset.school as 'amanta' | 'purnimanta';
    document.querySelectorAll<HTMLButtonElement>('.ps-seg-btn[data-school]').forEach(b => {
      b.classList.toggle('active', b.dataset.school === calSchool);
      b.setAttribute('aria-pressed', String(b.dataset.school === calSchool));
    });
    // Re-render summary card only (month label changes)
    const p = calcPanchang(currentDate, currentLoc);
    updateSummaryCard(p, currentDate, currentLoc);
  });
});

// ── Toolbar: chart toggle ──
const chartToggleBtn = document.getElementById('ps-chart-toggle');
const chartWrap = document.getElementById('ps-chart-wrap');
chartToggleBtn?.addEventListener('click', () => {
  chartVisible = !chartVisible;
  if (chartWrap) chartWrap.hidden = !chartVisible;
  chartToggleBtn.classList.toggle('active', chartVisible);
  chartToggleBtn.setAttribute('aria-expanded', String(chartVisible));
  if (chartVisible) {
    const p = calcPanchang(currentDate, currentLoc);
    drawSummaryTimeline(p);
  }
});

// Initial render
renderWithLoc(currentLoc, currentDate);

// Draw timeline every minute
setInterval(() => { const p = calcPanchang(currentDate, currentLoc); drawTimeline(p); }, 60000);
</script>

