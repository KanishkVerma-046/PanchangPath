function getHinduCalInfo(date: Date, sunSidereal: number, moonSidereal: number, paksha: 'Shukla' | 'Krishna') {
  const sunRashiIdx  = Math.floor(sunSidereal  / 30) % 12;
  const moonRashiIdx = Math.floor(moonSidereal / 30) % 12;
  const amantaIdx    = sunRashiIdx;
  const purnimantaIdx = paksha === 'Shukla' ? amantaIdx : (amantaIdx + 1) % 12;
  const year = date.getFullYear();
  const dayOfYear = Math.floor((Date.UTC(year, date.getMonth(), date.getDate()) - Date.UTC(year, 0, 0)) / 86400000);
  const vsYear = dayOfYear >= 91 ? year + 57 : year + 56;
  const ssYear = vsYear - 135;
  const vsName = SAMVATSARA_CL[(vsYear - 1) % 60];
  return { vsYear, ssYear, vsName, sunRashi: RASHIS_CL[sunRashiIdx], moonRashi: RASHIS_CL[moonRashiIdx], amantaMonth: AMANTA_CL[amantaIdx], purnimantaMonth: AMANTA_CL[purnimantaIdx] };
}

