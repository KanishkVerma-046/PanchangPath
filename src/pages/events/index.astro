---
import Layout from '../../layouts/Layout.astro';
import { computeUpcomingEvents, formatCountdownLabel, formatEventDateTime } from '../../lib/planetaryEvents';
import type { EventType } from '../../lib/planetaryEvents';

const today = new Date();
const allEvents = computeUpcomingEvents(today, 365);

// Group by month
const byMonth: Record<string, typeof allEvents> = {};
for (const ev of allEvents) {
  const key = ev.dateISO.slice(0, 7); // YYYY-MM
  if (!byMonth[key]) byMonth[key] = [];
  byMonth[key].push(ev);
}

function typeLabel(type: string): string {
  switch (type) {
    case 'sign_transit':     return 'Transit';
    case 'retrograde_start': return 'Retrograde';
    case 'direct_start':     return 'Direct';
    case 'conjunction':      return 'Conjunction';
    case 'opposition':       return 'Opposition';
    case 'solar_eclipse':    return 'Solar Eclipse';
    case 'lunar_eclipse':    return 'Lunar Eclipse';
    case 'solstice_equinox': return 'Solstice / Equinox';
    default:                 return 'Event';
  }
}

function typeClass(type: string): string {
  switch (type) {
    case 'sign_transit':      return 'ev-tag-transit';
    case 'retrograde_start':  return 'ev-tag-retro';
    case 'direct_start':      return 'ev-tag-direct';
    case 'conjunction':
    case 'opposition':        return 'ev-tag-aspect';
    case 'solar_eclipse':
    case 'lunar_eclipse':     return 'ev-tag-eclipse';
    case 'solstice_equinox':  return 'ev-tag-season';
    default:                  return '';
  }
}

function monthLabel(key: string): string {
  const d = new Date(key + '-01T00:00:00Z');
  return d.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });
}
---

<Layout
  title="Upcoming Planetary Events 2025–2026 — PanchangPath"
  description="Complete list of upcoming Jyotish planetary events: sign transits, retrograde/direct stations, eclipses, solstices, and conjunctions."
>

  <!-- Hero -->
  <section class="ev-hero">
    <div class="ev-hero-inner">
      <nav class="ev-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Planetary Events</span>
      </nav>
      <h1 class="ev-heading">
        <span class="en-text">Planetary Events</span>
        <span class="hi-text">ग्रह घटनाएँ</span>
      </h1>
      <p class="ev-sub en-text">
        Sign transits, retrogrades, eclipses, conjunctions, and seasonal crossings — next 12 months.
      </p>
      <p class="ev-sub hi-text">
        ग्रह राशि परिवर्तन, वक्री, ग्रहण, युति, और ऋतु परिवर्तन — अगले 12 महीने।
      </p>

      <!-- Type legend -->
      <div class="ev-legend" aria-label="Event types">
        <span class="ev-tag ev-tag-transit">Transit</span>
        <span class="ev-tag ev-tag-retro">Retrograde</span>
        <span class="ev-tag ev-tag-direct">Direct</span>
        <span class="ev-tag ev-tag-aspect">Conjunction / Opposition</span>
        <span class="ev-tag ev-tag-eclipse">Eclipse</span>
        <span class="ev-tag ev-tag-season">Solstice / Equinox</span>
      </div>
    </div>
  </section>

  <!-- Event list by month -->
  <div class="ev-wrapper">
    {Object.entries(byMonth).map(([monthKey, evs]) => (
      <section class="ev-month-section">
        <h2 class="ev-month-label">{monthLabel(monthKey)}</h2>
        <div class="ev-month-list">
          {evs.map(ev => {
            const countdown = formatCountdownLabel(ev.daysAway);
            const datetime  = formatEventDateTime(ev);
            const isToday   = ev.daysAway === 0;
            const isSoon    = ev.daysAway <= 7 && !isToday;
            return (
              <a href={`/events/${ev.id}`} class={`ev-row ${isToday ? 'ev-today' : ''}`}>
                <div class="ev-icon-col">
                  <span class="ev-planet-icon" style={`color:${ev.badgeColor}`}>{ev.icon}</span>
                </div>
                <div class="ev-body-col">
                  <div class="ev-meta">
                    <span class={`ev-tag ${typeClass(ev.type)}`}>{typeLabel(ev.type)}</span>
                    <span class={`ev-when ${isToday ? 'ev-when-now' : isSoon ? 'ev-when-soon' : ''}`}>
                      {isToday && <span class="ev-pulse"></span>}
                      {countdown}
                    </span>
                  </div>
                  <p class="ev-name en-text">{ev.title}</p>
                  <p class="ev-name hi-text">{ev.titleHi}</p>
                  <p class="ev-dt">{datetime}</p>
                  <p class="ev-blurb">{ev.description}</p>
                </div>
                <span class="ev-arrow" aria-hidden="true">›</span>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

</Layout>

<style>
/* ── Hero ── */
.ev-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #312e81 100%);
  padding: 48px 0 40px;
}
.ev-hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.ev-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: rgba(255,255,255,0.55);
  margin-bottom: 14px;
}
.ev-breadcrumb a { color: rgba(255,255,255,0.55); text-decoration: none; }
.ev-breadcrumb a:hover { color: #fff; }
.ev-heading {
  font-size: 36px;
  font-weight: 800;
  letter-spacing: -1px;
  color: #fff;
  margin: 0 0 10px;
  line-height: 1.1;
}
@media (max-width: 640px) { .ev-heading { font-size: 26px; } }
.ev-sub {
  font-size: 15px;
  color: rgba(255,255,255,0.7);
  margin: 0 0 20px;
  line-height: 1.6;
}
.ev-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}

/* ── Wrapper ── */
.ev-wrapper {
  max-width: 860px;
  margin: 0 auto;
  padding: 40px 24px 64px;
}

/* ── Month section ── */
.ev-month-section { margin-bottom: 40px; }
.ev-month-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: var(--color-mute);
  margin: 0 0 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--color-hairline);
}
.ev-month-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--color-hairline);
  border-radius: 10px;
  overflow: hidden;
}

/* ── Row ── */
.ev-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
  padding: 0;
  text-decoration: none;
  color: inherit;
  border-bottom: 1px solid var(--color-hairline);
  transition: background 0.15s;
}
.ev-row:last-child { border-bottom: none; }
.ev-row:hover { background: var(--color-canvas-soft); }
.ev-today { background: rgba(255,153,51,0.05); }
.ev-today:hover { background: rgba(255,153,51,0.09); }

.ev-icon-col {
  width: 52px;
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 16px;
}
.ev-planet-icon {
  font-size: 20px;
  line-height: 1;
  display: block;
}

.ev-body-col {
  flex: 1;
  min-width: 0;
  padding: 13px 8px 13px 0;
}
.ev-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
  flex-wrap: wrap;
}
.ev-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 3px;
  line-height: 1.3;
}
.ev-row:hover .ev-name { color: var(--color-saffron-deep); }
.ev-dt {
  font-size: 11px;
  font-family: var(--font-mono, monospace);
  color: var(--color-mute);
  margin: 0 0 3px;
}
.ev-blurb {
  font-size: 12px;
  color: var(--color-body-text);
  margin: 0;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ev-arrow {
  font-size: 20px;
  color: var(--color-hairline);
  padding: 14px 14px 14px 6px;
  align-self: center;
  flex-shrink: 0;
  transition: color 0.15s;
}
.ev-row:hover .ev-arrow { color: var(--color-saffron); }

/* ── Tags ── */
.ev-tag {
  display: inline-block;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 4px;
}
.ev-tag-transit { background: rgba(255,153,51,0.12); color: #c05c00; }
.ev-tag-retro   { background: rgba(220,38,38,0.10);  color: #b91c1c; }
.ev-tag-direct  { background: rgba(21,128,61,0.10);  color: #15803d; }
.ev-tag-aspect  { background: rgba(124,58,237,0.10); color: #6d28d9; }
.ev-tag-eclipse { background: rgba(30,27,75,0.12);   color: #312e81; }
.ev-tag-season  { background: rgba(14,165,233,0.10); color: #0369a1; }
html.dark .ev-tag-transit { background: rgba(255,153,51,0.18); color: #fb923c; }
html.dark .ev-tag-retro   { background: rgba(220,38,38,0.18);  color: #fca5a5; }
html.dark .ev-tag-direct  { background: rgba(21,128,61,0.18);  color: #86efac; }
html.dark .ev-tag-aspect  { background: rgba(167,139,250,0.18);color: #c4b5fd; }
html.dark .ev-tag-eclipse { background: rgba(99,102,241,0.18); color: #a5b4fc; }
html.dark .ev-tag-season  { background: rgba(56,189,248,0.18); color: #7dd3fc; }

/* ── Countdown ── */
.ev-when {
  font-size: 10.5px;
  font-weight: 700;
  font-family: var(--font-mono, monospace);
  color: var(--color-mute);
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.ev-when-now  { color: var(--color-saffron-deep); }
.ev-when-soon { color: #b45309; }
.ev-pulse {
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-saffron);
  animation: ep-blink 1.4s ease-in-out infinite;
}
@keyframes ep-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
</style>
