  <section style="max-width:1200px;margin:0 auto;padding:80px 24px;text-align:center;">
    <div style="font-size:40px;margin-bottom:16px;">🔮</div>
    <h1 style="font-size:28px;font-weight:700;color:var(--color-ink);margin:0 0 12px;">Full Kundali</h1>
    <p style="color:var(--color-body-text);font-size:15px;max-width:480px;margin:0 auto 32px;">
      Detailed birth chart with house lords, planetary dignities, Vimshottari Dasha, and complete Jyotish analysis — coming soon.
    </p>
    <a href="/" style="display:inline-block;padding:10px 24px;background:var(--color-saffron);color:#fff;border-radius:8px;font-weight:600;text-decoration:none;font-size:14px;">
      ← Back to Panchang
    </a>
  </section>
</Layout>
