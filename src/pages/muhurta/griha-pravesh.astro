---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Griha Pravesh Muhurat 2025-2026 — House Entry Dates — PanchangPath" description="Find auspicious Griha Pravesh (housewarming / house entry) dates using Vedic Panchang criteria.">

  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:40px 0 32px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <a href="/muhurta" style="font-size:12px;color:var(--color-mute);text-decoration:none;">← Muhurta Tools</a>
      <p class="caption-mono" style="color:var(--color-mute);margin:12px 0 8px;">गृह प्रवेश मुहूर्त</p>
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-1.2px;color:var(--color-ink);margin:0 0 10px;">Griha Pravesh Muhurat</h1>
      <p style="font-size:15px;color:var(--color-body-text);margin:0;max-width:520px;">Find the most auspicious dates to enter a new home or conduct a housewarming ceremony, based on Vedic Panchang rules.</p>
    </div>
  </section>

  <section style="padding:28px 0 48px;">
    <div class="container" style="max-width:900px;margin:0 auto;">
      <div class="card" style="padding:28px;margin-bottom:32px;">
        <h2 style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 20px;">Search Griha Pravesh Dates</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px;">
          <div>
            <label style="font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">From Date</label>
            <input type="date" id="gp-from" class="input" style="height:38px;" />
          </div>
          <div>
            <label style="font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">To Date</label>
            <input type="date" id="gp-to" class="input" style="height:38px;" />
          </div>
          <div>
            <label style="font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">Location</label>
            <select id="gp-city" class="input" style="height:38px;"></select>
          </div>
        </div>
        <div style="margin-bottom:20px;">
          <label style="font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:8px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em;">Griha Pravesh Type</label>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            {['Apoorva (new house)','Sapoorva (returning)','Dwandwah (after repairs)'].map((t,i) => (
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--color-body-text);cursor:pointer;">
                <input type="radio" name="gp-type" value={i} checked={i===0} style="accent-color:var(--color-saffron);" />
                {t}
              </label>
            ))}
          </div>
        </div>
        <button id="gp-find" class="btn-primary" style="width:100%;height:44px;justify-content:center;font-size:15px;">Find Griha Pravesh Dates →</button>
      </div>

      <div id="gp-results" style="display:none;">
        <h2 id="gp-results-title" style="font-size:16px;font-weight:600;color:var(--color-ink);margin:0 0 16px;"></h2>
        <div id="gp-list" style="display:flex;flex-direction:column;gap:10px;margin-bottom:40px;"></div>
      </div>

      <!-- Muhurta timing form -->
      <div class="card" style="padding:20px;margin-bottom:24px;border-left:3px solid var(--color-saffron);">
        <p style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 6px;">💡 Tip: Muhurta Timing</p>
        <p style="font-size:12px;color:var(--color-body-text);margin:0;line-height:1.6;">Once you identify an auspicious date, plan to enter the house during Amrit or Shubh Choghadiya, during Jupiter or Moon Hora, and when a benefic Lagna is rising. Avoid Rahu Kala timing for the actual entry.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;">
        {[
          {label:'Good Nakshatras',desc:'Rohini, Mrigashira, Punarvasu, Pushya, Uttara Phalguni, Hasta, Chitra, Swati, Anuradha, Uttara Ashadha, Shravana, Dhanishtha, Revati'},
          {label:'Good Tithis',desc:'Dwitiya, Tritiya, Panchami, Saptami, Dashami, Ekadashi, Dwadashi, Trayodashi. Avoid Rikta tithis (4th, 9th, 14th) and Amavasya.'},
          {label:'Good Weekdays',desc:'Monday, Wednesday, Thursday, Friday. Avoid Sunday (Ravi Vara) for most auspicious activities.'},
          {label:'Months to Avoid',desc:'Kharmas (Sun in Sagittarius or Pisces), Adhika Masa, Shraadh Paksha (Krishna Paksha of Ashwin). These periods weaken any Muhurta.'},
        ].map(c => (
          <div class="card" style="padding:14px;">
            <p style="font-size:12px;font-weight:600;color:var(--color-ink);margin:0 0 5px;">{c.label}</p>
            <p style="font-size:11px;color:var(--color-body-text);margin:0;line-height:1.5;">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
const LOCS = [
  {name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},
  {name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},
  {name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},
  {name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},
  {name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},
  {name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},
  {name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},
  {name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},
  {name:'Dubai',lat:25.2048,lng:55.2708,tz:4},
  {name:'New York',lat:40.7128,lng:-74.006,tz:-4},
  {name:'London',lat:51.5074,lng:-0.1278,tz:1},
];

const GP_GOOD_NAKS = [3,4,6,7,11,12,13,14,16,20,21,22,26];
const GP_GOOD_TITHIS = [1,2,4,6,9,10,11,12];
const GP_AVOID_TITHIS = [3,8,13,29];
const GP_GOOD_VARAS = [1,3,4,5];
const PANCHAKA_NAKS = [22,23,24,25,26];
const GOOD_YOGAS = [1,2,3,4,6,7,10,11,13,15,19,20,21,22,23,24,25];
const NAK_NAMES=['Ashwini','Bharani','Krittika','Rohini','Mrigashira','Ardra','Punarvasu','Pushya','Ashlesha','Magha','Purva Phalguni','Uttara Phalguni','Hasta','Chitra','Swati','Vishakha','Anuradha','Jyeshtha','Mula','Purva Ashadha','Uttara Ashadha','Shravana','Dhanishtha','Shatabhisha','Purva Bhadrapada','Uttara Bhadrapada','Revati'];
const TITHI_NAMES=['Pratipada','Dwitiya','Tritiya','Chaturthi','Panchami','Shashthi','Saptami','Ashtami','Navami','Dashami','Ekadashi','Dwadashi','Trayodashi','Chaturdashi','Purnima','Pratipada','Dwitiya','Tritiya','Chaturthi','Panchami','Shashthi','Saptami','Ashtami','Navami','Dashami','Ekadashi','Dwadashi','Trayodashi','Chaturdashi','Amavasya'];
const VARA_NAMES=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const RAHU_SLOTS=[7,1,6,4,5,2,3];

function toJD(y:number,m:number,d:number,h=0){
  if(m<=2){y--;m+=12;}
  const A=Math.floor(y/100),B=2-A+Math.floor(A/4);
  return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;
}
const n360=(a:number)=>((a%360)+360)%360;
const toRad=(d:number)=>d*Math.PI/180;
const toDeg=(r:number)=>r*180/Math.PI;

function calcDay(y:number,m:number,d:number,loc:{lat:number;lng:number;tz:number}){
  const jd=toJD(y,m,d,6-loc.tz);
  const T=(jd-2451545)/36525;
  const L0=n360(280.46646+36000.76983*T);
  const Ms=n360(357.52911+35999.05029*T);
  const sunLon=n360(L0+(1.914602-0.004817*T)*Math.sin(toRad(Ms))+0.019993*Math.sin(2*toRad(Ms)));
  const moonL=n360(218.3164477+481267.88123421*T);
  const moonD=n360(297.8501921+445267.1114034*T);
  const moonMp=n360(134.9633964+477198.8675055*T);
  const moonF=n360(93.2720950+483202.0175233*T);
  const dL=6.288774*Math.sin(toRad(moonMp))+1.274027*Math.sin(toRad(2*moonD-moonMp))+0.658314*Math.sin(toRad(2*moonD))+0.213618*Math.sin(toRad(2*moonMp))-0.185116*Math.sin(toRad(Ms))-0.114332*Math.sin(toRad(2*moonF));
  const moonLon=n360(moonL+dL/1000);
  const ay=23.85+1.3612*T;
  const sunSid=n360(sunLon-ay), moonSid=n360(moonLon-ay);
  const elong=n360(moonLon-sunLon);
  const tithiIdx=Math.floor(elong/12)%30;
  const nakIdx=Math.floor(moonSid/(360/27))%27;
  const yogaIdx=Math.floor(n360(sunSid+moonSid)/(360/27))%27;
  const sunRashiIdx=Math.floor(sunSid/30)%12;
  const date=new Date(y,m-1,d);
  const wd=date.getDay();
  const sinDec=Math.sin(toRad(23.4393))*Math.sin(toRad(sunLon));
  const dec=Math.asin(sinDec);
  const cosHA=(Math.sin(toRad(-0.8333))-Math.sin(toRad(loc.lat))*Math.sin(dec))/(Math.cos(toRad(loc.lat))*Math.cos(dec));
  const ha=toDeg(Math.acos(Math.max(-1,Math.min(1,cosHA))));
  const noon=12-loc.lng/15;
  const srMins=(noon-ha/15)*60+loc.tz*60, ssMins=(noon+ha/15)*60+loc.tz*60;
  const dur=(ssMins-srMins)/8;
  const rahuStart=srMins+RAHU_SLOTS[wd]*dur, rahuEnd=rahuStart+dur;
  return {tithiIdx,nakIdx,yogaIdx,wd,sunRashiIdx,rahuStart,rahuEnd,paksha:tithiIdx<15?'S':'K'};
}

function scoreGP(res:{tithiIdx:number;nakIdx:number;yogaIdx:number;wd:number;sunRashiIdx:number;rahuStart:number;rahuEnd:number;paksha:string}){
  let score=0;
  const notes:string[]=[], bad:string[]=[];
  if(GP_GOOD_VARAS.includes(res.wd)){score+=3;notes.push(VARA_NAMES[res.wd]+' (good weekday)');}
  else bad.push(VARA_NAMES[res.wd]+' (avoid)');
  if(GP_GOOD_NAKS.includes(res.nakIdx)){score+=4;notes.push(NAK_NAMES[res.nakIdx]+' (good nakshatra)');}
  else if(PANCHAKA_NAKS.includes(res.nakIdx)){score-=2;bad.push('Panchaka — '+NAK_NAMES[res.nakIdx]);}
  else bad.push(NAK_NAMES[res.nakIdx]+' (not ideal)');
  if(GP_AVOID_TITHIS.includes(res.tithiIdx)){score-=3;bad.push(TITHI_NAMES[res.tithiIdx]+' Rikta tithi (avoid)');}
  else if(GP_GOOD_TITHIS.includes(res.tithiIdx)){score+=3;notes.push((res.paksha==='S'?'Shukla ':'')+TITHI_NAMES[res.tithiIdx]);}
  if(GOOD_YOGAS.includes(res.yogaIdx)){score+=2;notes.push('Auspicious yoga');}
  if(res.sunRashiIdx===8||res.sunRashiIdx===11){score-=4;bad.push('Kharmas month');}
  return {score,notes,bad};
}

function fmtMins(m:number){
  const h=Math.floor(((m/60)%24+24)%24),mn=Math.round(((m%60)+60)%60);
  return `${h%12||12}:${String(mn).padStart(2,'0')} ${h<12?'AM':'PM'}`;
}

const sel=document.getElementById('gp-city') as HTMLSelectElement;
sel.innerHTML=LOCS.map(l=>`<option value="${l.name}">${l.name}</option>`).join('');
const now=new Date();
const fromInput=document.getElementById('gp-from') as HTMLInputElement;
const toInput=document.getElementById('gp-to') as HTMLInputElement;
fromInput.value=now.toISOString().split('T')[0];
const sixMonths=new Date(now); sixMonths.setMonth(sixMonths.getMonth()+6);
toInput.value=sixMonths.toISOString().split('T')[0];

document.getElementById('gp-find')?.addEventListener('click',()=>{
  const fromStr=fromInput.value, toStr=toInput.value;
  const cityName=sel.value;
  const loc=LOCS.find(l=>l.name===cityName)||LOCS[0];
  const [fy,fm,fd]=fromStr.split('-').map(Number);
  const [ty,tm,td]=toStr.split('-').map(Number);
  const fromD=new Date(fy,fm-1,fd), toD=new Date(ty,tm-1,td);
  if(toD<=fromD||((toD.getTime()-fromD.getTime())>365*24*3600*1000)){
    alert('Please select a range up to 1 year.');return;
  }

  const results:any[]=[];
  const cur=new Date(fromD);
  while(cur<=toD){
    const y=cur.getFullYear(),m=cur.getMonth()+1,d=cur.getDate();
    const res=calcDay(y,m,d,loc);
    const {score,notes,bad}=scoreGP(res);
    if(score>=5) results.push({date:new Date(cur),score,notes,bad,res});
    cur.setDate(cur.getDate()+1);
  }
  results.sort((a,b)=>b.score-a.score);
  const top=results.slice(0,20);

  const listEl=document.getElementById('gp-list');
  const titleEl=document.getElementById('gp-results-title');
  const secEl=document.getElementById('gp-results');
  if(!listEl||!titleEl||!secEl)return;
  titleEl.textContent=`${top.length} auspicious Griha Pravesh dates found`;
  if(!top.length){
    listEl.innerHTML=`<div class="card" style="padding:20px;text-align:center;"><p style="color:var(--color-mute);">No strong dates found. Try extending the range.</p></div>`;
  } else {
    listEl.innerHTML=top.map((r,i)=>{
      const label=r.score>=9?'Excellent':r.score>=7?'Very Good':'Good';
      const lc=r.score>=9?'#15803d':r.score>=7?'#b45309':'#1d4ed8';
      const isTop=i===0;
      const tc=isTop?'#fff':'var(--color-ink)';
      const mut=isTop?'rgba(255,255,255,0.6)':'var(--color-mute)';
      return `<div class="card" style="padding:18px;${isTop?'background:var(--color-ink);':''}">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <div>
            <p style="font-size:16px;font-weight:700;color:${tc};margin:0;">${r.date.toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</p>
            <p style="font-size:11px;color:${mut};margin:3px 0 0;font-family:var(--font-mono);">${NAK_NAMES[r.res.nakIdx]} · ${TITHI_NAMES[r.res.tithiIdx]} · Score: ${r.score}/12</p>
          </div>
          <span style="font-size:11px;font-weight:700;padding:4px 12px;border-radius:100px;background:${isTop?'rgba(255,255,255,0.15)':lc+'18'};color:${isTop?'#fff':lc};border:1px solid ${isTop?'rgba(255,255,255,0.2)':lc+'44'};">${label}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:${r.bad.length?'8px':'0'};">
          ${r.notes.map((n:string)=>`<span style="font-size:10px;padding:2px 8px;border-radius:100px;background:${isTop?'rgba(255,255,255,0.15)':'var(--color-canvas-soft-2)'};color:${isTop?'rgba(255,255,255,0.85)':'var(--color-body-text)'};border:1px solid ${isTop?'rgba(255,255,255,0.2)':'var(--color-hairline)'};">✓ ${n}</span>`).join('')}
        </div>
        ${r.bad.length?`<div style="display:flex;flex-wrap:wrap;gap:6px;">
          ${r.bad.map((n:string)=>`<span style="font-size:10px;padding:2px 8px;border-radius:100px;background:#fee2e2;color:#dc2626;border:1px solid #fecaca;">✗ ${n}</span>`).join('')}
        </div>`:''}
        ${isTop?`<div style="margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.15);">
          <p style="font-size:10px;color:rgba(255,255,255,0.5);margin:0 0 2px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.05em;">Avoid Rahu Kala</p>
          <p style="font-size:12px;color:rgba(255,255,255,0.85);margin:0;">${fmtMins(r.res.rahuStart)} – ${fmtMins(r.res.rahuEnd)}</p>
        </div>`:''}
      </div>`;
    }).join('');
  }
  secEl.style.display='block';
  secEl.scrollIntoView({behavior:'smooth',block:'start'});
});
</script>
