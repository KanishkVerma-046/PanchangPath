---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Kundali Generator — Free Vedic Birth Chart — PanchangPath" description="Generate your free Vedic birth chart (Janma Kundali) with planetary positions, signs, nakshatras, Lagna and interpretations. Drik calculations, Lahiri ayanamsha.">

  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:40px 0 32px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <a href="/jyotish" style="font-size:12px;color:var(--color-mute);text-decoration:none;">← Jyotish Tools</a>
      <p class="caption-mono" style="color:var(--color-mute);margin:12px 0 8px;">जन्म कुंडली · KUNDALI GENERATOR</p>
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-1.2px;color:var(--color-ink);margin:0 0 10px;">Kundali Generator</h1>
      <p style="font-size:15px;color:var(--color-body-text);margin:0;max-width:500px;">Enter your birth details to generate a full Vedic birth chart with planetary positions, Lagna, nakshatras and key interpretations.</p>
    </div>
  </section>

  <section style="padding:28px 0 56px;">
    <div class="container">
      <!-- Form -->
      <div style="display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
        <div>
          <label class="fld-label">Name (optional)</label>
          <input type="text" id="f-name" class="input" placeholder="Your name" style="height:38px;min-width:150px;" />
        </div>
        <div>
          <label class="fld-label">Date of Birth</label>
          <input type="date" id="f-date" class="input" style="height:38px;" />
        </div>
        <div>
          <label class="fld-label">Time of Birth</label>
          <input type="time" id="f-time" class="input" style="height:38px;" />
        </div>
        <div>
          <label class="fld-label">Place of Birth</label>
          <select id="f-city" class="input" style="height:38px;min-width:150px;"></select>
        </div>
        <button id="f-calc" class="btn-primary" style="height:38px;padding:0 20px;">Generate Kundali</button>
      </div>

      <!-- Chart style selector -->
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:28px;">
        <span class="fld-label" style="margin:0;">Chart Style:</span>
        <button class="style-btn active" data-style="north">North Indian</button>
        <button class="style-btn" data-style="south">South Indian</button>
        <button class="style-btn" data-style="east">East Indian</button>
        <button class="style-btn" data-style="west">West Indian</button>
      </div>

      <div id="result" style="display:none;">
        <div style="display:grid;grid-template-columns:340px 1fr;gap:28px;align-items:start;" class="kund-layout">
          <!-- Chart -->
          <div>
            <div class="card" style="padding:20px;">
              <h2 id="chart-title" style="font-size:15px;font-weight:600;color:var(--color-ink);margin:0 0 4px;">Lagna Chart (D-1)</h2>
              <p id="chart-sub" style="font-size:12px;color:var(--color-mute);margin:0 0 14px;font-family:var(--font-mono);"></p>
              <div id="chart-box"></div>
            </div>
            <div class="card" style="padding:18px;margin-top:16px;">
              <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 10px;">Birth Summary</h3>
              <div id="summary-list" style="display:flex;flex-direction:column;gap:8px;"></div>
            </div>
          </div>

          <!-- Tables + interpretation -->
          <div>
            <div class="card" style="padding:20px;overflow-x:auto;">
              <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">Planetary Positions (Graha Sphuta)</h3>
              <table style="width:100%;border-collapse:collapse;font-size:13px;" id="planet-table"></table>
            </div>
            <div class="card" style="padding:20px;margin-top:16px;">
              <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">Key Interpretations</h3>
              <div id="interp" style="display:flex;flex-direction:column;gap:12px;"></div>
            </div>
          </div>
        </div>
      </div>

      <div id="err" style="display:none;padding:16px;background:var(--color-inauspicious-soft);border-radius:8px;color:#b91c1c;font-size:14px;"></div>

      <!-- About -->
      <div class="card" style="padding:28px;margin-top:36px;">
        <h2 style="font-size:18px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">About the Janma Kundali</h2>
        <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0 0 10px;">The Janma Kundali (birth chart) is a map of the heavens at the exact moment and place of your birth. The 12 houses (bhavas), the rashi rising on the eastern horizon (Lagna), and the placement of the nine grahas together describe your life's potential, strengths and karmic patterns.</p>
        <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0;">Choose from four regional chart styles: <b>North Indian</b> (Hindustani diamond/kite), <b>South Indian</b> (fixed-sign 4&times;4 grid used in Tamil Nadu and Karnataka), <b>East Indian</b> (Bengali 3&times;3 square), or <b>West Indian</b> (Gujarati/Marathi fixed-sign grid). All styles show the same astronomical data.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fld-label { font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em; }
  #planet-table th { text-align:left;padding:6px 8px;border-bottom:1px solid var(--color-hairline);color:var(--color-mute);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.04em; }
  #planet-table td { padding:7px 8px;border-bottom:1px solid var(--color-hairline);color:var(--color-body-text); }
  .style-btn { padding:5px 13px;border:1px solid var(--color-hairline-strong);border-radius:6px;background:var(--color-canvas);color:var(--color-body-text);cursor:pointer;font-size:12px;font-family:var(--font-mono); }
  .style-btn.active { background:var(--color-ink);color:var(--color-canvas);border-color:var(--color-ink); }
  @media (max-width: 820px) { .kund-layout { grid-template-columns: 1fr !important; } }
</style>

<script>
let currentStyle = 'north';
const LOCS=[{name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},{name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},{name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},{name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},{name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},{name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},{name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},{name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},{name:'Ahmedabad',lat:23.0225,lng:72.5714,tz:5.5},{name:'Pune',lat:18.5204,lng:73.8567,tz:5.5},{name:'Dubai',lat:25.2048,lng:55.2708,tz:4},{name:'Singapore',lat:1.3521,lng:103.8198,tz:8},{name:'New York',lat:40.7128,lng:-74.006,tz:-5},{name:'London',lat:51.5074,lng:-0.1278,tz:0},{name:'Toronto',lat:43.6532,lng:-79.3832,tz:-5}];
function toJD(y,m,d,h){h=h||0;if(m<=2){y--;m+=12;}const A=Math.floor(y/100),B=2-A+Math.floor(A/4);return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;}
const n360=a=>((a%360)+360)%360;
const toR=d=>d*Math.PI/180;
const toD=r=>r*180/Math.PI;
function ayanamsha(T){return 23.85+1.3612*T-0.000136*T*T;}
function sunLon(jd){const T=(jd-2451545)/36525;const L0=n360(280.46646+36000.76983*T+0.0003032*T*T);const M=n360(357.52911+35999.05029*T-0.0001537*T*T);const C=(1.914602-0.004817*T-0.000014*T*T)*Math.sin(toR(M))+(0.019993-0.000101*T)*Math.sin(2*toR(M))+0.000289*Math.sin(3*toR(M));return n360(L0+C);}
function moonLon(jd){const T=(jd-2451545)/36525;const Lm=n360(218.3164477+481267.88123421*T);const D=n360(297.8501921+445267.1114034*T);const M=n360(357.5291092+35999.0502909*T);const Mp=n360(134.9633964+477198.8675055*T);const F=n360(93.2720950+483202.0175233*T);const dL=6.288774*Math.sin(toR(Mp))+1.274027*Math.sin(toR(2*D-Mp))+0.658314*Math.sin(toR(2*D))+0.213618*Math.sin(toR(2*Mp))-0.185116*Math.sin(toR(M))-0.114332*Math.sin(toR(2*F));return n360(Lm+dL/1000);}
function rahuLon(jd){const T=(jd-2451545)/36525;return n360(125.04452-1934.136261*T+0.0020708*T*T);}
function solveKepler(M,e){let E=M;for(let k=0;k<50;k++){const dE=(M-E+e*Math.sin(E))/(1-e*Math.cos(E));E+=dE;if(Math.abs(dE)<1e-10)break;}return E;}
const ORB={mercury:{L:252.250906,Ld:149472.6746358,wp:77.456119,wpd:0.1588643,Om:48.330893,Omd:-0.1254229,i:7.004979,id:-0.005952,e:0.20563069,ed:0.00002527,a:0.38709831},venus:{L:181.979801,Ld:58517.815676,wp:131.563707,wpd:0.0036096,Om:76.67992,Omd:-0.278008,i:3.394662,id:-0.000857,e:0.00677323,ed:-0.00004938,a:0.72332102},earth:{L:100.464457,Ld:36000.7698278,wp:102.937348,wpd:0.3225557,Om:174.873174,Omd:-0.2410908,i:0,id:0.013055,e:0.01671022,ed:-0.00003804,a:1.00000018},mars:{L:355.432818,Ld:19140.2993313,wp:336.040768,wpd:0.4439016,Om:49.558093,Omd:-0.295025,i:1.849726,id:-0.008148,e:0.09341233,ed:0.00011902,a:1.52371243},jupiter:{L:34.351484,Ld:3034.9056746,wp:14.331309,wpd:0.2155402,Om:100.464441,Omd:0.1350208,i:1.30327,id:-0.001987,e:0.04839266,ed:-0.0001288,a:5.20248019},saturn:{L:50.077444,Ld:1222.1137943,wp:93.056787,wpd:0.5691095,Om:113.665524,Omd:-0.2566722,i:2.488878,id:0.002552,e:0.0541506,ed:-0.00036762,a:9.54149883}};
function helioXY(el,T){const e=el.e+el.ed*T;const wp=n360(el.wp+el.wpd*T);const Om=n360(el.Om+el.Omd*T);const inc=el.i+el.id*T;const L=n360(el.L+el.Ld*T);const M=toR(n360(L-wp));const w=toR(n360(wp-Om));const Omega=toR(Om);const iR=toR(inc);const E=solveKepler(M,e);const nu=2*Math.atan2(Math.sqrt(1+e)*Math.sin(E/2),Math.sqrt(1-e)*Math.cos(E/2));const r=el.a*(1-e*Math.cos(E));const arg=nu+w;const x=r*(Math.cos(Omega)*Math.cos(arg)-Math.sin(Omega)*Math.sin(arg)*Math.cos(iR));const y=r*(Math.sin(Omega)*Math.cos(arg)+Math.cos(Omega)*Math.sin(arg)*Math.cos(iR));return[x,y];}
function allLons(jd){const T=(jd-2451545)/36525;const ay=ayanamsha(T);const[xE,yE]=helioXY(ORB.earth,T);const geo=k=>{const[xP,yP]=helioXY(ORB[k],T);return n360(toD(Math.atan2(yP-yE,xP-xE)));};const rahu=rahuLon(jd);return{surya:sunLon(jd),chandra:moonLon(jd),mangal:geo('mars'),budha:geo('mercury'),guru:geo('jupiter'),shukra:geo('venus'),shani:geo('saturn'),rahu,ketu:n360(rahu+180),ay};}
function calcLagna(jd,lat,lng){const T=(jd-2451545)/36525;const eps=23.439291111-0.013004167*T;const GMST=n360(280.46061837+360.98564736629*(jd-2451545)+0.000387933*T*T);const RAMC=toR(n360(GMST+lng));const e=toR(eps),phi=toR(lat);const tanA=-Math.cos(RAMC)/(Math.sin(e)*Math.tan(phi)+Math.cos(e)*Math.sin(RAMC));let A=toD(Math.atan(tanA));if(Math.cos(RAMC)>0)A+=180;return n360(A);}

const RASHI=['Mesha','Vrishabha','Mithuna','Karka','Simha','Kanya','Tula','Vrishchika','Dhanu','Makara','Kumbha','Meena'];
const RASHI_EN=['Aries','Taurus','Gemini','Cancer','Leo','Virgo','Libra','Scorpio','Sagittarius','Capricorn','Aquarius','Pisces'];
const RASHI_LORD=['Mars','Venus','Mercury','Moon','Sun','Mercury','Venus','Mars','Jupiter','Saturn','Saturn','Jupiter'];
const NAKS=['Ashwini','Bharani','Krittika','Rohini','Mrigashira','Ardra','Punarvasu','Pushya','Ashlesha','Magha','Purva Phalguni','Uttara Phalguni','Hasta','Chitra','Swati','Vishakha','Anuradha','Jyeshtha','Mula','Purva Ashadha','Uttara Ashadha','Shravana','Dhanishtha','Shatabhisha','Purva Bhadrapada','Uttara Bhadrapada','Revati'];
const PLANETS=[['surya','Sun','Su'],['chandra','Moon','Mo'],['mangal','Mars','Ma'],['budha','Mercury','Me'],['guru','Jupiter','Ju'],['shukra','Venus','Ve'],['shani','Saturn','Sa'],['rahu','Rahu','Ra'],['ketu','Ketu','Ke']];
function fmtDMS(lon){const d=lon%30;const deg=Math.floor(d);const mn=Math.floor((d-deg)*60);return deg+'\xb0'+String(mn).padStart(2,'0')+"'";}
function nakInfo(sid){const idx=Math.floor(sid/(360/27));const pada=Math.floor((sid%(360/27))/((360/27)/4))+1;return{name:NAKS[idx],pada};}

// ── North Indian chart (diamond/kite) ──
function drawNorthChart(signOfHouse,planetsByHouse){
  const S=320;
  const f=[[0.5,0.25],[0.25,0.12],[0.12,0.25],[0.25,0.5],[0.12,0.75],[0.25,0.88],[0.5,0.75],[0.75,0.88],[0.88,0.75],[0.75,0.5],[0.88,0.25],[0.75,0.12]];
  let lines=`<line x1="0" y1="0" x2="${S}" y2="${S}"/><line x1="${S}" y1="0" x2="0" y2="${S}"/><polygon points="${S/2},0 ${S},${S/2} ${S/2},${S} 0,${S/2}" fill="none"/>`;
  let txt='';
  for(let h=0;h<12;h++){
    const cx=f[h][0]*S,cy=f[h][1]*S;
    txt+=`<text x="${cx}" y="${cy-18}" text-anchor="middle" font-size="10" fill="var(--color-mute)" font-family="var(--font-mono)">${signOfHouse[h]+1}</text>`;
    const pls=planetsByHouse[h]||[];
    pls.forEach((p,i)=>{const perRow=3;const col=i%perRow;const row=Math.floor(i/perRow);const px=cx+(col-(Math.min(pls.length,perRow)-1)/2)*22;const py=cy+row*14;txt+=`<text x="${px}" y="${py}" text-anchor="middle" font-size="11" font-weight="600" fill="${p==='As'?'var(--color-saffron-deep)':'var(--color-ink)'}">${p}</text>`;});
  }
  return `<svg viewBox="-2 -2 ${S+4} ${S+4}" width="100%" style="max-width:320px;stroke:var(--color-hairline-strong);stroke-width:1;"><rect x="0" y="0" width="${S}" height="${S}" fill="var(--color-canvas-soft)"/>${lines}${txt}</svg>`;
}

// ── South Indian chart (fixed-sign 4×4 grid) ──
// Signs fixed clockwise: Pisces top-left → Aries → ... → Aquarius left
const SOUTH_SIGN=[[11,0,1,2],[10,-1,-1,3],[9,-1,-1,4],[8,7,6,5]];
function drawSouthChart(planetsBySign,lagnaSign){
  const C=80,S=C*4;
  let svg=`<svg viewBox="0 0 ${S} ${S}" width="100%" style="max-width:320px;">`;
  svg+=`<rect x="${C}" y="${C}" width="${2*C}" height="${2*C}" fill="var(--color-canvas)" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
  svg+=`<text x="${C+C}" y="${C+C}" text-anchor="middle" dominant-baseline="middle" font-size="30" fill="var(--color-hairline)">&#x1F549;</text>`;
  for(let r=0;r<4;r++){for(let c=0;c<4;c++){
    const s=SOUTH_SIGN[r][c];if(s===-1)continue;
    const x=c*C,y=r*C,isL=s===lagnaSign;
    svg+=`<rect x="${x}" y="${y}" width="${C}" height="${C}" fill="${isL?'rgba(220,130,50,0.08)':'var(--color-canvas-soft)'}" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
    svg+=`<text x="${x+4}" y="${y+12}" font-size="9" fill="var(--color-mute)" font-family="var(--font-mono)">${s+1}</text>`;
    if(isL){svg+=`<line x1="${x}" y1="${y}" x2="${x+22}" y2="${y}" stroke="var(--color-saffron-deep)" stroke-width="2.5"/><line x1="${x}" y1="${y}" x2="${x}" y2="${y+22}" stroke="var(--color-saffron-deep)" stroke-width="2.5"/>`;}
    const plts=planetsBySign[s]||[];
    plts.forEach((p,i)=>{svg+=`<text x="${x+5+(i%3)*24}" y="${y+28+Math.floor(i/3)*14}" font-size="11" font-weight="600" fill="${p==='As'?'var(--color-saffron-deep)':'var(--color-ink)'}">${p}</text>`;});
  }}
  svg+='</svg>';return svg;
}

// ── East Indian chart (Bengali 3×3 grid, Lagna top-centre) ──
// Corner cells hold 2 houses each; edge cells hold 1; centre = Om
const EAST_CELLS=[[[10,11],[0],[1,2]],[[9],null,[3]],[[8,7],[6],[5,4]]];
function drawEastChart(signOfHouse,planetsByHouse){
  const C=100,S=300;
  let svg=`<svg viewBox="0 0 ${S} ${S}" width="100%" style="max-width:300px;">`;
  svg+=`<rect x="${C}" y="${C}" width="${C}" height="${C}" fill="var(--color-canvas)" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
  svg+=`<text x="${C+C/2}" y="${C+C/2}" text-anchor="middle" dominant-baseline="middle" font-size="26" fill="var(--color-hairline)">&#x1F549;</text>`;
  for(let r=0;r<3;r++){for(let c=0;c<3;c++){
    if(r===1&&c===1)continue;
    const houses=EAST_CELLS[r][c];
    const x=c*C,y=r*C,isLagna=houses.includes(0);
    svg+=`<rect x="${x}" y="${y}" width="${C}" height="${C}" fill="${isLagna?'rgba(220,130,50,0.08)':'var(--color-canvas-soft)'}" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
    svg+=`<text x="${x+4}" y="${y+12}" font-size="9" fill="var(--color-mute)" font-family="var(--font-mono)">${houses.map(h=>h+1).join(',')}</text>`;
    if(isLagna){svg+=`<text x="${x+C-4}" y="${y+12}" text-anchor="end" font-size="9" fill="var(--color-saffron-deep)">As</text>`;}
    let allP=[];houses.forEach(h=>{allP=allP.concat(planetsByHouse[h]||[]);});
    allP.forEach((p,i)=>{svg+=`<text x="${x+6+(i%3)*28}" y="${y+32+Math.floor(i/3)*14}" font-size="11" font-weight="600" fill="${p==='As'?'var(--color-saffron-deep)':'var(--color-ink)'}">${p}</text>`;});
  }}
  svg+='</svg>';return svg;
}

// ── West Indian chart (Gujarati/Marathi — fixed-sign like South but signs run anti-clockwise) ──
// Top row L→R: Aries Taurus Gemini Cancer; left col T→B: Pisces Aquarius Capricorn; etc.
const WEST_SIGN=[[0,1,2,3],[11,-1,-1,4],[10,-1,-1,5],[9,8,7,6]];
function drawWestChart(planetsBySign,lagnaSign){
  const C=80,S=C*4;
  let svg=`<svg viewBox="0 0 ${S} ${S}" width="100%" style="max-width:320px;">`;
  svg+=`<rect x="${C}" y="${C}" width="${2*C}" height="${2*C}" fill="var(--color-canvas)" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
  svg+=`<text x="${C+C}" y="${C+C}" text-anchor="middle" dominant-baseline="middle" font-size="30" fill="var(--color-hairline)">&#x1F549;</text>`;
  for(let r=0;r<4;r++){for(let c=0;c<4;c++){
    const s=WEST_SIGN[r][c];if(s===-1)continue;
    const x=c*C,y=r*C,isL=s===lagnaSign;
    svg+=`<rect x="${x}" y="${y}" width="${C}" height="${C}" fill="${isL?'rgba(220,130,50,0.08)':'var(--color-canvas-soft)'}" stroke="var(--color-hairline-strong)" stroke-width="1.5"/>`;
    svg+=`<text x="${x+4}" y="${y+12}" font-size="9" fill="var(--color-mute)" font-family="var(--font-mono)">${s+1}</text>`;
    if(isL){svg+=`<line x1="${x}" y1="${y}" x2="${x+22}" y2="${y}" stroke="var(--color-saffron-deep)" stroke-width="2.5"/><line x1="${x}" y1="${y}" x2="${x}" y2="${y+22}" stroke="var(--color-saffron-deep)" stroke-width="2.5"/>`;}
    const plts=planetsBySign[s]||[];
    plts.forEach((p,i)=>{svg+=`<text x="${x+5+(i%3)*24}" y="${y+28+Math.floor(i/3)*14}" font-size="11" font-weight="600" fill="${p==='As'?'var(--color-saffron-deep)':'var(--color-ink)'}">${p}</text>`;});
  }}
  svg+='</svg>';return svg;
}

// Style selector wiring
document.querySelectorAll('.style-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    currentStyle=btn.dataset.style;
    document.querySelectorAll('.style-btn').forEach(b=>b.classList.toggle('active',b===btn));
    if(window._lastCalc)redrawChart();
  });
});

function redrawChart(){
  const{signOfHouse,planetsByHouse,planetsBySign,lagnaSign}=window._lastCalc;
  let html;
  if(currentStyle==='north')html=drawNorthChart(signOfHouse,planetsByHouse);
  else if(currentStyle==='south')html=drawSouthChart(planetsBySign,lagnaSign);
  else if(currentStyle==='east')html=drawEastChart(signOfHouse,planetsByHouse);
  else html=drawWestChart(planetsBySign,lagnaSign);
  document.getElementById('chart-box').innerHTML=html;
}

const citySel=document.getElementById('f-city');
citySel.innerHTML=LOCS.map(l=>`<option value="${l.name}">${l.name}</option>`).join('');
const today=new Date();
document.getElementById('f-date').value=today.toISOString().split('T')[0];
document.getElementById('f-time').value='12:00';

function calculate(){
  try{
    const dateStr=document.getElementById('f-date').value;
    const timeStr=document.getElementById('f-time').value||'12:00';
    const cityName=document.getElementById('f-city').value;
    const name=document.getElementById('f-name').value.trim();
    const loc=LOCS.find(l=>l.name===cityName)||LOCS[0];
    const[y,m,d]=dateStr.split('-').map(Number);
    const[hh,mm]=timeStr.split(':').map(Number);
    const jd=toJD(y,m,d,(hh+mm/60)-loc.tz);
    const L=allLons(jd);const ay=L.ay;
    const Lp=allLons(jd+1);
    const sid={};PLANETS.forEach(([k])=>sid[k]=n360(L[k]-ay));
    const lagnaTrop=calcLagna(jd,loc.lat,loc.lng);
    const lagna=n360(lagnaTrop-ay);
    const lagnaSign=Math.floor(lagna/30);

    const signOfHouse=[];for(let h=0;h<12;h++)signOfHouse[h]=(lagnaSign+h)%12;
    const planetsByHouse={};for(let h=0;h<12;h++)planetsByHouse[h]=[];
    const planetsBySign={};for(let s=0;s<12;s++)planetsBySign[s]=[];
    planetsByHouse[0].push('As');
    planetsBySign[lagnaSign].push('As');
    PLANETS.forEach(([k,,abbr])=>{
      const sign=Math.floor(sid[k]/30);
      const house=((sign-lagnaSign)+12)%12;
      planetsByHouse[house].push(abbr);
      planetsBySign[sign].push(abbr);
    });

    window._lastCalc={signOfHouse,planetsByHouse,planetsBySign,lagnaSign};
    redrawChart();

    document.getElementById('chart-title').textContent=(name?name+"'s ":'')+'Lagna Chart (D-1)';
    document.getElementById('chart-sub').textContent=RASHI[lagnaSign]+' Lagna \xb7 '+dateStr+' '+timeStr+' \xb7 '+cityName;

    const moonSign=Math.floor(sid.chandra/30);
    const sunSign=Math.floor(sid.surya/30);
    const moonNak=nakInfo(sid.chandra);
    document.getElementById('summary-list').innerHTML=[
      ['Lagna (Asc)',RASHI[lagnaSign]+' ('+RASHI_EN[lagnaSign]+')'],
      ['Lagna Lord',RASHI_LORD[lagnaSign]],
      ['Moon Rashi',RASHI[moonSign]+' ('+RASHI_EN[moonSign]+')'],
      ['Sun Rashi',RASHI[sunSign]+' ('+RASHI_EN[sunSign]+')'],
      ['Nakshatra',moonNak.name+' (Pada '+moonNak.pada+')'],
      ['Ayanamsha',ay.toFixed(3)+'\xb0 Lahiri'],
    ].map(r=>`<div style="display:flex;justify-content:space-between;gap:10px;font-size:12.5px;"><span style="color:var(--color-mute);">${r[0]}</span><span style="color:var(--color-ink);font-weight:600;text-align:right;">${r[1]}</span></div>`).join('');

    let rows='<tr><th>Graha</th><th>Rashi</th><th>Degree</th><th>Nakshatra</th><th>Pada</th><th>Motion</th></tr>';
    let akName='',akDeg=-1;
    PLANETS.forEach(([k,full])=>{
      const s=sid[k];const sign=Math.floor(s/30);const nk=nakInfo(s);
      let motion='Margi';
      if(k==='rahu'||k==='ketu')motion='Vakri';
      else if(k!=='surya'&&k!=='chandra'){const cur=n360(L[k]-ay);const nxt=n360(Lp[k]-Lp.ay);let diff=nxt-cur;if(diff>180)diff-=360;if(diff<-180)diff+=360;motion=diff<0?'Vakri':'Margi';}
      let degInSign=s%30;if(k==='rahu')degInSign=30-(s%30);
      if(k!=='ketu'&&degInSign>akDeg){akDeg=degInSign;akName=full;}
      rows+=`<tr><td style="color:var(--color-ink);font-weight:600;">${full}</td><td>${RASHI[sign]}</td><td style="font-family:var(--font-mono);">${fmtDMS(s)}</td><td>${nk.name}</td><td>${nk.pada}</td><td style="color:${motion==='Vakri'?'#dc2626':'var(--color-body-text)'};">${motion}</td></tr>`;
    });
    document.getElementById('planet-table').innerHTML=rows;

    document.getElementById('interp').innerHTML=[
      ['Lagna (Ascendant)','Your rising sign is <b>'+RASHI[lagnaSign]+' ('+RASHI_EN[lagnaSign]+')</b>, ruled by '+RASHI_LORD[lagnaSign]+'. The Lagna shapes your physical body, temperament and how others first perceive you.'],
      ['Moon Sign (Rashi)','Your Moon is in <b>'+RASHI[moonSign]+' ('+RASHI_EN[moonSign]+')</b> in '+moonNak.name+' nakshatra. This is your emotional core and the rashi used for daily Rashifal and most muhurta decisions.'],
      ['Sun Sign','Your Sun is in <b>'+RASHI[sunSign]+' ('+RASHI_EN[sunSign]+')</b>, representing your soul, vitality, ego and your relationship with authority and the father.'],
      ['Atmakaraka','<b>'+akName+'</b> holds the highest degree in its sign and is your Atmakaraka — the soul planet of the Jaimini system, signifying your deepest desires and the main lesson of this lifetime.'],
    ].map(i=>`<div><p style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 3px;">${i[0]}</p><p style="font-size:13px;color:var(--color-body-text);line-height:1.6;margin:0;">${i[1]}</p></div>`).join('');

    document.getElementById('result').style.display='block';
    document.getElementById('err').style.display='none';
  }catch(e){
    const er=document.getElementById('err');er.style.display='block';er.textContent='Could not generate chart: '+e.message;
    document.getElementById('result').style.display='none';
  }
}
document.getElementById('f-calc').addEventListener('click',calculate);
calculate();
</script>
