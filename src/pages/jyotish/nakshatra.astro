---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nakshatra Calculator — Find Your Birth Star — PanchangPath" description="Find your Janma Nakshatra (birth star) and pada from birth details. Includes lord, gana, nadi, yoni, deity, symbol and name syllables.">

  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:40px 0 32px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <a href="/jyotish" style="font-size:12px;color:var(--color-mute);text-decoration:none;">← Jyotish Tools</a>
      <p class="caption-mono" style="color:var(--color-mute);margin:12px 0 8px;">नक्षत्र · NAKSHATRA CALCULATOR</p>
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-1.2px;color:var(--color-ink);margin:0 0 10px;">Nakshatra (Birth Star) Calculator</h1>
      <p style="font-size:15px;color:var(--color-body-text);margin:0;max-width:500px;">The 27 nakshatras are the lunar mansions of Vedic astrology. Your Janma Nakshatra is where the Moon sat at birth — central to your personality, naming and muhurta.</p>
    </div>
  </section>

  <section style="padding:28px 0 56px;">
    <div class="container">
      <div style="display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-bottom:32px;">
        <div><label class="fld-label">Date of Birth</label><input type="date" id="f-date" class="input" style="height:38px;" /></div>
        <div><label class="fld-label">Time of Birth</label><input type="time" id="f-time" class="input" style="height:38px;" /></div>
        <div><label class="fld-label">Place</label><select id="f-city" class="input" style="height:38px;min-width:150px;"></select></div>
        <button id="f-calc" class="btn-primary" style="height:38px;padding:0 20px;">Calculate</button>
      </div>

      <div id="result" style="display:none;margin-bottom:36px;">
        <div class="card" style="padding:28px;margin-bottom:24px;background:linear-gradient(135deg,var(--color-canvas) 60%,var(--color-saffron-soft));">
          <p class="caption-mono" style="color:var(--color-saffron-deep);margin:0 0 4px;">YOUR BIRTH STAR</p>
          <h2 id="n-name" style="font-size:28px;font-weight:700;color:var(--color-ink);margin:0 0 4px;"></h2>
          <p id="n-meta" style="font-size:14px;color:var(--color-mute);margin:0 0 8px;"></p>
          <div id="n-badges" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;" class="two-col">
          <div class="card" style="padding:20px;">
            <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">Attributes</h3>
            <div id="attr-list" style="display:flex;flex-direction:column;gap:9px;"></div>
          </div>
          <div class="card" style="padding:20px;">
            <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">The Four Padas</h3>
            <div id="pada-list" style="display:flex;flex-direction:column;gap:8px;"></div>
            <p style="font-size:11.5px;color:var(--color-mute);margin:12px 0 0;line-height:1.5;">Traditionally, a baby\'s name begins with the syllable of the pada in which the Moon falls.</p>
          </div>
        </div>
        <!-- Personality traits panel -->
        <div class="card" style="padding:24px;">
          <p class="caption-mono" style="color:var(--color-saffron-deep);margin:0 0 4px;">NAKSHATRA PERSONALITY TRAITS</p>
          <h3 id="trait-title" style="font-size:17px;font-weight:700;color:var(--color-ink);margin:0 0 10px;"></h3>
          <p id="trait-text" style="font-size:14px;color:var(--color-body-text);line-height:1.75;margin:0;"></p>
        </div>
      </div>
      <div id="err" style="display:none;padding:16px;background:var(--color-inauspicious-soft);border-radius:8px;color:#b91c1c;font-size:14px;margin-bottom:24px;"></div>

      <h3 style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 14px;">All 27 Nakshatras</h3>
      <div id="all-naks" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:36px;"></div>

      <div class="card" style="padding:28px;">
        <h2 style="font-size:18px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">About Nakshatras</h2>
        <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0;">The ecliptic is divided into 27 nakshatras of 13°20\' each, every one further split into 4 padas of 3°20\'. Each nakshatra has a ruling planet (used for Vimshottari Dasha), a deity, an animal (yoni), a gana (temperament), and a nadi (constitution) — all of which inform compatibility matching, naming and electional astrology.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fld-label { font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em; }
  #attr-list .dl-row { display:flex;justify-content:space-between;gap:10px;font-size:13px; }
  #attr-list .dl-row span:first-child { color:var(--color-mute); }
  #attr-list .dl-row span:last-child { color:var(--color-ink);font-weight:600;text-align:right; }
  @media (max-width:640px){ .two-col{ grid-template-columns:1fr !important; } }
</style>

<script>
const LOCS=[{name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},{name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},{name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},{name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},{name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},{name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},{name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},{name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},{name:'Ahmedabad',lat:23.0225,lng:72.5714,tz:5.5},{name:'Pune',lat:18.5204,lng:73.8567,tz:5.5},{name:'Dubai',lat:25.2048,lng:55.2708,tz:4},{name:'Singapore',lat:1.3521,lng:103.8198,tz:8},{name:'New York',lat:40.7128,lng:-74.006,tz:-5},{name:'London',lat:51.5074,lng:-0.1278,tz:0},{name:'Toronto',lat:43.6532,lng:-79.3832,tz:-5}];
function toJD(y,m,d,h){h=h||0;if(m<=2){y--;m+=12;}const A=Math.floor(y/100),B=2-A+Math.floor(A/4);return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;}
const n360=a=>((a%360)+360)%360;
const toR=d=>d*Math.PI/180;
function ayanamsha(T){return 23.85+1.3612*T-0.000136*T*T;}
function moonLon(jd){const T=(jd-2451545)/36525;const Lm=n360(218.3164477+481267.88123421*T);const D=n360(297.8501921+445267.1114034*T);const M=n360(357.5291092+35999.0502909*T);const Mp=n360(134.9633964+477198.8675055*T);const F=n360(93.2720950+483202.0175233*T);const dL=6.288774*Math.sin(toR(Mp))+1.274027*Math.sin(toR(2*D-Mp))+0.658314*Math.sin(toR(2*D))+0.213618*Math.sin(toR(2*Mp))-0.185116*Math.sin(toR(M))-0.114332*Math.sin(toR(2*F));return n360(Lm+dL/1000);}

const NAKS=[
{n:'Ashwini',h:'अश्विनी',lord:'Ketu',yoni:'Horse',gana:'Deva',nadi:'Adi',varna:'Vaishya',deity:'Ashwini Kumaras',sym:'Horse head',p:['Chu','Che','Cho','La'],traits:'Quick-minded and energetically pioneering, you start projects with great enthusiasm and possess natural healing instincts. Impatience can undermine follow-through, but your courage and spontaneity make you a natural trailblazer and leader.'},
{n:'Bharani',h:'भरणी',lord:'Venus',yoni:'Elephant',gana:'Manushya',nadi:'Madhya',varna:'Mleccha',deity:'Yama',sym:'Yoni',p:['Li','Lu','Le','Lo'],traits:'Intense, creative and deeply responsible, you carry great burdens with strength and purpose. Passionate and fiercely determined, you are drawn to life\'s extremes — beauty, art and deep transformation. Truth matters to you above all.'},
{n:'Krittika',h:'कृत्तिका',lord:'Sun',yoni:'Sheep',gana:'Rakshasa',nadi:'Antya',varna:'Brahmin',deity:'Agni',sym:'Razor/Flame',p:['A','I','U','E'],traits:'Sharp-minded, ambitious and highly critical, you burn away the impure and demand excellence from yourself and others. Your fiery clarity can be uncompromising, but it is also your greatest strength — cutting through illusion to find truth.'},
{n:'Rohini',h:'रोहिणी',lord:'Moon',yoni:'Serpent',gana:'Manushya',nadi:'Antya',varna:'Shudra',deity:'Brahma',sym:'Ox cart',p:['O','Va','Vi','Vu'],traits:'Charming, artistic and deeply sensual, you have a natural magnetism and love of beauty, fertility and comfort. Highly creative and pleasure-loving, you may become possessive of what you cherish. Stability and aesthetic richness are your life\'s rewards.'},
{n:'Mrigashira',h:'मृगशिरा',lord:'Mars',yoni:'Serpent',gana:'Deva',nadi:'Madhya',varna:'Vaishya',deity:'Soma',sym:'Deer head',p:['Ve','Vo','Ka','Ki'],traits:'Eternally curious and gently searching, you are a seeker of the ideal — in love, knowledge and beauty. Sensitive, communicative and restless, you bring fresh perspectives and creative insight wherever you go.'},
{n:'Ardra',h:'आर्द्रा',lord:'Rahu',yoni:'Dog',gana:'Manushya',nadi:'Adi',varna:'Mleccha',deity:'Rudra',sym:'Teardrop',p:['Ku','Gha','Ing','Ja'],traits:'Intense and transformative, you possess a sharp and penetrating intellect capable of thriving through storms of change. Your life may include dramatic disruptions, but each one deepens your insight. Raw, honest and unafraid of the dark.'},
{n:'Punarvasu',h:'पुनर्वसु',lord:'Jupiter',yoni:'Cat',gana:'Deva',nadi:'Adi',varna:'Brahmin',deity:'Aditi',sym:'Quiver',p:['Ke','Ko','Ha','Hi'],traits:'Optimistic, philosophical and gifted with renewal, you bounce back from difficulties with inspiring resilience. Generous, expansive and freedom-loving, you are happiest when learning, growing and sharing wisdom with others.'},
{n:'Pushya',h:'पुष्य',lord:'Saturn',yoni:'Sheep',gana:'Deva',nadi:'Madhya',varna:'Kshatriya',deity:'Brihaspati',sym:'Lotus',p:['Hu','He','Ho','Da'],traits:'Nurturing, devoted and deeply traditional, you are a natural caretaker who brings stability, prosperity and spiritual warmth to those around you. Patient and principled, your inner strength grows steadily over time.'},
{n:'Ashlesha',h:'अश्लेषा',lord:'Mercury',yoni:'Cat',gana:'Rakshasa',nadi:'Antya',varna:'Mleccha',deity:'Nagas',sym:'Coiled serpent',p:['Di','Du','De','Do'],traits:'Shrewd, perceptive and emotionally complex, you possess great strategic intelligence and a powerful ability to read people. Persuasive and resilient, you can be secretive, but your determination and psychological depth are formidable gifts.'},
{n:'Magha',h:'मघा',lord:'Ketu',yoni:'Rat',gana:'Rakshasa',nadi:'Antya',varna:'Shudra',deity:'Pitris',sym:'Throne',p:['Ma','Mi','Mu','Me'],traits:'Proud, regal and rooted in ancestral tradition, you are a natural leader with a strong sense of lineage and dignity. Generous and commanding, you thrive in positions of authority and honour the past as a foundation for greatness.'},
{n:'Purva Phalguni',h:'पूर्व फाल्गुनी',lord:'Venus',yoni:'Rat',gana:'Manushya',nadi:'Madhya',varna:'Brahmin',deity:'Bhaga',sym:'Bed front',p:['Mo','Ta','Ti','Tu'],traits:'Creative, romantic and pleasure-loving, you radiate natural charisma and a love of luxury, beauty and sensory experience. Generous in love and friendship, you are a devoted partner and gifted artist who thrives in rest and celebration.'},
{n:'Uttara Phalguni',h:'उत्तर फाल्गुनी',lord:'Sun',yoni:'Cow',gana:'Manushya',nadi:'Antya',varna:'Kshatriya',deity:'Aryaman',sym:'Bed back',p:['Te','To','Pa','Pi'],traits:'Reliable, helpful and ethically disciplined, you are the steady, dependable pillar others lean on. Balancing creativity with service, you seek long-term relationships and commitments built on mutual respect and shared values.'},
{n:'Hasta',h:'हस्त',lord:'Moon',yoni:'Buffalo',gana:'Deva',nadi:'Adi',varna:'Vaishya',deity:'Savitar',sym:'Hand',p:['Pu','Sha','Na','Tha'],traits:'Clever, resourceful and exceptionally skilled with your hands, you are a master of craft, humour and practical intelligence. Sharp-witted and adaptable, you manifest your intentions quickly and have a gift for healing and service.'},
{n:'Chitra',h:'चित्रा',lord:'Mars',yoni:'Tiger',gana:'Rakshasa',nadi:'Madhya',varna:'Kshatriya',deity:'Vishwakarma',sym:'Bright jewel',p:['Pe','Po','Ra','Ri'],traits:'Artistic, glamorous and technically brilliant, you have an extraordinary aesthetic sensibility and a relentless drive for perfection. Innovative, visually gifted and detail-oriented, you build beautiful things with precision and passion.'},
{n:'Swati',h:'स्वाती',lord:'Rahu',yoni:'Buffalo',gana:'Deva',nadi:'Adi',varna:'Mleccha',deity:'Vayu',sym:'Coral',p:['Ru','Re','Ro','Ta'],traits:'Independent, diplomatic and fair-minded like the wind, you bend without breaking and excel in commerce, networking and mediation. Self-motivated and socially skilled, you value personal freedom and bring balance wherever you go.'},
{n:'Vishakha',h:'विशाखा',lord:'Jupiter',yoni:'Tiger',gana:'Rakshasa',nadi:'Madhya',varna:'Brahmin',deity:'Indra-Agni',sym:'Gateway',p:['Ti','Tu','Te','To'],traits:'Goal-oriented, ambitious and fiercely competitive, you are a driven achiever who stays focused until every aim is fulfilled. Patient and persistent beneath your intensity, you have great power to transform society through principled leadership.'},
{n:'Anuradha',h:'अनुराधा',lord:'Saturn',yoni:'Deer',gana:'Deva',nadi:'Adi',varna:'Kshatriya',deity:'Mitra',sym:'Lotus',p:['Na','Ni','Nu','Ne'],traits:'Devoted, organized and resilient, you excel at building lasting friendships and sustaining organisations. Spiritually inclined and adaptable, you thrive through adversity and your quiet loyalty inspires deep bonds of trust in all relationships.'},
{n:'Jyeshtha',h:'ज्येष्ठा',lord:'Mercury',yoni:'Deer',gana:'Rakshasa',nadi:'Madhya',varna:'Brahmin',deity:'Indra',sym:'Amulet',p:['No','Ya','Yi','Yu'],traits:'Senior, protective and intensely responsible, you carry a deep sense of duty toward those in your care. Proud and courageous, with a fierce loyalty that demands respect. Jealousy and control are the shadows you are here to master.'},
{n:'Mula',h:'मूल',lord:'Ketu',yoni:'Dog',gana:'Rakshasa',nadi:'Antya',varna:'Mleccha',deity:'Nirriti',sym:'Tied roots',p:['Ye','Yo','Bha','Bhi'],traits:'Philosophical, investigative and unafraid to uproot the old, you dive to the root of everything. A truth-seeker who questions foundations and transforms through destruction. Freedom, inquiry and spiritual liberation are your deepest drives.'},
{n:'Purva Ashadha',h:'पूर्वाषाढा',lord:'Venus',yoni:'Monkey',gana:'Manushya',nadi:'Adi',varna:'Brahmin',deity:'Apas',sym:'Fan',p:['Bhu','Dha','Bha','Pha'],traits:'Optimistic, proud and powerfully persuasive, you have a magnetic drive and an unshakeable belief in your path. Resilient under opposition and gifted with natural leadership, you inspire others through your vision and spirited determination.'},
{n:'Uttara Ashadha',h:'उत्तराषाढा',lord:'Sun',yoni:'Mongoose',gana:'Manushya',nadi:'Madhya',varna:'Kshatriya',deity:'Vishvadevas',sym:'Planks',p:['Bhe','Bho','Ja','Ji'],traits:'Ethical, determined and universally principled, you move slowly but surely toward lofty, lasting goals. An enduring leader with a broad perspective and deep integrity — your victories, once won, are never easily reversed.'},
{n:'Shravana',h:'श्रवण',lord:'Moon',yoni:'Monkey',gana:'Deva',nadi:'Antya',varna:'Mleccha',deity:'Vishnu',sym:'Three footprints',p:['Khi','Khu','Khe','Kho'],traits:'An exceptional listener and lifelong learner, you have an organized mind, wide knowledge and a deep connection to the spoken and sacred word. Social, empathetic and skilled in communication, you preserve and transmit wisdom across generations.'},
{n:'Dhanishtha',h:'धनिष्ठा',lord:'Mars',yoni:'Lion',gana:'Rakshasa',nadi:'Madhya',varna:'Shudra',deity:'Vasus',sym:'Drum',p:['Ga','Gi','Gu','Ge'],traits:'Musical, courageous and powerfully ambitious, you have natural rhythm, group leadership and the drive to accumulate wealth. Generous by nature but career-focused, you may at times prioritise achievement over intimate relationships.'},
{n:'Shatabhisha',h:'शतभिषा',lord:'Rahu',yoni:'Horse',gana:'Rakshasa',nadi:'Adi',varna:'Mleccha',deity:'Varuna',sym:'Empty circle',p:['Go','Sa','Si','Su'],traits:'Independent, scientific and deeply philosophical, you are drawn to healing, hidden knowledge and the mysteries of the cosmos. Introspective and secretive, you carry strong humanitarian ideals and work best when given complete creative freedom.'},
{n:'Purva Bhadrapada',h:'पूर्वभाद्रपदा',lord:'Jupiter',yoni:'Lion',gana:'Manushya',nadi:'Madhya',varna:'Brahmin',deity:'Aja Ekapada',sym:'Funeral cot front',p:['Se','So','Da','Di'],traits:'Intense, passionate and deeply idealistic, you are willing to sacrifice comfort and convention for your beliefs. Spiritually powerful and courageous, you can be extreme or impulsive — yet your visionary fire ignites real transformation.'},
{n:'Uttara Bhadrapada',h:'उत्तरभाद्रपदा',lord:'Saturn',yoni:'Cow',gana:'Manushya',nadi:'Antya',varna:'Kshatriya',deity:'Ahir Budhnya',sym:'Funeral cot back',p:['Du','Tha','Jha','Nya'],traits:'Wise, patient and profoundly compassionate, you are a deep thinker with extraordinary inner strength and spiritual endurance. A quiet warrior who serves selflessly, your power grows beneath the surface and impacts lives in ways rarely visible.'},
{n:'Revati',h:'रेवती',lord:'Mercury',yoni:'Elephant',gana:'Deva',nadi:'Antya',varna:'Brahmin',deity:'Pushan',sym:'Fish/Drum',p:['De','Do','Cha','Chi'],traits:'Compassionate, nurturing and deeply spiritual, you carry a universal love and the gift of empathy. Artistic, imaginative and gentle, you are a bridge-builder who completes cycles and guides souls gently across transitions and thresholds.'}];

const sel=document.getElementById('f-city');sel.innerHTML=LOCS.map(l=>`<option>${l.name}</option>`).join('');
document.getElementById('f-date').value=new Date().toISOString().split('T')[0];
document.getElementById('f-time').value='12:00';

function calculate(){
  try{
    const dateStr=document.getElementById('f-date').value;
    const timeStr=document.getElementById('f-time').value||'12:00';
    const loc=LOCS.find(l=>l.name===document.getElementById('f-city').value)||LOCS[0];
    const [y,m,d]=dateStr.split('-').map(Number);const [hh,mm]=timeStr.split(':').map(Number);
    const jd=toJD(y,m,d,(hh+mm/60)-loc.tz);
    const T=(jd-2451545)/36525;const ay=ayanamsha(T);
    const sid=n360(moonLon(jd)-ay);
    const idx=Math.floor(sid/(360/27));const pada=Math.floor((sid%(360/27))/((360/27)/4))+1;
    const nk=NAKS[idx];
    document.getElementById('n-name').textContent=nk.n+' \xb7 '+nk.h;
    document.getElementById('n-meta').textContent='Pada '+pada+' \xb7 Ruled by '+nk.lord+' \xb7 Deity: '+nk.deity;
    document.getElementById('trait-title').textContent=nk.n+' — Personality Profile';
    document.getElementById('trait-text').textContent=nk.traits;
    document.getElementById('n-badges').innerHTML=
      `<span class="badge badge-saffron">${nk.gana} Gana</span><span class="badge">${nk.nadi} Nadi</span><span class="badge">${nk.yoni} Yoni</span><span class="badge">Syllable: ${nk.p[pada-1]}</span>`;
    document.getElementById('attr-list').innerHTML=[
      ['Nakshatra',`${nk.n} (#${idx+1})`],['Pada',String(pada)],['Lord',nk.lord],['Deity',nk.deity],
      ['Symbol',nk.sym],['Yoni (Animal)',nk.yoni],['Gana',nk.gana],['Nadi',nk.nadi],['Varna',nk.varna],['Ayanamsha',`${ay.toFixed(3)}° Lahiri`]
    ].map(r=>`<div class="dl-row"><span>${r[0]}</span><span>${r[1]}</span></div>`).join('');
    document.getElementById('pada-list').innerHTML=nk.p.map((s,i)=>
      `<div style="display:flex;align-items:center;gap:10px;padding:7px 10px;border-radius:7px;background:${i===pada-1?'var(--color-saffron-soft)':'var(--color-canvas-soft-2)'};">
        <span style="font-size:11px;font-weight:600;color:var(--color-mute);font-family:var(--font-mono);">Pada ${i+1}</span>
        <span style="font-size:15px;font-weight:700;color:${i===pada-1?'var(--color-saffron-deep)':'var(--color-ink)'};">${s}</span>
        ${i===pada-1?'<span class="badge badge-saffron" style="margin-left:auto;">Your pada</span>':''}
      </div>`).join('');
    document.getElementById('result').style.display='block';
    document.getElementById('err').style.display='none';
  }catch(e){const er=document.getElementById('err');er.style.display='block';er.textContent='Calculation error: '+e.message;}
}
document.getElementById('all-naks').innerHTML=NAKS.map((nk,i)=>
  `<div class="card" style="padding:12px;">
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;">
      <span style="font-size:13px;font-weight:600;color:var(--color-ink);">${nk.n}</span>
      <span style="font-size:10px;color:var(--color-mute);font-family:var(--font-mono);">${i+1}</span>
    </div>
    <p style="font-size:11px;color:var(--color-mute);margin:0;">${nk.h} · ${nk.lord}</p>
    <p style="font-size:10.5px;color:var(--color-body-text);margin:4px 0 0;">${nk.gana} · ${nk.yoni}</p>
  </div>`).join('');
document.getElementById('f-calc').addEventListener('click',calculate);
calculate();
</script>
