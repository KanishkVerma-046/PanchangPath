---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Horoscope Matching — Ashta Kuta Guna Milan — PanchangPath" description="Free Kundli Milan / horoscope matching with the 8-fold Ashta Kuta system. Get your Guna Milan score out of 36 with Varna, Vashya, Tara, Yoni, Graha Maitri, Gana, Bhakoot and Nadi.">

  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:40px 0 32px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <a href="/jyotish" style="font-size:12px;color:var(--color-mute);text-decoration:none;">← Jyotish Tools</a>
      <p class="caption-mono" style="color:var(--color-mute);margin:12px 0 8px;">गुण मिलान · HOROSCOPE MATCH</p>
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-1.2px;color:var(--color-ink);margin:0 0 10px;">Horoscope Matching (Ashta Kuta)</h1>
      <p style="font-size:15px;color:var(--color-body-text);margin:0;max-width:520px;">Compare two birth charts using the traditional 8-fold Guna Milan system. Enter both birth details to get a compatibility score out of 36.</p>
    </div>
  </section>

  <section style="padding:28px 0 56px;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;" class="two-col">
        <div class="card" style="padding:20px;">
          <h3 style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 14px;">👦 Boy / Groom</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div><label class="fld-label">Date of Birth</label><input type="date" id="b-date" class="input" style="height:38px;" /></div>
            <div><label class="fld-label">Time of Birth</label><input type="time" id="b-time" class="input" style="height:38px;" /></div>
            <div><label class="fld-label">Place</label><select id="b-city" class="input" style="height:38px;"></select></div>
          </div>
        </div>
        <div class="card" style="padding:20px;">
          <h3 style="font-size:14px;font-weight:600;color:var(--color-ink);margin:0 0 14px;">👧 Girl / Bride</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div><label class="fld-label">Date of Birth</label><input type="date" id="g-date" class="input" style="height:38px;" /></div>
            <div><label class="fld-label">Time of Birth</label><input type="time" id="g-time" class="input" style="height:38px;" /></div>
            <div><label class="fld-label">Place</label><select id="g-city" class="input" style="height:38px;"></select></div>
          </div>
        </div>
      </div>
      <div style="text-align:center;margin-bottom:32px;">
        <button id="f-calc" class="btn-primary" style="height:42px;padding:0 32px;font-size:15px;">Match Horoscopes</button>
      </div>

      <div id="result" style="display:none;">
        <div class="card" id="score-banner" style="padding:28px;text-align:center;margin-bottom:24px;"></div>
        <div class="card" style="padding:20px;overflow-x:auto;margin-bottom:24px;">
          <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">Ashta Kuta Breakdown</h3>
          <table style="width:100%;border-collapse:collapse;font-size:13px;" id="kuta-table"></table>
        </div>
        <div class="card" id="verdict-box" style="padding:24px;"></div>
      </div>
      <div id="err" style="display:none;padding:16px;background:var(--color-inauspicious-soft);border-radius:8px;color:#b91c1c;font-size:14px;"></div>

      <div class="card" style="padding:28px;margin-top:36px;">
        <h2 style="font-size:18px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">About Guna Milan</h2>
        <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0 0 10px;">Ashta Kuta Guna Milan compares the Moon\'s nakshatra and rashi of two people across 8 factors (kutas), each carrying a different weight, totalling 36 points. A score of 18 or above is traditionally considered acceptable for marriage; 24+ is very good.</p>
        <p style="font-size:13px;color:var(--color-mute);line-height:1.7;margin:0;">The Nadi (8 points) and Bhakoot (7 points) kutas are the most important — a Nadi dosha (same nadi) or Bhakoot dosha can override a high score, though many such doshas have classical cancellations. Always consult an astrologer for a full reading.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fld-label { font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em; }
  #kuta-table th { text-align:left;padding:7px 8px;border-bottom:1px solid var(--color-hairline);color:var(--color-mute);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.04em; }
  #kuta-table td { padding:8px;border-bottom:1px solid var(--color-hairline);color:var(--color-body-text); }
  @media (max-width:640px){ .two-col{ grid-template-columns:1fr !important; } }
</style>

<script>
const LOCS=[{name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},{name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},{name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},{name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},{name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},{name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},{name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},{name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},{name:'Ahmedabad',lat:23.0225,lng:72.5714,tz:5.5},{name:'Pune',lat:18.5204,lng:73.8567,tz:5.5},{name:'Dubai',lat:25.2048,lng:55.2708,tz:4},{name:'Singapore',lat:1.3521,lng:103.8198,tz:8},{name:'New York',lat:40.7128,lng:-74.006,tz:-5},{name:'London',lat:51.5074,lng:-0.1278,tz:0},{name:'Toronto',lat:43.6532,lng:-79.3832,tz:-5}];
function toJD(y,m,d,h){h=h||0;if(m<=2){y--;m+=12;}const A=Math.floor(y/100),B=2-A+Math.floor(A/4);return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;}
const n360=a=>((a%360)+360)%360;
const toR=d=>d*Math.PI/180;
function ayanamsha(T){return 23.85+1.3612*T-0.000136*T*T;}
function moonLon(jd){const T=(jd-2451545)/36525;const Lm=n360(218.3164477+481267.88123421*T);const D=n360(297.8501921+445267.1114034*T);const M=n360(357.5291092+35999.0502909*T);const Mp=n360(134.9633964+477198.8675055*T);const F=n360(93.2720950+483202.0175233*T);const dL=6.288774*Math.sin(toR(Mp))+1.274027*Math.sin(toR(2*D-Mp))+0.658314*Math.sin(toR(2*D))+0.213618*Math.sin(toR(2*Mp))-0.185116*Math.sin(toR(M))-0.114332*Math.sin(toR(2*F));return n360(Lm+dL/1000);}

const RASHI=['Mesha','Vrishabha','Mithuna','Karka','Simha','Kanya','Tula','Vrishchika','Dhanu','Makara','Kumbha','Meena'];
const NAKS=['Ashwini','Bharani','Krittika','Rohini','Mrigashira','Ardra','Punarvasu','Pushya','Ashlesha','Magha','Purva Phalguni','Uttara Phalguni','Hasta','Chitra','Swati','Vishakha','Anuradha','Jyeshtha','Mula','Purva Ashadha','Uttara Ashadha','Shravana','Dhanishtha','Shatabhisha','Purva Bhadrapada','Uttara Bhadrapada','Revati'];
const GANA=[0,1,2,1,0,1,0,0,2,2,1,1,0,2,0,2,0,2,2,1,1,0,2,2,1,1,0]; // 0 Deva,1 Manushya,2 Rakshasa
const GANA_NAME=['Deva','Manushya','Rakshasa'];
const NADI=[0,1,2,2,1,0,0,1,2,2,1,2,0,1,0,1,0,1,2,0,1,2,1,0,1,2,2]; // 0 Adi,1 Madhya,2 Antya
const NADI_NAME=['Adi','Madhya','Antya'];
const YONI=[0,1,2,3,3,4,5,2,5,6,6,7,8,9,8,9,10,10,4,11,12,11,13,0,13,7,1];
const YONI_NAME=['Horse','Elephant','Sheep','Serpent','Dog','Cat','Rat','Cow','Buffalo','Tiger','Deer','Monkey','Mongoose','Lion'];
const VASHYA=[1,1,0,4,3,0,0,4,1,2,0,2]; // by rashi
const RASHI_LORD=[2,5,3,1,0,3,5,2,4,6,6,4];
const PLANET_NAME=['Sun','Moon','Mars','Mercury','Jupiter','Venus','Saturn'];
const PLT_FRIEND=[[2,2,2,1,2,0,0],[2,2,1,2,1,1,1],[2,1,2,0,2,1,1],[2,0,1,2,1,2,1],[2,2,2,0,2,0,1],[0,0,1,2,1,2,2],[0,0,1,2,1,2,2]];
const VARNA_RANK=[3,2,1,4,3,2,1,4,3,2,1,4]; // by rashi: Brahmin4 Ksh3 Vaishya2 Shudra1
const VARNA_NAME=['','Shudra','Vaishya','Kshatriya','Brahmin'];
// Yoni bitter-enemy pairs (0 pts)
const YONI_ENEMY=[[5,6],[7,9],[1,13],[0,8],[4,10],[3,12],[11,2]];

['b-city','g-city'].forEach(id=>document.getElementById(id).innerHTML=LOCS.map(l=>`<option>${l.name}</option>`).join(''));
document.getElementById('b-date').value='1995-06-15';document.getElementById('b-time').value='10:30';
document.getElementById('g-date').value='1997-09-20';document.getElementById('g-time').value='14:15';

function moonNakRashi(dateStr,timeStr,loc){
  const [y,m,d]=dateStr.split('-').map(Number);const [hh,mm]=(timeStr||'12:00').split(':').map(Number);
  const jd=toJD(y,m,d,(hh+mm/60)-loc.tz);const T=(jd-2451545)/36525;const ay=ayanamsha(T);
  const sid=n360(moonLon(jd)-ay);
  return{nak:Math.floor(sid/(360/27)),rashi:Math.floor(sid/30)};
}

function kVarna(b,g){const pt=VARNA_RANK[b.rashi]>=VARNA_RANK[g.rashi]?1:0;return{pt,max:1,bd:VARNA_NAME[VARNA_RANK[b.rashi]],gd:VARNA_NAME[VARNA_RANK[g.rashi]]};}
function kVashya(b,g){const bv=VASHYA[b.rashi],gv=VASHYA[g.rashi];let pt;if(bv===gv)pt=2;else if(Math.abs(bv-gv)===1)pt=1;else if((bv===0&&gv===2)||(gv===0&&bv===2))pt=1;else pt=0.5;return{pt,max:2,bd:String(bv),gd:String(gv)};}
function kTara(b,g){let good=0;[[b.nak,g.nak],[g.nak,b.nak]].forEach(([s,t])=>{let c=((t-s+27)%27)+1;let tara=c%9;if(tara===0)tara=9;if(![3,5,7].includes(tara))good++;});const pt=good*1.5;return{pt,max:3,bd:NAKS[b.nak],gd:NAKS[g.nak]};}
function kYoni(b,g){const by=YONI[b.nak],gy=YONI[g.nak];let pt;if(by===gy)pt=4;else if(YONI_ENEMY.some(p=>(p[0]===by&&p[1]===gy)||(p[1]===by&&p[0]===gy)))pt=0;else pt=3;return{pt,max:4,bd:YONI_NAME[by],gd:YONI_NAME[gy]};}
function kMaitri(b,g){const bl=RASHI_LORD[b.rashi],gl=RASHI_LORD[g.rashi];if(bl===gl)return{pt:5,max:5,bd:PLANET_NAME[bl],gd:PLANET_NAME[gl]};const r1=PLT_FRIEND[bl][gl],r2=PLT_FRIEND[gl][bl];const s=r1+r2;let pt;if(s===4)pt=5;else if(s===3)pt=4;else if(s===2)pt=3;else if(s===1)pt=0.5;else pt=0;return{pt,max:5,bd:PLANET_NAME[bl],gd:PLANET_NAME[gl]};}
function kGana(b,g){const bg=GANA[b.nak],gg=GANA[g.nak];let pt;if(bg===gg)pt=6;else{const pair=[bg,gg].sort().join('');if(pair==='01')pt=(bg===0?6:5);else if(pair==='02')pt=1;else pt=0;}return{pt,max:6,bd:GANA_NAME[bg],gd:GANA_NAME[gg]};}
function kBhakoot(b,g){const d1=((g.rashi-b.rashi+12)%12)+1;const d2=((b.rashi-g.rashi+12)%12)+1;const set=[d1,d2].sort((x,y)=>x-y).join('-');const bad=['6-8','2-12','5-9'];const pt=bad.includes(set)?0:7;return{pt,max:7,bd:RASHI[b.rashi],gd:RASHI[g.rashi]};}
function kNadi(b,g){const pt=NADI[b.nak]===NADI[g.nak]?0:8;return{pt,max:8,bd:NADI_NAME[NADI[b.nak]],gd:NADI_NAME[NADI[g.nak]]};}

function calculate(){
  try{
    const bLoc=LOCS.find(l=>l.name===document.getElementById('b-city').value)||LOCS[0];
    const gLoc=LOCS.find(l=>l.name===document.getElementById('g-city').value)||LOCS[0];
    const b=moonNakRashi(document.getElementById('b-date').value,document.getElementById('b-time').value,bLoc);
    const g=moonNakRashi(document.getElementById('g-date').value,document.getElementById('g-time').value,gLoc);

    const kutas=[
      ['Varna',kVarna(b,g),'Spiritual / ego compatibility'],
      ['Vashya',kVashya(b,g),'Mutual attraction & control'],
      ['Tara',kTara(b,g),'Health & wellbeing / destiny'],
      ['Yoni',kYoni(b,g),'Physical & sexual compatibility'],
      ['Graha Maitri',kMaitri(b,g),'Mental & intellectual bond'],
      ['Gana',kGana(b,g),'Temperament compatibility'],
      ['Bhakoot',kBhakoot(b,g),'Love, finances & family'],
      ['Nadi',kNadi(b,g),'Health & progeny (constitution)'],
    ];
    let total=0,max=0;kutas.forEach(k=>{total+=k[1].pt;max+=k[1].max;});

    const color=total>=18?'#15803d':total>=14?'#b45309':'#dc2626';
    const bg=total>=18?'var(--color-auspicious-soft)':total>=14?'var(--color-warning-soft)':'var(--color-inauspicious-soft)';
    document.getElementById('score-banner').style.background=bg;
    document.getElementById('score-banner').innerHTML=
      `<p class="caption-mono" style="color:${color};margin:0 0 6px;">GUNA MILAN SCORE</p>
       <div style="font-size:48px;font-weight:700;color:${color};line-height:1;">${total% 1===0?total:total.toFixed(1)} <span style="font-size:22px;color:var(--color-mute);">/ ${max}</span></div>
       <p style="font-size:13px;color:var(--color-body-text);margin:10px 0 0;">Boy: ${NAKS[b.nak]} / ${RASHI[b.rashi]} &nbsp;·&nbsp; Girl: ${NAKS[g.nak]} / ${RASHI[g.rashi]}</p>`;

    let rows=`<tr><th>Kuta</th><th>Boy</th><th>Girl</th><th>Points</th><th>Significance</th></tr>`;
    kutas.forEach(([name,k,sig])=>{
      const pc=k.pt===0?'#dc2626':k.pt>=k.max*0.5?'#15803d':'#b45309';
      rows+=`<tr><td style="color:var(--color-ink);font-weight:600;">${name}</td><td>${k.bd}</td><td>${k.gd}</td><td style="font-weight:700;color:${pc};">${k.pt%1===0?k.pt:k.pt.toFixed(1)} / ${k.max}</td><td style="font-size:12px;color:var(--color-mute);">${sig}</td></tr>`;
    });
    document.getElementById('kuta-table').innerHTML=rows;

    const nadiDosha=kutas[7][1].pt===0;const bhakootDosha=kutas[6][1].pt===0;
    let verdict,vColor,rec;
    if(total>=28){verdict='Excellent Match';vColor='#15803d';rec='An outstanding compatibility score. This is a highly auspicious union with strong harmony across mind, body and values.';}
    else if(total>=18){verdict='Good Match';vColor='#15803d';rec='A favourable match that meets the traditional threshold for marriage. Minor differences can be worked through with understanding.';}
    else if(total>=14){verdict='Average Match';vColor='#b45309';rec='A borderline match. Marriage is possible but careful consideration of the weaker kutas and any doshas is advised.';}
    else{verdict='Poor Match';vColor='#dc2626';rec='The score falls below the traditional threshold. Consult an experienced astrologer to examine doshas and possible remedies before proceeding.';}
    let doshaNote='';
    if(nadiDosha)doshaNote+='<p style="font-size:13px;color:#b91c1c;margin:8px 0 0;">⚠ Nadi Dosha present (same Nadi) — classically a concern for health & progeny. Check for cancellations (same rashi different nakshatra, etc.).</p>';
    if(bhakootDosha)doshaNote+='<p style="font-size:13px;color:#b91c1c;margin:8px 0 0;">⚠ Bhakoot Dosha present — may affect finances and family harmony. Often cancelled if Graha Maitri is strong.</p>';
    document.getElementById('verdict-box').innerHTML=
      `<h3 style="font-size:18px;font-weight:700;color:${vColor};margin:0 0 8px;">${verdict}</h3>
       <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0;">${rec}</p>${doshaNote}`;

    document.getElementById('result').style.display='block';
    document.getElementById('err').style.display='none';
  }catch(e){const er=document.getElementById('err');er.style.display='block';er.textContent='Calculation error: '+e.message;document.getElementById('result').style.display='none';}
}
document.getElementById('f-calc').addEventListener('click',calculate);
calculate();
</script>
