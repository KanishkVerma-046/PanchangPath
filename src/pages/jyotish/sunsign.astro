---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sun Sign Calculator — Vedic & Western — PanchangPath" description="Find both your Vedic (sidereal) and Western (tropical) Sun signs from birth date, time and location, with element, quality, ruler, compatible signs and personality traits.">

  <section style="background:var(--color-canvas);border-bottom:1px solid var(--color-hairline);padding:40px 0 32px;position:relative;overflow:hidden;">
    <div class="gradient-mesh" style="position:absolute;inset:0;opacity:0.4;pointer-events:none;"></div>
    <div class="container" style="position:relative;">
      <a href="/jyotish" style="font-size:12px;color:var(--color-mute);text-decoration:none;">← Jyotish Tools</a>
      <p class="caption-mono" style="color:var(--color-mute);margin:12px 0 8px;">सूर्य राशि · SUNSIGN CALCULATOR</p>
      <h1 style="font-size:30px;font-weight:600;letter-spacing:-1.2px;color:var(--color-ink);margin:0 0 10px;">Sun Sign Calculator</h1>
      <p style="font-size:15px;color:var(--color-body-text);margin:0;max-width:520px;">See both your Sun signs — the Western (tropical) sign used in popular horoscopes, and the Vedic (sidereal) sun sign used in Jyotish — along with their personality traits.</p>
    </div>
  </section>

  <section style="padding:28px 0 56px;">
    <div class="container">
      <div style="display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-bottom:32px;">
        <div><label class="fld-label">Date of Birth</label><input type="date" id="f-date" class="input" style="height:38px;" /></div>
        <div><label class="fld-label">Time of Birth <span style="font-size:10px;color:var(--color-mute);">(optional, helps on cusp days)</span></label><input type="time" id="f-time" class="input" style="height:38px;" /></div>
        <div><label class="fld-label">Place of Birth <span style="font-size:10px;color:var(--color-mute);">(optional)</span></label><select id="f-city" class="input" style="height:38px;min-width:140px;"></select></div>
        <button id="f-calc" class="btn-primary" style="height:38px;padding:0 20px;">Calculate</button>
      </div>

      <div id="result" style="display:none;">
        <!-- Side-by-side sign cards -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;" class="two-col">
          <div class="card" id="card-w" style="padding:24px;text-align:center;"></div>
          <div class="card" id="card-v" style="padding:24px;text-align:center;border-top:3px solid var(--color-saffron-deep);"></div>
        </div>
        <!-- Difference note -->
        <div class="card" style="padding:20px;margin-bottom:24px;">
          <h3 style="font-size:13px;font-weight:600;color:var(--color-ink);margin:0 0 6px;">Why are they different?</h3>
          <p id="diff-note" style="font-size:13.5px;color:var(--color-body-text);line-height:1.7;margin:0;"></p>
        </div>
        <!-- Vedic sign personality traits -->
        <div class="card" style="padding:24px;">
          <p class="caption-mono" style="color:var(--color-saffron-deep);margin:0 0 4px;">VEDIC SUN SIGN — SOLAR PERSONALITY</p>
          <h3 id="trait-title" style="font-size:18px;font-weight:700;color:var(--color-ink);margin:0 0 10px;"></h3>
          <p id="trait-text" style="font-size:14px;color:var(--color-body-text);line-height:1.75;margin:0;"></p>
        </div>
      </div>
      <div id="err" style="display:none;padding:16px;background:var(--color-inauspicious-soft);border-radius:8px;color:#b91c1c;font-size:14px;"></div>

      <div class="card" style="padding:28px;margin-top:36px;">
        <h2 style="font-size:18px;font-weight:600;color:var(--color-ink);margin:0 0 12px;">About Sun Signs</h2>
        <p style="font-size:14px;color:var(--color-body-text);line-height:1.7;margin:0 0 10px;">Western astrology uses the <b>tropical zodiac</b>, anchored to the seasons (Aries always begins at the spring equinox). Vedic astrology uses the <b>sidereal zodiac</b>, anchored to the actual fixed stars. Due to the precession of the equinoxes, the two have drifted apart by roughly 24&deg; over millennia.</p>
        <p style="font-size:13px;color:var(--color-mute);line-height:1.7;margin:0;">A person born in late March will typically be a Western Aries but a Vedic Pisces. Both systems are internally consistent — they just measure from different reference points. In Jyotish, the Vedic Sun sign describes the soul's core purpose, while the Moon sign (Rashi) governs the mind and daily life.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fld-label { font-size:11px;font-weight:500;color:var(--color-mute);display:block;margin-bottom:5px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.06em; }
  @media (max-width:640px){ .two-col{ grid-template-columns:1fr !important; } }
</style>

<script>
const LOCS=[{name:'New Delhi',lat:28.6139,lng:77.209,tz:5.5},{name:'Mumbai',lat:19.076,lng:72.8777,tz:5.5},{name:'Bengaluru',lat:12.9716,lng:77.5946,tz:5.5},{name:'Chennai',lat:13.0827,lng:80.2707,tz:5.5},{name:'Kolkata',lat:22.5726,lng:88.3639,tz:5.5},{name:'Hyderabad',lat:17.385,lng:78.4867,tz:5.5},{name:'Jaipur',lat:26.9124,lng:75.7873,tz:5.5},{name:'Varanasi',lat:25.3176,lng:82.9739,tz:5.5},{name:'Ahmedabad',lat:23.0225,lng:72.5714,tz:5.5},{name:'Pune',lat:18.5204,lng:73.8567,tz:5.5},{name:'Dubai',lat:25.2048,lng:55.2708,tz:4},{name:'Singapore',lat:1.3521,lng:103.8198,tz:8},{name:'New York',lat:40.7128,lng:-74.006,tz:-5},{name:'London',lat:51.5074,lng:-0.1278,tz:0},{name:'Toronto',lat:43.6532,lng:-79.3832,tz:-5}];
function toJD(y,m,d,h){h=h||0;if(m<=2){y--;m+=12;}const A=Math.floor(y/100),B=2-A+Math.floor(A/4);return Math.floor(365.25*(y+4716))+Math.floor(30.6001*(m+1))+d+h/24+B-1524.5;}
const n360=a=>((a%360)+360)%360;const toR=d=>d*Math.PI/180;
function ayanamsha(T){return 23.85+1.3612*T-0.000136*T*T;}
function sunLon(jd){const T=(jd-2451545)/36525;const L0=n360(280.46646+36000.76983*T+0.0003032*T*T);const M=n360(357.52911+35999.05029*T-0.0001537*T*T);const C=(1.914602-0.004817*T-0.000014*T*T)*Math.sin(toR(M))+(0.019993-0.000101*T)*Math.sin(2*toR(M))+0.000289*Math.sin(3*toR(M));return n360(L0+C);}

const W_SIGNS=[
{name:'Aries',h:'मेष',sym:'♈',from:[3,21],to:[4,19],el:'Fire',ruler:'Mars',quality:'Cardinal',comp:'Leo, Sagittarius, Gemini'},
{name:'Taurus',h:'वृषभ',sym:'♉',from:[4,20],to:[5,20],el:'Earth',ruler:'Venus',quality:'Fixed',comp:'Virgo, Capricorn, Cancer'},
{name:'Gemini',h:'मिथुन',sym:'♊',from:[5,21],to:[6,20],el:'Air',ruler:'Mercury',quality:'Mutable',comp:'Libra, Aquarius, Aries'},
{name:'Cancer',h:'कर्क',sym:'♋',from:[6,21],to:[7,22],el:'Water',ruler:'Moon',quality:'Cardinal',comp:'Scorpio, Pisces, Taurus'},
{name:'Leo',h:'सिंह',sym:'♌',from:[7,23],to:[8,22],el:'Fire',ruler:'Sun',quality:'Fixed',comp:'Aries, Sagittarius, Libra'},
{name:'Virgo',h:'कन्या',sym:'♍',from:[8,23],to:[9,22],el:'Earth',ruler:'Mercury',quality:'Mutable',comp:'Taurus, Capricorn, Cancer'},
{name:'Libra',h:'तुला',sym:'♎',from:[9,23],to:[10,22],el:'Air',ruler:'Venus',quality:'Cardinal',comp:'Gemini, Aquarius, Leo'},
{name:'Scorpio',h:'वृश्चिक',sym:'♏',from:[10,23],to:[11,21],el:'Water',ruler:'Mars',quality:'Fixed',comp:'Cancer, Pisces, Virgo'},
{name:'Sagittarius',h:'धनु',sym:'♐',from:[11,22],to:[12,21],el:'Fire',ruler:'Jupiter',quality:'Mutable',comp:'Aries, Leo, Aquarius'},
{name:'Capricorn',h:'मकर',sym:'♑',from:[12,22],to:[1,19],el:'Earth',ruler:'Saturn',quality:'Cardinal',comp:'Taurus, Virgo, Scorpio'},
{name:'Aquarius',h:'कुम्भ',sym:'♒',from:[1,20],to:[2,18],el:'Air',ruler:'Saturn',quality:'Fixed',comp:'Gemini, Libra, Sagittarius'},
{name:'Pisces',h:'मीन',sym:'♓',from:[2,19],to:[3,20],el:'Water',ruler:'Jupiter',quality:'Mutable',comp:'Cancer, Scorpio, Capricorn'}];

const RASHI=['Mesha','Vrishabha','Mithuna','Karka','Simha','Kanya','Tula','Vrishchika','Dhanu','Makara','Kumbha','Meena'];

// Solar personality — how the Sun expresses through each Vedic sign
const SOLAR_TRAITS=[
  'Your solar self is bold, pioneering and fiercely independent. The Sun in Mesha gives you a natural drive to initiate, lead and compete. You possess an entrepreneurial spirit and infectious enthusiasm, though patience is a lifelong lesson. Your courage is your greatest asset.',
  'The Sun in Vrishabha bestows a patient, steady and deeply sensual nature. You build slowly and surely, valuing security, beauty and lasting results. Reliable and determined, you rarely give up — but can be resistant to change. Your strength lies in persistence and loyalty.',
  'Your solar energy is quick, curious and multi-faceted. The Sun in Mithuna makes you a natural communicator, thinker and adapter. You thrive on variety and mental stimulation, with a sharp wit and gift for languages. Learning to focus is your great challenge and reward.',
  'The Sun in Karka illuminates through emotional depth, nurturing and intuition. Home, family and roots are central to your identity. You are deeply empathetic and protective of those you love, with a powerful inner world and psychic sensitivity.',
  'The Sun rules Simha and shines brightest here — gifting you with charisma, generosity and a natural dramatic flair. You were born to lead, create and be seen. Pride and a need for recognition can challenge you, but your warmth and loyalty make you a natural centre of any group.',
  'Your solar nature is analytical, precise and deeply service-oriented. The Sun in Kanya drives you to improve, refine and be of genuine use. You notice what others miss and have a powerful intellect, though self-criticism can undermine your confidence. Perfection-seeking is both your strength and your shadow.',
  'The Sun in Tula seeks balance, beauty and harmonious connection. You are naturally diplomatic, charming and fair-minded, with a refined aesthetic sense. Partnership is central to your solar purpose. Indecision and people-pleasing are the edges you must navigate.',
  'Intense, perceptive and deeply transformative — the Sun in Vrishchika gives you extraordinary willpower and the courage to dive into the darkest corners of life. You are drawn to mystery, power and psychological depth. Trust is earned slowly, but your loyalty is fierce and lasting.',
  'The Sun in Dhanu is adventurous, philosophical and eternally optimistic. You seek truth, wisdom and the freedom to explore — in thought, culture and geography. Honesty is your core value, sometimes delivered bluntly. Your solar purpose is to expand horizons and inspire others.',
  'Disciplined, ambitious and profoundly responsible, the Sun in Makara gives you an unmatched capacity for long-term effort. You build legacies, respect structures and are willing to sacrifice immediate comfort for lasting achievement. Status and integrity matter deeply to you.',
  'The Sun in Kumbha is original, humanitarian and intellectually independent. You are drawn to ideals, communities and visions of a better future. Friendly yet detached, you march to your own drum. Your solar purpose is to liberate, innovate and serve the collective.',
  'The Sun in Meena is compassionate, imaginative and spiritually attuned. You feel everything deeply and have an innate connection to the unseen. Artistic, empathetic and selfless, you are here to serve as a bridge between worlds. Boundaries and groundedness are the skills to cultivate.'
];

const sel=document.getElementById('f-city');
sel.innerHTML='<option value="0">None (use date only)</option>'+LOCS.map((l,i)=>`<option value="${i+1}">${l.name}</option>`).join('');
document.getElementById('f-date').value=new Date().toISOString().split('T')[0];
document.getElementById('f-time').value='12:00';

function westernSign(m,d){
  for(let i=0;i<12;i++){const s=W_SIGNS[i];const[fm,fd]=s.from;const[tm,td]=s.to;
    if(fm<=tm){if((m===fm&&d>=fd)||(m===tm&&d<=td)||(m>fm&&m<tm))return i;}
    else{if((m===fm&&d>=fd)||(m===tm&&d<=td)||m>fm||m<tm)return i;}}
  return 0;
}
function fmtRange(s){const M=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];return M[s.from[0]-1]+' '+s.from[1]+' – '+M[s.to[0]-1]+' '+s.to[1];}
function signCard(s,label,subname,showTraits){
  return `<p class="caption-mono" style="color:var(--color-saffron-deep);margin:0 0 8px;">${label}</p>
    <div style="font-size:52px;line-height:1;margin-bottom:6px;">${s.sym}</div>
    <h2 style="font-size:24px;font-weight:700;color:var(--color-ink);margin:0 0 2px;">${s.name}</h2>
    <p style="font-size:13px;color:var(--color-mute);margin:0 0 14px;">${subname}</p>
    <div style="display:flex;flex-direction:column;gap:7px;text-align:left;max-width:240px;margin:0 auto;">
      ${[['Dates',fmtRange(s)],['Element',s.el],['Quality',s.quality],['Ruler',s.ruler],['Compatible',s.comp]].map(r=>`<div style="display:flex;justify-content:space-between;gap:8px;font-size:12.5px;"><span style="color:var(--color-mute);">${r[0]}</span><span style="color:var(--color-ink);font-weight:600;text-align:right;">${r[1]}</span></div>`).join('')}
    </div>`;
}

function calculate(){
  try{
    const dateStr=document.getElementById('f-date').value;
    const timeStr=document.getElementById('f-time').value||'12:00';
    const cityVal=parseInt(document.getElementById('f-city').value)||0;
    const loc=cityVal>0?LOCS[cityVal-1]:null;
    const tz=loc?loc.tz:0;
    const[y,m,d]=dateStr.split('-').map(Number);
    const[hh,mm]=timeStr.split(':').map(Number);
    const wIdx=westernSign(m,d);
    const jd=toJD(y,m,d,(hh+mm/60)-tz);
    const T=(jd-2451545)/36525;
    const vIdx=Math.floor(n360(sunLon(jd)-ayanamsha(T))/30);

    document.getElementById('card-w').innerHTML=signCard(W_SIGNS[wIdx],'WESTERN (TROPICAL)',W_SIGNS[wIdx].h);
    document.getElementById('card-v').innerHTML=signCard(W_SIGNS[vIdx],'VEDIC (SIDEREAL)',RASHI[vIdx]+' \xb7 '+W_SIGNS[vIdx].h);

    document.getElementById('diff-note').textContent=vIdx===wIdx
      ?'Your Western and Vedic Sun signs are both '+W_SIGNS[wIdx].name+'. This happens when the Sun is far enough into the sign that the ~24\xb0 ayanamsha shift does not push it into the previous sign.'
      :'Your Western Sun sign is '+W_SIGNS[wIdx].name+', but your Vedic Sun sign is '+RASHI[vIdx]+' ('+W_SIGNS[vIdx].name+'). The difference comes from the ayanamsha — the ~24\xb0 precession gap between the tropical and sidereal zodiacs.';

    document.getElementById('trait-title').textContent=RASHI[vIdx]+' ('+W_SIGNS[vIdx].name+') Sun';
    document.getElementById('trait-text').textContent=SOLAR_TRAITS[vIdx];

    document.getElementById('result').style.display='block';
    document.getElementById('err').style.display='none';
  }catch(e){const er=document.getElementById('err');er.style.display='block';er.textContent='Calculation error: '+e.message;}
}
document.getElementById('f-calc').addEventListener('click',calculate);
calculate();
</script>
